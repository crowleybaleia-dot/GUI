                        isOpen = false
                        Tween(chevron, { Rotation = 0 }, 0.2)
                        Tween(dropList, { Size = UDim2.new(1, 0, 0, 0) }, 0.2)
                        task.wait(0.22)
                        dropList.Visible = false
                        callback(selected)
                    end)
                end

                local totalH = #options * 28
                dropBtn.MouseButton1Click:Connect(function()
                    isOpen = not isOpen
                    if isOpen then
                        dropList.Visible = true
                        dropList.Size = UDim2.new(1, 0, 0, 0)
                        Tween(dropList, { Size = UDim2.new(1, 0, 0, totalH) }, 0.25, Enum.EasingStyle.Back)
                        Tween(chevron, { Rotation = 180 }, 0.2)
                    else
                        Tween(chevron, { Rotation = 0 }, 0.2)
                        Tween(dropList, { Size = UDim2.new(1, 0, 0, 0) }, 0.2)
                        task.wait(0.22)
                        dropList.Visible = false
                    end
                end)

                local DropObj = {}
                function DropObj:Set(v) selected = v; selectedLabel.Text = tostring(v) end
                function DropObj:Get() return selected end
                return DropObj
            end

            -- ──────────────────────────
            --  TEXTBOX
            -- ──────────────────────────
            function Section:AddTextBox(cfg)
                cfg = cfg or {}
                local name        = cfg.Name        or "TextBox"
                local placeholder = cfg.Placeholder or "Enter value..."
                local default     = cfg.Default     or ""
                local numberOnly  = cfg.NumberOnly  or false
                local callback    = cfg.Callback    or function() end

                local row = MakeRow(name, 38)

                local box = Create("TextBox", {
                    BackgroundColor3 = Theme.BG_Surface,
                    Position = UDim2.new(0.45, 0, 0.5, -13),
                    Size = UDim2.new(0.55, -4, 0, 26),
                    Text = default,
                    PlaceholderText = placeholder,
                    TextColor3 = Theme.Text_Primary,
                    PlaceholderColor3 = Theme.Text_Muted,
                    Font = Theme.Font_Body,
                    TextSize = 11,
                    ClearTextOnFocus = false,
                    Parent = row,
                })
                AddCorner(box, 7)
                local boxStroke = AddStroke(box, Theme.Border_Subtle, 1)

                box.Focused:Connect(function()
                    Tween(boxStroke, { Color = Theme.Pink_Vivid }, 0.2)
                    Tween(box, { BackgroundColor3 = Color3.fromRGB(55, 28, 78) }, 0.2)
                end)
                box.FocusLost:Connect(function(enter)
                    Tween(boxStroke, { Color = Theme.Border_Subtle }, 0.2)
                    Tween(box, { BackgroundColor3 = Theme.BG_Surface }, 0.2)
                    if numberOnly then
                        local n = tonumber(box.Text)
                        if not n then box.Text = default end
                    end
                    if enter then callback(box.Text) end
                end)
                box:GetPropertyChangedSignal("Text"):Connect(function()
                    if numberOnly then
                        box.Text = box.Text:gsub("[^%d%.%-]", "")
                    end
                end)

                local TBObj = {}
                function TBObj:Set(v) box.Text = tostring(v) end
                function TBObj:Get() return box.Text end
                return TBObj
            end

            -- ──────────────────────────
            --  COLOR PICKER
            -- ──────────────────────────
            function Section:AddColorPicker(cfg)
                cfg = cfg or {}
                local name     = cfg.Name     or "Color"
                local default  = cfg.Default  or Color3.fromRGB(255, 105, 180)
                local callback = cfg.Callback or function() end

                local row = MakeRow(name, 38)
                local currentColor = default
                local pickerOpen = false

                -- Swatch
                local swatch = Create("TextButton", {
                    BackgroundColor3 = currentColor,
                    Position = UDim2.new(1, -36, 0.5, -14),
                    Size = UDim2.new(0, 30, 0, 26),
                    Text = "",
                    ClipsDescendants = false,
                    Parent = row,
                })
                AddCorner(swatch, 7)
                AddStroke(swatch, Theme.Border_Subtle, 1)
                MakeGlow(swatch, currentColor, 8, 0.6)

                -- Mini picker panel
                local pickerPanel = Create("Frame", {
                    BackgroundColor3 = Theme.BG_Elevated,
                    Position = UDim2.new(1, -200, 1, 6),
                    Size = UDim2.new(0, 190, 0, 0),
                    ZIndex = 60,
                    Visible = false,
                    ClipsDescendants = true,
                    Parent = row,
                })
                AddCorner(pickerPanel, 10)
                AddStroke(pickerPanel, Theme.Pink_Muted, 1, 0.3)
                AddPadding(pickerPanel, 10, 10, 10, 10)

                local pickerLayout = Create("UIListLayout", {
                    Padding = UDim.new(0, 8),
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    Parent = pickerPanel,
                })

                -- H, S, V sliders inside picker
                local hsvValues = { H = 0, S = 1, V = 1 }
                do
                    local h, s, v = Color3.toHSV(default)
                    hsvValues.H, hsvValues.S, hsvValues.V = h, s, v
                end

                local function RebuildColor()
                    currentColor = Color3.fromHSV(hsvValues.H, hsvValues.S, hsvValues.V)
                    swatch.BackgroundColor3 = currentColor
                    local glowImg = swatch:FindFirstChildOfClass("ImageLabel")
                    if glowImg then glowImg.ImageColor3 = currentColor end
                    callback(currentColor)
                end

                local sliderDefs = {
                    { label = "H", key = "H", color1 = Color3.fromRGB(255,0,0), color2 = Color3.fromRGB(255,0,255) },
                    { label = "S", key = "S", color1 = Color3.fromRGB(200,200,200), color2 = Color3.fromRGB(255,105,180) },
                    { label = "V", key = "V", color1 = Color3.fromRGB(0,0,0), color2 = Color3.fromRGB(255,255,255) },
                }

                for i, sd in ipairs(sliderDefs) do
                    local slRow = Create("Frame", {
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 28),
                        LayoutOrder = i,
                        Parent = pickerPanel,
                    })
                    Create("TextLabel", {
                        BackgroundTransparency = 1,
                        Size = UDim2.new(0, 14, 0, 28),
                        Text = sd.label,
                        TextColor3 = Theme.Text_Muted,
                        Font = Theme.Font_Mono,
                        TextSize = 10,
                        Parent = slRow,
                    })
                    local slTrack = Create("Frame", {
                        BackgroundColor3 = Theme.BG_Surface,
                        Position = UDim2.new(0, 18, 0.5, -5),
                        Size = UDim2.new(1, -18, 0, 10),
                        Parent = slRow,
                    })
                    AddCorner(slTrack, 999)
                    Create("UIGradient", {
                        Color = ColorSequence.new({
                            ColorSequenceKeypoint.new(0, sd.color1),
                            ColorSequenceKeypoint.new(1, sd.color2),
                        }),
                        Parent = slTrack,
                    })
                    local slThumb = Create("Frame", {
                        BackgroundColor3 = Color3.fromRGB(255,255,255),
                        AnchorPoint = Vector2.new(0.5, 0.5),
                        Position = UDim2.new(hsvValues[sd.key], 0, 0.5, 0),
                        Size = UDim2.new(0, 12, 0, 12),
                        ZIndex = 5,
                        Parent = slTrack,
                    })
                    AddCorner(slThumb, 999)
                    AddStroke(slThumb, Color3.fromRGB(255,255,255), 2)

                    local draggingHSV = false
                    slTrack.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            draggingHSV = true
                            local pct = math.clamp((input.Position.X - slTrack.AbsolutePosition.X) / slTrack.AbsoluteSize.X, 0, 1)
                            hsvValues[sd.key] = pct
                            slThumb.Position = UDim2.new(pct, 0, 0.5, 0)
                            RebuildColor()
                        end
                    end)
                    UserInputService.InputChanged:Connect(function(input)
                        if draggingHSV and input.UserInputType == Enum.UserInputType.MouseMovement then
                            local pct = math.clamp((input.Position.X - slTrack.AbsolutePosition.X) / slTrack.AbsoluteSize.X, 0, 1)
                            hsvValues[sd.key] = pct
                            slThumb.Position = UDim2.new(pct, 0, 0.5, 0)
                            RebuildColor()
                        end
                    end)
                    UserInputService.InputEnded:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingHSV = false end
                    end)
                end

                swatch.MouseButton1Click:Connect(function()
                    pickerOpen = not pickerOpen
                    if pickerOpen then
                        pickerPanel.Visible = true
                        pickerPanel.Size = UDim2.new(0, 190, 0, 0)
                        Tween(pickerPanel, { Size = UDim2.new(0, 190, 0, 120) }, 0.3, Enum.EasingStyle.Back)
                    else
                        Tween(pickerPanel, { Size = UDim2.new(0, 190, 0, 0) }, 0.2)
                        task.wait(0.22)
                        pickerPanel.Visible = false
                    end
                end)

                local CPObj = {}
                function CPObj:Set(c)
                    currentColor = c
                    swatch.BackgroundColor3 = c
                    local h, s, v = Color3.toHSV(c)
                    hsvValues.H, hsvValues.S, hsvValues.V = h, s, v
                end
                function CPObj:Get() return currentColor end
                return CPObj
            end

            -- ──────────────────────────
            --  LABEL
            -- ──────────────────────────
            function Section:AddLabel(text)
                itemOrder = itemOrder + 1
                local row = Create("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 28),
                    LayoutOrder = itemOrder,
                    Parent = sectionCard,
                })
                Create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 4, 0, 0),
                    Size = UDim2.new(1, -8, 1, 0),
                    Text = text,
                    TextColor3 = Theme.Text_Secondary,
                    Font = Theme.Font_Body,
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextWrapped = true,
                    Parent = row,
                })
            end

            -- ──────────────────────────
            --  SEPARATOR
            -- ──────────────────────────
            function Section:AddSeparator(label)
                itemOrder = itemOrder + 1
                local sep = Create("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 24),
                    LayoutOrder = itemOrder,
                    Parent = sectionCard,
                })
                Create("Frame", {
                    BackgroundColor3 = Theme.Border_Subtle,
                    AnchorPoint = Vector2.new(0, 0.5),
                    Position = UDim2.new(0, 0, 0.5, 0),
                    Size = UDim2.new(1, 0, 0, 1),
                    Parent = sep,
                })
                if label then
                    local lbl = Create("Frame", {
                        BackgroundColor3 = Theme.BG_Elevated,
                        AnchorPoint = Vector2.new(0, 0.5),
                        Position = UDim2.new(0, 8, 0.5, 0),
                        Size = UDim2.new(0, 0, 0, 20),
                        AutomaticSize = Enum.AutomaticSize.X,
                        Parent = sep,
                    })
                    AddPadding(lbl, 0, 6, 0, 6)
                    Create("TextLabel", {
                        BackgroundTransparency = 1,
                        Size = UDim2.new(0, 0, 1, 0),
                        AutomaticSize = Enum.AutomaticSize.X,
                        Text = label,
                        TextColor3 = Theme.Pink_Muted,
                        Font = Theme.Font_Title,
                        TextSize = 9,
                        Parent = lbl,
                    })
                end
            end

            return Section
        end -- AddSection

        return Tab
    end -- AddTab

    return Window
end -- CreateWindow

return BarbiUI
