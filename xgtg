function BarbiUI:CreateWindow(config)
    config = config or {}
    local title     = config.Title    or "BarbiUI"
    local subtitle  = config.Subtitle or "Script Panel"
    local key       = config.Key      or Enum.KeyCode.RightShift
    local logoIcon  = config.Icon     or "🎀"

    -- ScreenGui
    local sg = Create("ScreenGui", {
        Name = "BarbiUI_" .. title,
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Global,
        IgnoreGuiInset = true,
        Parent = CoreGui,
    })

    -- Blur effect (protected — many executors don't support BlurEffect)
    local blur = nil
    pcall(function()
        blur = Instance.new("BlurEffect")
        blur.Size = 0
        blur.Parent = game:GetService("Lighting")
    end)

    local function TweenBlur(targetSize, duration)
        if blur then
            pcall(function()
                Tween(blur, { Size = targetSize }, duration or 0.3)
            end)
        end
    end

    -- Main Window Frame
    local windowFrame = Create("Frame", {
        Name = "Window",
        BackgroundColor3 = Theme.BG_Primary,
        Size = UDim2.new(0, 860, 0, 520),
        Position = UDim2.new(0.5, -430, 0.5, -260),
        ClipsDescendants = false,
        Parent = sg,
    })
    AddCorner(windowFrame, 12)
    AddStroke(windowFrame, Theme.Border_Subtle, 1)

    -- Background gradient
    Create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Theme.BG_Primary),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(30, 8, 45)),
        }),
        Rotation = 135,
        Parent = windowFrame,
    })

    -- Decorative pink orb bg
    for _, cfg in ipairs({
        { Color3.fromRGB(255,80,160), UDim2.new(0,-80,0,-80), UDim2.new(0,260,0,260), 0.92 },
        { Color3.fromRGB(180,50,220), UDim2.new(1,-120,1,-120), UDim2.new(0,200,0,200), 0.94 },
    }) do
        local orb = Create("Frame", {
            BackgroundColor3 = cfg[1],
            Position = cfg[2],
            Size = cfg[3],
            BackgroundTransparency = cfg[4],
            ZIndex = 0,
            Parent = windowFrame,
        })
        AddCorner(orb, 999)
    end

    -- ── TITLEBAR ──
    local titleBar = Create("Frame", {
        Name = "TitleBar",
        BackgroundColor3 = Theme.BG_Sidebar,
        Size = UDim2.new(1, 0, 0, 48),
        ZIndex = 10,
        ClipsDescendants = true,
        Parent = windowFrame,
    })
    AddCorner(titleBar, 12)
    -- flatten bottom corners
    Create("Frame", {
        BackgroundColor3 = Theme.BG_Sidebar,
        Size = UDim2.new(1, 0, 0.5, 0),
        Position = UDim2.new(0, 0, 0.5, 0),
        ZIndex = 10,
        Parent = titleBar,
    })

    -- Logo / Icon
    local logoLabel = Create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 14, 0.5, -11),
        Size = UDim2.new(0, 24, 0, 24),
        Text = logoIcon,
        TextSize = 18,
        ZIndex = 11,
        Parent = titleBar,
    })

    -- Title text
    Create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 44, 0.5, -10),
        Size = UDim2.new(0, 200, 0, 20),
        Text = string.upper(title),
        TextColor3 = Theme.Pink_Vivid,
        Font = Theme.Font_Title,
        TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 11,
        Parent = titleBar,
    })

    -- Status indicators (right side)
    local statusFrame = Create("Frame", {
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -180, 0.5, -10),
        Size = UDim2.new(0, 140, 0, 20),
        ZIndex = 11,
        Parent = titleBar,
    })
    Create("UIListLayout", {
        FillDirection = Enum.FillDirection.Horizontal,
        HorizontalAlignment = Enum.HorizontalAlignment.Right,
        VerticalAlignment = Enum.VerticalAlignment.Center,
        Padding = UDim.new(0, 12),
        Parent = statusFrame,
    })

    -- Helper to make status dot
    local function AddStatus(text, dotColor)
        local holder = Create("Frame", {
            BackgroundTransparency = 1,
            Size = UDim2.new(0, 80, 0, 20),
            ZIndex = 11,
            Parent = statusFrame,
        })
        Create("UIListLayout", {
            FillDirection = Enum.FillDirection.Horizontal,
            VerticalAlignment = Enum.VerticalAlignment.Center,
            Padding = UDim.new(0, 5),
            Parent = holder,
        })
        local dot = Create("Frame", {
            BackgroundColor3 = dotColor,
            Size = UDim2.new(0, 7, 0, 7),
            ZIndex = 12,
            Parent = holder,
        })
        AddCorner(dot, 999)
        -- Pulse
        local function pulse()
            Tween(dot, { BackgroundTransparency = 0.6 }, 0.8)
            task.wait(0.8)
            Tween(dot, { BackgroundTransparency = 0 }, 0.8)
            task.wait(0.8)
        end
        task.spawn(function() while dot.Parent do pulse() end end)
        Create("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(0, 65, 0, 20),
            Text = text,
            TextColor3 = Theme.Text_Muted,
            Font = Theme.Font_Mono,
            TextSize = 9,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 12,
            Parent = holder,
        })
        return holder
    end

    AddStatus("INJECTED ✦", Theme.Pink_Vivid)
    AddStatus("ANTICHEAT: BYPASSED", Theme.Success)

    -- Window controls (close, minimize)
    local function WindowControl(symbol, colorHover, xPos, callback)
        local btn = Create("TextButton", {
            BackgroundColor3 = Theme.BG_Surface,
            Position = UDim2.new(1, xPos, 0.5, -9),
            Size = UDim2.new(0, 18, 0, 18),
            Text = symbol,
            TextColor3 = Theme.Text_Muted,
            Font = Theme.Font_Title,
            TextSize = 11,
            ZIndex = 15,
            Parent = titleBar,
        })
        AddCorner(btn, 999)
        btn.MouseEnter:Connect(function()
            Tween(btn, { BackgroundColor3 = colorHover, TextColor3 = Color3.fromRGB(255,255,255) }, 0.15)
        end)
        btn.MouseLeave:Connect(function()
            Tween(btn, { BackgroundColor3 = Theme.BG_Surface, TextColor3 = Theme.Text_Muted }, 0.15)
        end)
        btn.MouseButton1Click:Connect(callback)
        return btn
    end

    WindowControl("×", Theme.Error, -28, function()
        TweenBlur(0, 0.3)
        Tween(windowFrame, { Size = UDim2.new(0, 860, 0, 0), Position = UDim2.new(0.5, -430, 0.5, 0), BackgroundTransparency = 1 }, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.wait(0.35)
        sg:Destroy()
        if blur then pcall(function() blur:Destroy() end) end
    end)

    local minimized = false
    local normalSize = windowFrame.Size
    WindowControl("─", Theme.Warning, -52, function()
        minimized = not minimized
        if minimized then
            normalSize = windowFrame.Size
            Tween(windowFrame, { Size = UDim2.new(0, 860, 0, 48) }, 0.3, Enum.EasingStyle.Quart)
        else
            Tween(windowFrame, { Size = normalSize }, 0.4, Enum.EasingStyle.Back)
        end
    end)

    -- ── WINDOW DRAG ──
    local dragging, dragStart, startPos
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = windowFrame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            windowFrame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- ── TOGGLE KEYBIND ──
    local visible = true
    UserInputService.InputBegan:Connect(function(input, gp)
        if not gp and input.KeyCode == key then
            visible = not visible
            if visible then
                windowFrame.Visible = true
                windowFrame.Size = UDim2.new(0, 860, 0, 20)
                Tween(windowFrame, { Size = UDim2.new(0, 860, 0, 520) }, 0.4, Enum.EasingStyle.Back)
                TweenBlur(8, 0.3)
            else
                TweenBlur(0, 0.3)
                Tween(windowFrame, { Size = UDim2.new(0, 860, 0, 20) }, 0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
                task.wait(0.35)
                windowFrame.Visible = false
            end
        end
    end)

    -- Opening animation
    windowFrame.Size = UDim2.new(0, 860, 0, 0)
    windowFrame.BackgroundTransparency = 1
    task.wait(0.05)
    Tween(windowFrame, { Size = UDim2.new(0, 860, 0, 520), BackgroundTransparency = 0 }, 0.45, Enum.EasingStyle.Back)
    TweenBlur(8, 0.45)

    -- ── BODY ──
    local body = Create("Frame", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 48),
        Size = UDim2.new(1, 0, 1, -48),
        ClipsDescendants = true,
        Parent = windowFrame,
    })

    -- ── SIDEBAR ──
    local sidebar = Create("ScrollingFrame", {
        BackgroundColor3 = Theme.BG_Sidebar,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(0, 180, 1, 0),
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = Theme.Pink_Muted,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ClipsDescendants = true,
        Parent = body,
    })
    -- flatten right top/bottom corners
    Create("Frame", {
        BackgroundColor3 = Theme.BG_Sidebar,
        Size = UDim2.new(0, 12, 1, 0),
        Position = UDim2.new(1, -12, 0, 0),
        ZIndex = 0,
        Parent = sidebar,
    })

    local sidebarLayout = Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 4),
        Parent = sidebar,
    })
    AddPadding(sidebar, 12, 8, 12, 8)

    -- Sidebar "NAVIGATION" header
    Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 22),
        Text = "✦  NAVIGATION",
        TextColor3 = Theme.Text_Muted,
        Font = Theme.Font_Title,
        TextSize = 9,
        TextXAlignment = Enum.TextXAlignment.Left,
        LayoutOrder = 0,
        Parent = sidebar,
    })
    AddPadding(sidebar:FindFirstChild("TextLabel"), 0, 0, 4, 4)

    -- ── CONTENT AREA ──
