            -- ──────────────────────────
            --  BIND
            -- ──────────────────────────
            function Section:AddBind(cfg)
                cfg = cfg or {}
                local name     = cfg.Name     or "Keybind"
                local default  = cfg.Default  -- Enum.KeyCode or nil
                local callback = cfg.Callback or function() end

                local row = MakeRow(name)
                local bindVal = default
                local listening = false

                local chip = Create("TextButton", {
                    BackgroundColor3 = Theme.BG_Surface,
                    Position = UDim2.new(1, -80, 0.5, -12),
                    Size = UDim2.new(0, 74, 0, 24),
                    Text = default and default.Name or "No Bind",
                    TextColor3 = default and Theme.Pink_Soft or Theme.Text_Muted,
                    Font = Theme.Font_Mono,
                    TextSize = 10,
                    ClipsDescendants = true,
                    Parent = row,
                })
                AddCorner(chip, 6)
                AddStroke(chip, Theme.Border_Subtle, 1)

                chip.MouseButton1Click:Connect(function()
                    if listening then return end
                    listening = true
                    chip.Text = "..."
                    chip.TextColor3 = Theme.Pink_Vivid
                    Tween(chip, { BackgroundColor3 = Color3.fromRGB(60, 25, 75) }, 0.1)
                    local con
                    con = UserInputService.InputBegan:Connect(function(input, gp)
                        if gp then return end
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            local kc = input.KeyCode
                            if kc == Enum.KeyCode.Escape then
                                bindVal = nil
                                chip.Text = "No Bind"
                                chip.TextColor3 = Theme.Text_Muted
                            else
                                bindVal = kc
                                chip.Text = kc.Name
                                chip.TextColor3 = Theme.Pink_Soft
                            end
                            listening = false
                            Tween(chip, { BackgroundColor3 = Theme.BG_Surface }, 0.2)
                            con:Disconnect()
                        end
                    end)
                end)

                -- Listen for the keybind
                UserInputService.InputBegan:Connect(function(input, gp)
                    if not gp and bindVal and input.KeyCode == bindVal then
                        callback()
                    end
                end)

                local BindObj = {}
                function BindObj:Set(kc) bindVal = kc; chip.Text = kc and kc.Name or "No Bind" end
                function BindObj:Get() return bindVal end
                return BindObj
            end

