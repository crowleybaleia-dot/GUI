                        TextSize = 9,
                        Parent = row,
                    })
                    AddCorner(row:FindFirstChildOfClass("TextLabel"), 4) -- approximate
                end

                -- Track bg
                local trackBg = Create("Frame", {
                    BackgroundColor3 = Theme.BG_Surface,
                    Position = UDim2.new(1, -56, 0.5, -11),
                    Size = UDim2.new(0, 44, 0, 22),
                    Parent = row,
                })
                AddCorner(trackBg, 999)
                AddStroke(trackBg, Theme.Border_Subtle, 1)

                local trackFill = Create("Frame", {
                    BackgroundColor3 = Theme.Pink_Vivid,
                    Size = UDim2.new(0, 0, 1, 0),
                    ClipsDescendants = true,
                    Parent = trackBg,
                })
                AddCorner(trackFill, 999)

                local thumb = Create("Frame", {
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    Position = UDim2.new(0, 2, 0.5, -8),
                    Size = UDim2.new(0, 16, 0, 16),
                    ZIndex = 3,
                    Parent = trackBg,
                })
                AddCorner(thumb, 999)
                MakeGlow(thumb, Theme.Pink_Glow, 10, 0.8)

                local function UpdateToggle(s, animate)
                    if s then
                        if animate then
                            Tween(trackFill, { Size = UDim2.new(1, 0, 1, 0) }, 0.25)
                            Tween(thumb, { Position = UDim2.new(1, -18, 0.5, -8), BackgroundColor3 = Theme.Pink_Vivid }, 0.25)
                            Tween(trackBg, { BackgroundColor3 = Color3.fromRGB(255, 105, 180) }, 0.25)
                        else
                            trackFill.Size = UDim2.new(1, 0, 1, 0)
                            thumb.Position = UDim2.new(1, -18, 0.5, -8)
                            thumb.BackgroundColor3 = Theme.Pink_Vivid
                            trackBg.BackgroundColor3 = Color3.fromRGB(255, 105, 180)
                        end
                    else
                        if animate then
                            Tween(trackFill, { Size = UDim2.new(0, 0, 1, 0) }, 0.25)
                            Tween(thumb, { Position = UDim2.new(0, 2, 0.5, -8), BackgroundColor3 = Color3.fromRGB(255,255,255) }, 0.25)
                            Tween(trackBg, { BackgroundColor3 = Theme.BG_Surface }, 0.25)
                        else
                            trackFill.Size = UDim2.new(0, 0, 1, 0)
                            thumb.Position = UDim2.new(0, 2, 0.5, -8)
                            thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                            trackBg.BackgroundColor3 = Theme.BG_Surface
                        end
                    end
                end

                UpdateToggle(state, false)

                local btn = Create("TextButton", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    ZIndex = 5,
                    Parent = row,
                })
                btn.MouseButton1Click:Connect(function()
                    state = not state
                    UpdateToggle(state, true)
                    callback(state)
                end)

                -- Glow burst on activate
                local origGlow = thumb:FindFirstChildOfClass("ImageLabel")
                local function BurstGlow()
                    if state and origGlow then
                        Tween(origGlow, { ImageTransparency = 0.3 }, 0.1)
                        task.wait(0.15)
                        Tween(origGlow, { ImageTransparency = 0.8 }, 0.4)
                    end
                end
                btn.MouseButton1Click:Connect(BurstGlow)

                local ToggleObj = {}
                function ToggleObj:Set(v, silent)
                    state = v
                    UpdateToggle(v, true)
                    if not silent then callback(v) end
                end
                function ToggleObj:Get() return state end
                return ToggleObj
            end

            -- ──────────────────────────
            --  SLIDER
            -- ──────────────────────────
            function Section:AddSlider(cfg)
                cfg = cfg or {}
                local name     = cfg.Name     or "Slider"
                local min      = cfg.Min      or 0
                local max      = cfg.Max      or 100
                local default  = cfg.Default  or min
                local callback = cfg.Callback or function() end
                local suffix   = cfg.Suffix   or ""

                itemOrder = itemOrder + 1
                local row = Create("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 52),
                    LayoutOrder = itemOrder,
                    Parent = sectionCard,
                })

                -- Name + Value display
                Create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 4, 0, 6),
                    Size = UDim2.new(0.6, 0, 0, 16),
                    Text = name,
                    TextColor3 = Theme.Text_Primary,
                    Font = Theme.Font_Body,
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = row,
                })

                local valLabel = Create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0.6, 0, 0, 6),
                    Size = UDim2.new(0.4, -4, 0, 16),
                    Text = tostring(default) .. suffix .. " / " .. tostring(max) .. suffix,
                    TextColor3 = Theme.Pink_Soft,
                    Font = Theme.Font_Mono,
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Parent = row,
                })

                -- Track
                local track = Create("Frame", {
                    BackgroundColor3 = Theme.BG_Surface,
                    Position = UDim2.new(0, 4, 0, 30),
                    Size = UDim2.new(1, -8, 0, 6),
                    Parent = row,
                })
                AddCorner(track, 999)
                AddStroke(track, Theme.Border_Subtle, 1)

                -- Gradient fill
                local fill = Create("Frame", {
                    BackgroundColor3 = Theme.Pink_Vivid,
                    Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
                    ClipsDescendants = true,
                    Parent = track,
                })
                AddCorner(fill, 999)
                Create("UIGradient", {
                    Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, Theme.Pink_Muted),
                        ColorSequenceKeypoint.new(1, Theme.Pink_Vivid),
                    }),
                    Parent = fill,
                })

                -- Thumb
                local thumb = Create("Frame", {
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Position = UDim2.new((default - min) / (max - min), 0, 0.5, 0),
                    Size = UDim2.new(0, 14, 0, 14),
                    ZIndex = 4,
                    Parent = track,
                })
                AddCorner(thumb, 999)
                AddStroke(thumb, Theme.Pink_Vivid, 2)
                MakeGlow(thumb, Theme.Pink_Glow, 10, 0.6)

                local sliderVal = default
                local draggingSlider = false

                local function UpdateSlider(v)
                    v = math.clamp(v, min, max)
                    if cfg.Integer then v = math.round(v) end
                    sliderVal = v
                    local pct = (v - min) / (max - min)
                    Tween(fill, { Size = UDim2.new(pct, 0, 1, 0) }, 0.05)
                    Tween(thumb, { Position = UDim2.new(pct, 0, 0.5, 0) }, 0.05)
                    valLabel.Text = tostring(math.round(v * 10) / 10) .. suffix .. " / " .. tostring(max) .. suffix
                    callback(v)
                end

                track.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSlider = true
                        local pct = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                        UpdateSlider(min + (max - min) * pct)
                    end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
                        local pct = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                        UpdateSlider(min + (max - min) * pct)
                    end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSlider = false
                    end
                end)

                local SliderObj = {}
                function SliderObj:Set(v, silent)
                    UpdateSlider(v)
                    -- suppress callback already handled in UpdateSlider, so we just call if not silent
                    -- Re-wire: UpdateSlider calls callback, so for silent we'd need a flag. Simplified:
                end
                function SliderObj:Get() return sliderVal end
                return SliderObj
            end

