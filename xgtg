function BarbiUI:Notify(config)
    EnsureNotifHolder()
    config = config or {}
    local title   = config.Title   or "Notification"
    local message = config.Message or ""
    local ntype   = config.Type    or "info"  -- info/success/warning/error
    local duration= config.Duration or 4

    local typeColor = ({
        info    = Theme.Info,
        success = Theme.Success,
        warning = Theme.Warning,
        error   = Theme.Error,
    })[ntype] or Theme.Info

    local typeIcon = ({
        info    = "ℹ",
        success = "✓",
        warning = "⚠",
        error   = "✕",
    })[ntype] or "ℹ"

    NotifCount = NotifCount + 1
    local lo = NotifCount

    local card = Create("Frame", {
        BackgroundColor3 = Theme.BG_Elevated,
        Size = UDim2.new(1, 0, 0, 70),
        BackgroundTransparency = 0,
        ClipsDescendants = true,
        LayoutOrder = lo,
        Parent = NotifHolder,
    })
    AddCorner(card, 10)
    AddStroke(card, typeColor, 1, 0.5)

    -- Left accent bar
    Create("Frame", {
        BackgroundColor3 = typeColor,
        Size = UDim2.new(0, 4, 1, 0),
        Position = UDim2.new(0, 0, 0, 0),
        Parent = card,
    })
    AddCorner(card:FindFirstChild("Frame"), 4)

    -- Icon circle
    local iconBg = Create("Frame", {
        BackgroundColor3 = typeColor,
        BackgroundTransparency = 0.7,
        Size = UDim2.new(0, 32, 0, 32),
        Position = UDim2.new(0, 16, 0.5, -16),
        Parent = card,
    })
    AddCorner(iconBg, 999)
    Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Text = typeIcon,
        TextColor3 = typeColor,
        Font = Theme.Font_Title,
        TextSize = 14,
        Parent = iconBg,
    })

    -- Title
    Create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 58, 0, 10),
        Size = UDim2.new(1, -70, 0, 18),
        Text = title,
        TextColor3 = Theme.Text_Primary,
        Font = Theme.Font_Title,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = card,
    })

    -- Message
    Create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 58, 0, 30),
        Size = UDim2.new(1, -70, 0, 28),
        Text = message,
        TextColor3 = Theme.Text_Secondary,
        Font = Theme.Font_Body,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = card,
    })

    -- Progress bar
    local progBg = Create("Frame", {
        BackgroundColor3 = Theme.BG_Surface,
        Size = UDim2.new(1, 0, 0, 3),
        Position = UDim2.new(0, 0, 1, -3),
        Parent = card,
    })
    local prog = Create("Frame", {
        BackgroundColor3 = typeColor,
        Size = UDim2.new(1, 0, 1, 0),
        Parent = progBg,
    })

    -- Slide-in animation
    card.Position = UDim2.new(1, 20, 0, 0)
    card.BackgroundTransparency = 1
    Tween(card, { Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 0 }, 0.35, Enum.EasingStyle.Back)

    -- Progress countdown
    Tween(prog, { Size = UDim2.new(0, 0, 1, 0) }, duration, Enum.EasingStyle.Linear)

    -- Slide-out and destroy
    task.delay(duration, function()
        Tween(card, { Position = UDim2.new(1, 20, 0, 0), BackgroundTransparency = 1 }, 0.3)
        task.wait(0.35)
        card:Destroy()
    end)

    -- Close button
    local closeBtn = Create("TextButton", {
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -24, 0, 6),
        Size = UDim2.new(0, 18, 0, 18),
        Text = "×",
        TextColor3 = Theme.Text_Muted,
        Font = Theme.Font_Title,
        TextSize = 16,
        Parent = card,
    })
    closeBtn.MouseButton1Click:Connect(function()
        Tween(card, { Position = UDim2.new(1, 20, 0, 0), BackgroundTransparency = 1 }, 0.3)
        task.wait(0.35)
        card:Destroy()
    end)
end

