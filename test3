-- ══════════════════════════════════════════════════════════════════
function BarbiUI:CreateWindow(cfg)
    cfg = cfg or {}
    local title     = cfg.Title      or "BarbiUI"
    local key       = cfg.Key        or Enum.KeyCode.RightShift
    local winWidth  = cfg.Width      or 920
    local winHeight = cfg.Height     or 560
    local showConsole = cfg.Console  ~= false  -- padrão true
    local consoleH  = showConsole and 110 or 0

    -- ScreenGui
    local sg = Utils.New("ScreenGui", {
        Name              = "BarbiUI_" .. title,
        ResetOnSpawn      = false,
        ZIndexBehavior    = Enum.ZIndexBehavior.Global,
        IgnoreGuiInset    = true,
        Parent            = CoreGui,
    })

    -- Blur (opcional, seguro)
    local blur = nil
    pcall(function()
        blur = Instance.new("BlurEffect")
        blur.Size   = 0
        blur.Parent = game:GetService("Lighting")
    end)
    local function TwBlur(sz, t)
        if blur then pcall(function() Utils.Tween(blur, { Size = sz }, t or 0.3) end) end
    end

    -- ──────────────────────────────────────────────────────────────
    -- JANELA PRINCIPAL
    -- ──────────────────────────────────────────────────────────────
    local win = Utils.New("Frame", {
        Name             = "Window",
        BackgroundColor3 = T.BG1,
        Size             = UDim2.new(0, winWidth, 0, winHeight),
        Position         = UDim2.new(0.5, -winWidth/2, 0.5, -winHeight/2),
        ClipsDescendants = false,
        Parent           = sg,
    })
    Utils.Corner(win, 12)
    Utils.Stroke(win, T.Border, 1)

    -- Sombra decorativa
    local shadow = Utils.New("ImageLabel", {
        BackgroundTransparency = 1,
        Image                  = "rbxassetid://6014261993",
        ImageColor3            = Color3.new(0, 0, 0),
        ImageTransparency      = 0.5,
        ScaleType              = Enum.ScaleType.Slice,
        SliceCenter            = Rect.new(49, 49, 450, 450),
        Size                   = UDim2.new(1, 50, 1, 50),
        Position               = UDim2.new(0, -25, 0, -25),
        ZIndex                 = -1,
        Parent                 = win,
    })

    -- Gradiente de fundo
    Utils.Gradient(win, { T.BG1, Color3.fromRGB(20, 5, 35) }, 135)

    -- ──────────────────────────────────────────────────────────────
    -- TITLEBAR
    -- ──────────────────────────────────────────────────────────────
    local titleH = 46
    local tb = Utils.New("Frame", {
        BackgroundColor3 = T.TitleBar,
        Size             = UDim2.new(1, 0, 0, titleH),
        ZIndex           = 10,
        ClipsDescendants = false,
        Parent           = win,
    })
    Utils.Corner(tb, 12)
    -- Cobre cantos inferiores do titlebar
    Utils.New("Frame", {
        BackgroundColor3 = T.TitleBar,
        Size             = UDim2.new(1, 0, 0, 12),
        Position         = UDim2.new(0, 0, 1, -12),
        ZIndex           = 10,
        Parent           = tb,
    })
    -- Linha separadora
    Utils.New("Frame", {
        BackgroundColor3      = T.Border,
        BackgroundTransparency = 0.3,
        Size                  = UDim2.new(1, 0, 0, 1),
        Position              = UDim2.new(0, 0, 1, -1),
        ZIndex                = 11,
        Parent                = tb,
    })

    -- Logo / Ícone decorativo
    local logoFrame = Utils.New("Frame", {
        BackgroundColor3      = T.Pink,
        BackgroundTransparency = 0.8,
        Size                  = UDim2.new(0, 26, 0, 26),
        Position              = UDim2.new(0, 12, 0.5, -13),
        ZIndex                = 12,
        Parent                = tb,
    })
    Utils.Corner(logoFrame, 6)
    Utils.New("TextLabel", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, 0, 1, 0),
        Text                   = "B",
        TextColor3             = T.Pink,
        Font                   = T.FntBold,
        TextSize               = 14,
        ZIndex                 = 13,
        Parent                 = logoFrame,
    })

    -- Título
    Utils.New("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, 46, 0.5, -9),
        Size                   = UDim2.new(0, 250, 0, 18),
        Text                   = string.upper(title),
        TextColor3             = T.TxtPri,
        Font                   = T.FntTitle,
        TextSize               = 13,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 11,
        Parent                 = tb,
    })

    -- Status dots (INJECTED / BYPASSED)
    local function StatusDot(label, color, xOffset)
        local container = Utils.New("Frame", {
            BackgroundTransparency = 1,
            Position               = UDim2.new(1, xOffset, 0.5, -8),
            Size                   = UDim2.new(0, 100, 0, 16),
            ZIndex                 = 11,
            Parent                 = tb,
        })
        local dot = Utils.New("Frame", {
            BackgroundColor3 = color,
            Size             = UDim2.new(0, 6, 0, 6),
            Position         = UDim2.new(0, 0, 0.5, -3),
            ZIndex           = 12,
            Parent           = container,
        })
        Utils.Corner(dot, 999)
        Utils.New("TextLabel", {
            BackgroundTransparency = 1,
            Position               = UDim2.new(0, 11, 0, 0),
            Size                   = UDim2.new(1, -11, 1, 0),
            Text                   = label,
            TextColor3             = T.TxtMute,
            Font                   = T.FntMono,
            TextSize               = 8,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = 12,
            Parent                 = container,
        })
        -- Pulse animation
        task.spawn(function()
            while dot and dot.Parent do
                Utils.Tween(dot, { BackgroundTransparency = 0.7, Size = UDim2.new(0, 5, 0, 5) }, 0.9)
                task.wait(0.9)
                Utils.Tween(dot, { BackgroundTransparency = 0, Size = UDim2.new(0, 6, 0, 6) }, 0.9)
                task.wait(0.9)
            end
        end)
        return container
    end

    StatusDot("INJECTED",  T.Pink,    -310)
    StatusDot("BYPASSED",  T.Success, -210)
    StatusDot("ANTICHEAT", T.Warning, -110)

    -- Relógio em tempo real
    local clock = Utils.New("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(1, -62, 0.5, -8),
        Size                   = UDim2.new(0, 55, 0, 16),
        Text                   = Utils.GetTime(),
        TextColor3             = T.TxtMute,
        Font                   = T.FntMono,
        TextSize               = 9,
        TextXAlignment         = Enum.TextXAlignment.Right,
        ZIndex                 = 11,
        Parent                 = tb,
    })
    task.spawn(function()
        while clock and clock.Parent do
            clock.Text = Utils.GetTime()
            task.wait(1)
        end
    end)

    -- ──────────────────────────────────────────────────────────────
    -- BOTÕES DE CONTROLE (fechar / minimizar)
    -- ──────────────────────────────────────────────────────────────
    local function CtrlBtn(symbol, hoverColor, xOffset, callback)
        local b = Utils.New("TextButton", {
            BackgroundColor3      = T.BG4,
            BackgroundTransparency = 0.4,
            Position              = UDim2.new(1, xOffset, 0.5, -10),
            Size                  = UDim2.new(0, 20, 0, 20),
            Text                  = symbol,
            TextColor3            = T.TxtMute,
            Font                  = T.FntBold,
            TextSize              = 11,
            ZIndex                = 15,
            Parent                = tb,
        })
        Utils.Corner(b, 999)
        Utils.Stroke(b, T.Border, 1, 0.5)
        b.MouseEnter:Connect(function()
            Utils.Tween(b, { BackgroundColor3 = hoverColor, TextColor3 = Color3.new(1,1,1), BackgroundTransparency = 0 }, 0.15)
        end)
        b.MouseLeave:Connect(function()
            Utils.Tween(b, { BackgroundColor3 = T.BG4, TextColor3 = T.TxtMute, BackgroundTransparency = 0.4 }, 0.15)
        end)
        b.MouseButton1Click:Connect(callback)
        return b
    end

    CtrlBtn("×", T.Error, -30, function()
        TwBlur(0, 0.3)
        Utils.Tween(win, { Size = UDim2.new(0, winWidth, 0, 0), BackgroundTransparency = 1 }, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.wait(0.38)
        sg:Destroy()
        if blur then pcall(function() blur:Destroy() end) end
    end)

    local minimized = false
    CtrlBtn("−", T.Warning, -56, function()
        minimized = not minimized
        if minimized then
            Utils.Tween(win, { Size = UDim2.new(0, winWidth, 0, titleH) }, 0.3, Enum.EasingStyle.Quart)
        else
            Utils.Tween(win, { Size = UDim2.new(0, winWidth, 0, winHeight) }, 0.4, Enum.EasingStyle.Back)
        end
    end)

    -- ──────────────────────────────────────────────────────────────
    -- DRAG (com conexões limpas)
    -- ──────────────────────────────────────────────────────────────
    local dragging, dragStart, startPos
    local inputConn, endConn

    tb.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            dragStart = i.Position
            startPos  = win.Position
        end
    end)

    inputConn = UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = i.Position - dragStart
            win.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)

    endConn = UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- ──────────────────────────────────────────────────────────────
    -- TOGGLE (tecla)
    -- ──────────────────────────────────────────────────────────────
    local visible = true
    UserInputService.InputBegan:Connect(function(i, gameProcessed)
        if gameProcessed then return end
        if i.KeyCode == key then
            visible = not visible
            if visible then
                win.Visible = true
                win.Size    = UDim2.new(0, winWidth, 0, 20)
                Utils.Tween(win, { Size = UDim2.new(0, winWidth, 0, winHeight) }, 0.4, Enum.EasingStyle.Back)
                TwBlur(8, 0.3)
            else
                TwBlur(0, 0.3)
                Utils.Tween(win, { Size = UDim2.new(0, winWidth, 0, 20) }, 0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
                task.wait(0.38)
                win.Visible = false
            end
        end
    end)

    -- ──────────────────────────────────────────────────────────────
    -- CORPO PRINCIPAL
    -- ──────────────────────────────────────────────────────────────
    local bodyTop   = titleH
    local bodyBottom = consoleH + (showConsole and 46 or 0) -- reserva console + botão
