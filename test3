local Utils = {}

-- Tween seguro
function Utils.Tween(obj, props, t, style, dir)
    if not obj or not obj.Parent then return end
    local ok, err = pcall(function()
        TweenService:Create(
            obj,
            TweenInfo.new(t or 0.25, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out),
            props
        ):Play()
    end)
    if not ok then warn("[BarbiUI] Tween error:", err) end
end

-- Criação de instância segura
function Utils.New(cls, props)
    local ok, obj = pcall(Instance.new, cls)
    if not ok then warn("[BarbiUI] Failed to create:", cls) return nil end
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then
            local s, e = pcall(function() obj[k] = v end)
            if not s then warn("[BarbiUI] Property error", k, e) end
        end
    end
    if props and props.Parent then
        pcall(function() obj.Parent = props.Parent end)
    end
    return obj
end

function Utils.Corner(parent, radius)
    return Utils.New("UICorner", { CornerRadius = UDim.new(0, radius or 8), Parent = parent })
end

function Utils.Stroke(parent, color, thickness, transparency)
    return Utils.New("UIStroke", {
        Color        = color or T.Border,
        Thickness    = thickness or 1,
        Transparency = transparency or 0,
        Parent       = parent,
    })
end

function Utils.Pad(parent, top, right, bottom, left)
    return Utils.New("UIPadding", {
        PaddingTop    = UDim.new(0, top    or 8),
        PaddingRight  = UDim.new(0, right  or 8),
        PaddingBottom = UDim.new(0, bottom or 8),
        PaddingLeft   = UDim.new(0, left   or 8),
        Parent        = parent,
    })
end

function Utils.Gradient(parent, colors, rotation)
    local kps = {}
    for i, c in ipairs(colors) do
        kps[i] = ColorSequenceKeypoint.new((i-1)/(#colors-1), c)
    end
    return Utils.New("UIGradient", {
        Color    = ColorSequence.new(kps),
        Rotation = rotation or 0,
        Parent   = parent,
    })
end

-- Efeito ripple no clique
function Utils.Ripple(btn, x, y)
    if not btn or not btn.AbsolutePosition then return end
    local lx = x - btn.AbsolutePosition.X - 8
    local ly = y - btn.AbsolutePosition.Y - 8
    local r = Utils.New("Frame", {
        BackgroundColor3      = Color3.new(1, 1, 1),
        BackgroundTransparency = 0.75,
        Position              = UDim2.new(0, lx, 0, ly),
        Size                  = UDim2.new(0, 16, 0, 16),
        ZIndex                = btn.ZIndex + 5,
        ClipsDescendants      = true,
        Parent                = btn,
    })
    if r then
        Utils.Corner(r, 999)
        local s = btn.AbsoluteSize.X * 2.5
        Utils.Tween(r, {
            Size = UDim2.new(0, s, 0, s),
            Position = UDim2.new(0.5, -s/2, 0.5, -s/2),
            BackgroundTransparency = 1,
        }, 0.5)
        task.delay(0.55, function() if r and r.Parent then r:Destroy() end end)
    end
end

-- Formatar tempo
function Utils.GetTime()
    local t = os.time and os.time() or 0
    return os.date and os.date("%H:%M:%S", t) or "00:00:00"
end

