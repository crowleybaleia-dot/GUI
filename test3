-- SISTEMA DE NOTIFICAÇÕES
-- ══════════════════════════════════════════════════════════════════
local NotifSystem = {
    holder     = nil,
    screenGui  = nil,
    count      = 0,
    queue      = {},
    maxVisible = 5,
    active     = 0,
}

function NotifSystem:Init()
    if self.screenGui and self.screenGui.Parent then return end
    local sg = Utils.New("ScreenGui", {
        Name              = "BarbiUI_Notifications",
        ResetOnSpawn      = false,
        ZIndexBehavior    = Enum.ZIndexBehavior.Global,
        IgnoreGuiInset    = true,
        Parent            = CoreGui,
    })
    self.screenGui = sg
    local holder = Utils.New("Frame", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(0, 320, 1, 0),
        Position               = UDim2.new(1, -335, 0, 0),
        Parent                 = sg,
    })
    Utils.New("UIListLayout", {
        SortOrder          = Enum.SortOrder.LayoutOrder,
        VerticalAlignment  = Enum.VerticalAlignment.Bottom,
        Padding            = UDim.new(0, 6),
        Parent             = holder,
    })
    Utils.Pad(holder, 12, 0, 12, 0)
    self.holder = holder
end

function NotifSystem:Send(cfg)
    self:Init()
    cfg = cfg or {}

    local title  = cfg.Title    or "Notification"
    local msg    = cfg.Message  or ""
    local ntype  = cfg.Type     or "info"
    local dur    = cfg.Duration or 4

    local typeMap = {
        info    = { color = T.Info,    icon = "i" },
        success = { color = T.Success, icon = "+" },
        warning = { color = T.Warning, icon = "!" },
        error   = { color = T.Error,   icon = "×" },
    }
    local tm  = typeMap[ntype] or typeMap.info
    local col = tm.color
    local icn = tm.icon

    self.count  = self.count + 1
    self.active = self.active + 1

    -- Card
    local card = Utils.New("Frame", {
        BackgroundColor3   = T.BG3,
        Size               = UDim2.new(1, 0, 0, 72),
        LayoutOrder        = self.count,
        ClipsDescendants   = true,
        Parent             = self.holder,
    })
    Utils.Corner(card, 10)
    Utils.Stroke(card, col, 1, 0.6)

    -- Barra lateral colorida
    Utils.New("Frame", {
        BackgroundColor3 = col,
        Size             = UDim2.new(0, 3, 1, 0),
        Parent           = card,
    })

    -- Ícone
    local iconBg = Utils.New("Frame", {
        BackgroundColor3      = col,
        BackgroundTransparency = 0.75,
        Size                  = UDim2.new(0, 28, 0, 28),
        Position              = UDim2.new(0, 12, 0.5, -14),
        Parent                = card,
    })
    Utils.Corner(iconBg, 999)
    Utils.New("TextLabel", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, 0, 1, 0),
        Text                   = icn,
        TextColor3             = col,
        Font                   = T.FntBold,
        TextSize               = 13,
        Parent                 = iconBg,
    })

    -- Título
    Utils.New("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, 50, 0, 9),
        Size                   = UDim2.new(1, -65, 0, 16),
        Text                   = title,
        TextColor3             = T.TxtPri,
        Font                   = T.FntBold,
        TextSize               = 11,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Parent                 = card,
    })

    -- Mensagem
    Utils.New("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, 50, 0, 27),
        Size                   = UDim2.new(1, -65, 0, 32),
        Text                   = msg,
        TextColor3             = T.TxtSec,
        Font                   = T.FntBody,
        TextSize               = 9,
        TextXAlignment         = Enum.TextXAlignment.Left,
        TextWrapped            = true,
        Parent                 = card,
    })

    -- Barra de progresso
    local pgBg = Utils.New("Frame", {
        BackgroundColor3 = T.BG4,
        Size             = UDim2.new(1, 0, 0, 3),
        Position         = UDim2.new(0, 0, 1, -3),
        Parent           = card,
    })
    local pgFill = Utils.New("Frame", {
        BackgroundColor3 = col,
        Size             = UDim2.new(1, 0, 1, 0),
        Parent           = pgBg,
    })

    -- Botão fechar
    local closeBtn = Utils.New("TextButton", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(1, -20, 0, 5),
        Size                   = UDim2.new(0, 15, 0, 15),
        Text                   = "×",
        TextColor3             = T.TxtMute,
        Font                   = T.FntBold,
        TextSize               = 14,
        ZIndex                 = 5,
        Parent                 = card,
    })

    -- Animação entrada
    card.Position              = UDim2.new(1, 15, 0, 0)
    card.BackgroundTransparency = 1
    Utils.Tween(card, { Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 0 }, 0.35, Enum.EasingStyle.Back)
    Utils.Tween(pgFill, { Size = UDim2.new(0, 0, 1, 0) }, dur, Enum.EasingStyle.Linear)

    local dismissed = false
    local function Dismiss()
        if dismissed then return end
        dismissed = true
        self.active = math.max(0, self.active - 1)
        Utils.Tween(card, { Position = UDim2.new(1, 15, 0, 0), BackgroundTransparency = 1 }, 0.28)
        task.delay(0.32, function() if card and card.Parent then card:Destroy() end end)
    end

    task.delay(dur, Dismiss)
    closeBtn.MouseButton1Click:Connect(Dismiss)

    -- Hover para pausar
    card.MouseEnter:Connect(function() Utils.Tween(card, { BackgroundColor3 = T.BG4 }, 0.2) end)
    card.MouseLeave:Connect(function() Utils.Tween(card, { BackgroundColor3 = T.BG3 }, 0.2) end)
end

