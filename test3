                    Font                   = T.FntBody,
                    TextSize               = 10,
                    TextXAlignment         = Enum.TextXAlignment.Left,
                    Parent                 = r,
                })
                return r
            end

            -- ── TOGGLE ──
            function Sec:AddToggle(c)
                c = c or {}
                local row    = Row(c.Name or "Toggle")
                local state  = c.Default or false
                local cb     = c.Callback or function() end

                local track = Utils.New("Frame", {
                    BackgroundColor3 = T.BG4,
                    Position         = UDim2.new(1, -50, 0.5, -10),
                    Size             = UDim2.new(0, 44, 0, 20),
                    Parent           = row,
                })
                Utils.Corner(track, 999)
                Utils.Stroke(track, T.Border, 1)

                local fill = Utils.New("Frame", {
                    BackgroundColor3 = T.Pink,
                    Size             = UDim2.new(0, 0, 1, 0),
                    ClipsDescendants = true,
                    Parent           = track,
                })
                Utils.Corner(fill, 999)

                local thumb = Utils.New("Frame", {
                    BackgroundColor3 = Color3.new(1, 1, 1),
                    Position         = UDim2.new(0, 2, 0.5, -7),
                    Size             = UDim2.new(0, 14, 0, 14),
                    ZIndex           = 3,
                    Parent           = track,
                })
                Utils.Corner(thumb, 999)

                local function UpdateToggle(s, animate)
                    if s then
                        if animate then
                            Utils.Tween(fill,  { Size = UDim2.new(1, 0, 1, 0) }, 0.2)
                            Utils.Tween(thumb, { Position = UDim2.new(1, -16, 0.5, -7), BackgroundColor3 = T.PinkLight }, 0.2)
                            Utils.Tween(track, { BackgroundColor3 = T.PinkDark }, 0.2)
                        else
                            fill.Size             = UDim2.new(1, 0, 1, 0)
                            thumb.Position        = UDim2.new(1, -16, 0.5, -7)
                            thumb.BackgroundColor3 = T.PinkLight
                            track.BackgroundColor3 = T.PinkDark
                        end
                    else
                        if animate then
                            Utils.Tween(fill,  { Size = UDim2.new(0, 0, 1, 0) }, 0.2)
                            Utils.Tween(thumb, { Position = UDim2.new(0, 2, 0.5, -7), BackgroundColor3 = Color3.new(1, 1, 1) }, 0.2)
                            Utils.Tween(track, { BackgroundColor3 = T.BG4 }, 0.2)
                        else
                            fill.Size              = UDim2.new(0, 0, 1, 0)
                            thumb.Position         = UDim2.new(0, 2, 0.5, -7)
                            thumb.BackgroundColor3 = Color3.new(1, 1, 1)
                            track.BackgroundColor3 = T.BG4
                        end
                    end
                end
                UpdateToggle(state, false)

                local hit = Utils.New("TextButton", {
                    BackgroundTransparency = 1,
                    Size                   = UDim2.new(1, 0, 1, 0),
                    Text                   = "",
                    ZIndex                 = 5,
                    Parent                 = row,
                })
                hit.MouseButton1Click:Connect(function()
                    state = not state
                    UpdateToggle(state, true)
                    cb(state)
                end)

                local obj = {}
                function obj:Set(v, silent)
                    state = v
                    UpdateToggle(v, true)
                    if not silent then cb(v) end
                end
                function obj:Get() return state end
                return obj
            end

            -- ── SLIDER ──
            function Sec:AddSlider(c)
                c = c or {}
                local mn    = c.Min     or 0
                local mx    = c.Max     or 100
                local def   = c.Default or mn
                local cb    = c.Callback or function() end
                local sfx   = c.Suffix  or ""
                local isInt = c.Integer or false

                iOrder = iOrder + 1
                local row = Utils.New("Frame", {
                    BackgroundTransparency = 1,
                    Size                   = UDim2.new(1, 0, 0, 48),
                    LayoutOrder            = iOrder,
                    Parent                 = card,
                })

                Utils.New("TextLabel", {
                    BackgroundTransparency = 1,
                    Position               = UDim2.new(0, 2, 0, 4),
                    Size                   = UDim2.new(0.6, 0, 0, 14),
                    Text                   = c.Name or "Slider",
                    TextColor3             = T.TxtPri,
                    Font                   = T.FntBody,
                    TextSize               = 10,
                    TextXAlignment         = Enum.TextXAlignment.Left,
                    Parent                 = row,
                })

                local valLabel = Utils.New("TextLabel", {
                    BackgroundTransparency = 1,
                    Position               = UDim2.new(0.6, 0, 0, 4),
                    Size                   = UDim2.new(0.4, -2, 0, 14),
                    Text                   = tostring(def) .. sfx,
                    TextColor3             = T.PinkLight,
                    Font                   = T.FntMono,
                    TextSize               = 9,
                    TextXAlignment         = Enum.TextXAlignment.Right,
                    Parent                 = row,
                })

                local track = Utils.New("Frame", {
                    BackgroundColor3 = T.BG4,
                    Position         = UDim2.new(0, 2, 0, 27),
                    Size             = UDim2.new(1, -4, 0, 8),
                    Parent           = row,
                })
                Utils.Corner(track, 999)
                Utils.Stroke(track, T.Border, 1)

                local fillBar = Utils.New("Frame", {
                    BackgroundColor3 = T.Pink,
                    Size             = UDim2.new((def - mn) / (mx - mn), 0, 1, 0),
                    ClipsDescendants = true,
                    Parent           = track,
                })
                Utils.Corner(fillBar, 999)
                Utils.Gradient(fillBar, { T.PinkMute, T.Pink }, 0)

                local thumb = Utils.New("Frame", {
                    BackgroundColor3 = Color3.new(1, 1, 1),
                    AnchorPoint      = Vector2.new(0.5, 0.5),
                    Position         = UDim2.new((def - mn) / (mx - mn), 0, 0.5, 0),
                    Size             = UDim2.new(0, 14, 0, 14),
                    ZIndex           = 4,
                    Parent           = track,
                })
                Utils.Corner(thumb, 999)
                Utils.Stroke(thumb, T.Pink, 2)

                local currentVal = def
                local draggingSlider = false

                local function UpdateSlider(v)
                    v = math.clamp(v, mn, mx)
                    if isInt then v = math.round(v) end
                    currentVal = v
                    local pct = (v - mn) / (mx - mn)
                    Utils.Tween(fillBar, { Size = UDim2.new(pct, 0, 1, 0) }, 0.05)
                    Utils.Tween(thumb,   { Position = UDim2.new(pct, 0, 0.5, 0) }, 0.05)
                    valLabel.Text = tostring(isInt and v or math.round(v * 10) / 10) .. sfx
                    cb(v)
                end

                track.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSlider = true
                        local pct = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                        UpdateSlider(mn + (mx - mn) * pct)
                    end
                end)

                -- Conexões locais para evitar leak global
                local sliderMove = UserInputService.InputChanged:Connect(function(i)
                    if draggingSlider and i.UserInputType == Enum.UserInputType.MouseMovement then
                        local pct = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                        UpdateSlider(mn + (mx - mn) * pct)
                    end
                end)
                local sliderEnd = UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSlider = false
                    end
                end)
                -- Limpar quando o card for destruído
                card.AncestryChanged:Connect(function()
                    if not card.Parent then
                        sliderMove:Disconnect()
                        sliderEnd:Disconnect()
                    end
                end)

                local obj = {}
                function obj:Set(v) UpdateSlider(v) end
                function obj:Get() return currentVal end
                return obj
            end

            -- ── BUTTON ──
            function Sec:AddButton(c)
                c = c or {}
                iOrder = iOrder + 1
                local rowH = c.Description and 52 or 34
                local row = Utils.New("Frame", {
                    BackgroundTransparency = 1,
                    Size                   = UDim2.new(1, 0, 0, rowH),
                    LayoutOrder            = iOrder,
                    Parent                 = card,
                })
                local btn2 = Utils.New("TextButton", {
                    BackgroundColor3 = T.BG4,
                    Position         = UDim2.new(0, 2, 0, c.Description and 4 or 5),
                    Size             = UDim2.new(1, -4, 0, 24),
                    Text             = "",
                    ClipsDescendants = true,
                    Parent           = row,
                })
                Utils.Corner(btn2, 6)
                Utils.Stroke(btn2, T.Border, 1)
                Utils.Gradient(btn2, { Color3.fromRGB(55, 22, 75), Color3.fromRGB(38, 14, 58) }, 90)

                Utils.New("TextLabel", {
                    BackgroundTransparency = 1,
                    Size                   = UDim2.new(1, 0, 1, 0),
                    Text                   = c.Name or "Button",
                    TextColor3             = T.PinkLight,
                    Font                   = T.FntBold,
                    TextSize               = 10,
                    Parent                 = btn2,
                })

                if c.Description then
                    Utils.New("TextLabel", {
                        BackgroundTransparency = 1,
                        Position               = UDim2.new(0, 2, 0, 30),
                        Size                   = UDim2.new(1, -4, 0, 14),
                        Text                   = c.Description,
                        TextColor3             = T.TxtMute,
                        Font                   = T.FntBody,
                        TextSize               = 8,
                        TextXAlignment         = Enum.TextXAlignment.Center,
                        Parent                 = row,
                    })
                end

                btn2.MouseEnter:Connect(function()
                    Utils.Tween(btn2, { BackgroundColor3 = Color3.fromRGB(68, 28, 90) }, 0.15)
                end)
                btn2.MouseLeave:Connect(function()
                    Utils.Tween(btn2, { BackgroundColor3 = T.BG4 }, 0.15)
                end)
                btn2.MouseButton1Click:Connect(function()
                    Utils.Ripple(btn2, Mouse.X, Mouse.Y)
                    Utils.Tween(btn2, { BackgroundColor3 = T.Pink }, 0.06)
                    task.wait(0.09)
                    Utils.Tween(btn2, { BackgroundColor3 = T.BG4 }, 0.3)
                    ;(c.Callback or function() end)()
                end)
            end

            -- ── KEYBIND ──
            function Sec:AddBind(c)
                c = c or {}
                local row       = Row(c.Name or "Keybind")
                local boundKey  = c.Default
                local listening = false
                local cb        = c.Callback or function() end

                local chip = Utils.New("TextButton", {
                    BackgroundColor3 = T.BG4,
                    Position         = UDim2.new(1, -76, 0.5, -11),
                    Size             = UDim2.new(0, 72, 0, 22),
                    Text             = boundKey and boundKey.Name or "None",
                    TextColor3       = boundKey and T.PinkLight or T.TxtMute,
                    Font             = T.FntMono,
                    TextSize         = 9,
                    ClipsDescendants = true,
                    Parent           = row,
                })
                Utils.Corner(chip, 5)
                Utils.Stroke(chip, T.Border, 1)

                chip.MouseButton1Click:Connect(function()
                    if listening then return end
                    listening      = true
                    chip.Text      = "..."
                    chip.TextColor3 = T.Pink
                    local con
                    con = UserInputService.InputBegan:Connect(function(i, gp)
                        if gp then return end
                        if i.UserInputType == Enum.UserInputType.Keyboard then
                            if i.KeyCode == Enum.KeyCode.Escape then
                                boundKey        = nil
                                chip.Text       = "None"
                                chip.TextColor3 = T.TxtMute
                            else
                                boundKey        = i.KeyCode
                                chip.Text       = i.KeyCode.Name
                                chip.TextColor3 = T.PinkLight
                            end
                            listening = false
                            con:Disconnect()
                        end
                    end)
                end)

                UserInputService.InputBegan:Connect(function(i, gp)
                    if not gp and boundKey and i.KeyCode == boundKey then cb() end
                end)

                local obj = {}
                function obj:Set(v)
                    boundKey        = v
                    chip.Text       = v and v.Name or "None"
                    chip.TextColor3 = v and T.PinkLight or T.TxtMute
                end
                function obj:Get() return boundKey end
                return obj
            end

            -- ── DROPDOWN ──
            function Sec:AddDropdown(c)
                c = c or {}
                local row     = Row(c.Name or "Dropdown", 34)
                local options = c.Options  or {}
                local sel     = c.Default  or options[1]
                local cb      = c.Callback or function() end
                local isOpen  = false

                local dropBtn = Utils.New("TextButton", {
                    BackgroundColor3 = T.BG4,
                    Position         = UDim2.new(0.42, 0, 0.5, -11),
                    Size             = UDim2.new(0.58, -2, 0, 22),
                    Text             = "",
                    ClipsDescendants = false,
                    Parent           = row,
                })
                Utils.Corner(dropBtn, 5)
                Utils.Stroke(dropBtn, T.Border, 1)

                local selLabel = Utils.New("TextLabel", {
                    BackgroundTransparency = 1,
                    Position               = UDim2.new(0, 7, 0, 0),
                    Size                   = UDim2.new(1, -22, 1, 0),
                    Text                   = tostring(sel or ""),
                    TextColor3             = T.TxtPri,
                    Font                   = T.FntBody,
                    TextSize               = 9,
                    TextXAlignment         = Enum.TextXAlignment.Left,
                    Parent                 = dropBtn,
                })

                local chevron = Utils.New("TextLabel", {
                    BackgroundTransparency = 1,
                    Position               = UDim2.new(1, -16, 0.5, -7),
                    Size                   = UDim2.new(0, 12, 0, 14),
                    Text                   = "v",
                    TextColor3             = T.PinkLight,
                    Font                   = T.FntBold,
                    TextSize               = 9,
                    Parent                 = dropBtn,
                })

                -- Lista flutuante (parente no contentArea para não clipar)
                local dropList = Utils.New("Frame", {
                    BackgroundColor3 = T.BG2,
                    Position         = UDim2.new(0, 0, 1, 4),
                    Size             = UDim2.new(1, 0, 0, 0),
                    ZIndex           = 100,
                    ClipsDescendants = true,
                    Visible          = false,
                    Parent           = dropBtn,
                })
                Utils.Corner(dropList, 7)
                Utils.Stroke(dropList, T.Border, 1)
                Utils.New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Parent = dropList })

                for i, opt in ipairs(options) do
                    local ob = Utils.New("TextButton", {
                        BackgroundColor3      = T.BG4,
                        BackgroundTransparency = (opt == sel) and 0.5 or 1,
                        Size                  = UDim2.new(1, 0, 0, 26),
                        Text                  = "",
                        LayoutOrder           = i,
                        ZIndex                = 101,
                        Parent                = dropList,
                    })
                    Utils.New("TextLabel", {
                        BackgroundTransparency = 1,
                        Position               = UDim2.new(0, 9, 0, 0),
                        Size                   = UDim2.new(1, -9, 1, 0),
                        Text                   = tostring(opt),
                        TextColor3             = (opt == sel) and T.PinkLight or T.TxtPri,
                        Font                   = T.FntBody,
                        TextSize               = 9,
                        TextXAlignment         = Enum.TextXAlignment.Left,
                        ZIndex                 = 102,
                        Parent                 = ob,
                    })
                    ob.MouseEnter:Connect(function() Utils.Tween(ob, { BackgroundTransparency = 0.6, BackgroundColor3 = T.BG4 }, 0.1) end)
                    ob.MouseLeave:Connect(function() Utils.Tween(ob, { BackgroundTransparency = opt == sel and 0.5 or 1 }, 0.1) end)
                    ob.MouseButton1Click:Connect(function()
                        sel           = opt
                        selLabel.Text = tostring(opt)
                        isOpen        = false
                        Utils.Tween(chevron,  { Rotation = 0 }, 0.2)
                        Utils.Tween(dropList, { Size = UDim2.new(1, 0, 0, 0) }, 0.2)
                        task.wait(0.22)
                        dropList.Visible = false
                        cb(sel)
                    end)
                end

                local totalH = #options * 26
                dropBtn.MouseButton1Click:Connect(function()
                    isOpen = not isOpen
                    if isOpen then
                        dropList.Visible = true
                        dropList.Size    = UDim2.new(1, 0, 0, 0)
                        Utils.Tween(dropList, { Size = UDim2.new(1, 0, 0, totalH) }, 0.28, Enum.EasingStyle.Back)
                        Utils.Tween(chevron,  { Rotation = 180 }, 0.2)
                    else
                        Utils.Tween(chevron,  { Rotation = 0 }, 0.2)
                        Utils.Tween(dropList, { Size = UDim2.new(1, 0, 0, 0) }, 0.2)
                        task.wait(0.22)
                        dropList.Visible = false
                    end
                end)

                local obj = {}
                function obj:Set(v)  sel = v selLabel.Text = tostring(v) end
                function obj:Get()  return sel end
                return obj
            end

            -- ── TEXTBOX ──
            function Sec:AddTextBox(c)
                c = c or {}
                local row     = Row(c.Name or "Input", 34)
                local cb      = c.Callback  or function() end
                local numOnly = c.NumberOnly or false

                local box = Utils.New("TextBox", {
                    BackgroundColor3  = T.BG4,
                    Position          = UDim2.new(0.42, 0, 0.5, -11),
                    Size              = UDim2.new(0.58, -2, 0, 22),
                    Text              = c.Default     or "",
                    PlaceholderText   = c.Placeholder  or "...",
                    TextColor3        = T.TxtPri,
                    PlaceholderColor3 = T.TxtMute,
                    Font              = T.FntBody,
                    TextSize          = 9,
                    ClearTextOnFocus  = false,
                    Parent            = row,
                })
                Utils.Corner(box, 5)
                local boxStroke = Utils.Stroke(box, T.Border, 1)

                box.Focused:Connect(function()
                    Utils.Tween(boxStroke, { Color = T.Pink }, 0.2)
                    Utils.Tween(box, { BackgroundColor3 = Color3.fromRGB(48, 22, 68) }, 0.2)
                end)
                box.FocusLost:Connect(function(enter)
                    Utils.Tween(boxStroke, { Color = T.Border }, 0.2)
                    Utils.Tween(box, { BackgroundColor3 = T.BG4 }, 0.2)
                    if numOnly and not tonumber(box.Text) then box.Text = "" end
                    if enter then cb(box.Text) end
                end)
                box:GetPropertyChangedSignal("Text"):Connect(function()
                    if numOnly then box.Text = box.Text:gsub("[^%d%.%-]", "") end
                end)

                local obj = {}
                function obj:Set(v) box.Text = tostring(v) end
                function obj:Get()  return box.Text end
                return obj
            end

            -- ── COLOR PICKER ──
            function Sec:AddColorPicker(c)
                c = c or {}
                local row   = Row(c.Name or "Color", 34)
                local cb    = c.Callback or function() end
                local cur   = c.Default  or Color3.fromRGB(255, 105, 180)
                local popen = false
                local hsv   = {}
                do
                    local h, s, v = Color3.toHSV(cur)
                    hsv.h, hsv.s, hsv.v = h, s, v
                end

                local swatch = Utils.New("TextButton", {
                    BackgroundColor3 = cur,
                    Position         = UDim2.new(1, -36, 0.5, -11),
                    Size             = UDim2.new(0, 32, 0, 22),
                    Text             = "",
                    Parent           = row,
                })
                Utils.Corner(swatch, 5)
                Utils.Stroke(swatch, T.Border, 1)

                -- Hex display
                local function ColorToHex(col)
                    return string.format("#%02X%02X%02X",
                        math.round(col.R * 255),
                        math.round(col.G * 255),
                        math.round(col.B * 255)
                    )
                end
                local hexLabel = Utils.New("TextLabel", {
                    BackgroundTransparency = 1,
                    Position               = UDim2.new(1, -38 - 55, 0.5, -8),
                    Size                   = UDim2.new(0, 52, 0, 16),
                    Text                   = ColorToHex(cur),
                    TextColor3             = T.TxtMute,
                    Font                   = T.FntMono,
                    TextSize               = 8,
                    Parent                 = row,
                })

                -- Panel flutuante
                local panel = Utils.New("Frame", {
                    BackgroundColor3 = T.BG2,
                    Size             = UDim2.new(0, 185, 0, 0),
                    ZIndex           = 200,
                    Visible          = false,
                    ClipsDescendants = true,
                    Parent           = contentArea,
                })
                Utils.Corner(panel, 9)
                Utils.Stroke(panel, T.PinkMute, 1, 0.3)
                Utils.Pad(panel, 10, 10, 10, 10)
                Utils.New("UIListLayout", { Padding = UDim.new(0, 8), SortOrder = Enum.SortOrder.LayoutOrder, Parent = panel })

                local function Rebuild()
                    cur              = Color3.fromHSV(hsv.h, hsv.s, hsv.v)
                    swatch.BackgroundColor3 = cur
                    hexLabel.Text           = ColorToHex(cur)
                    cb(cur)
                end

                local sliderDefs = {
                    { lbl = "H", key = "h", c1 = Color3.fromRGB(255,0,0), c2 = Color3.fromRGB(0,0,255) },
                    { lbl = "S", key = "s", c1 = Color3.fromRGB(160,160,160), c2 = Color3.fromRGB(255,105,180) },
                    { lbl = "V", key = "v", c1 = Color3.fromRGB(0,0,0), c2 = Color3.fromRGB(255,255,255) },
                }

                for i, sd in ipairs(sliderDefs) do
                    local sr = Utils.New("Frame", {
                        BackgroundTransparency = 1,
                        Size                   = UDim2.new(1, 0, 0, 26),
                        LayoutOrder            = i,
                        Parent                 = panel,
                    })
                    Utils.New("TextLabel", {
                        BackgroundTransparency = 1,
                        Size                   = UDim2.new(0, 12, 1, 0),
                        Text                   = sd.lbl,
                        TextColor3             = T.TxtMute,
                        Font                   = T.FntMono,
                        TextSize               = 9,
                        Parent                 = sr,
                    })
                    local slTrk = Utils.New("Frame", {
                        BackgroundColor3 = T.BG4,
                        Position         = UDim2.new(0, 16, 0.5, -5),
                        Size             = UDim2.new(1, -16, 0, 10),
                        Parent           = sr,
                    })
                    Utils.Corner(slTrk, 999)
                    Utils.New("UIGradient", {
                        Color  = ColorSequence.new({ ColorSequenceKeypoint.new(0, sd.c1), ColorSequenceKeypoint.new(1, sd.c2) }),
                        Parent = slTrk,
                    })
                    local slThumb = Utils.New("Frame", {
                        BackgroundColor3 = Color3.new(1, 1, 1),
                        AnchorPoint      = Vector2.new(0.5, 0.5),
                        Position         = UDim2.new(hsv[sd.key], 0, 0.5, 0),
                        Size             = UDim2.new(0, 12, 0, 12),
                        ZIndex           = 201,
                        Parent           = slTrk,
                    })
                    Utils.Corner(slThumb, 999)
                    Utils.Stroke(slThumb, Color3.new(1, 1, 1), 2)

                    local dH = false
                    slTrk.InputBegan:Connect(function(inp)
                        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                            dH = true
                            local p = math.clamp((inp.Position.X - slTrk.AbsolutePosition.X) / slTrk.AbsoluteSize.X, 0, 1)
                            hsv[sd.key]      = p
                            slThumb.Position = UDim2.new(p, 0, 0.5, 0)
                            Rebuild()
                        end
                    end)
                    local mv = UserInputService.InputChanged:Connect(function(inp)
                        if dH and inp.UserInputType == Enum.UserInputType.MouseMovement then
                            local p = math.clamp((inp.Position.X - slTrk.AbsolutePosition.X) / slTrk.AbsoluteSize.X, 0, 1)
                            hsv[sd.key]      = p
                            slThumb.Position = UDim2.new(p, 0, 0.5, 0)
                            Rebuild()
                        end
                    end)
                    local ed = UserInputService.InputEnded:Connect(function(inp)
                        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dH = false end
                    end)
                    panel.AncestryChanged:Connect(function()
                        if not panel.Parent then mv:Disconnect() ed:Disconnect() end
                    end)
                end

                swatch.MouseButton1Click:Connect(function()
                    popen = not popen
                    if popen then
                        local ax = swatch.AbsolutePosition.X - contentArea.AbsolutePosition.X
                        local ay = swatch.AbsolutePosition.Y - contentArea.AbsolutePosition.Y
                        panel.Position = UDim2.new(0,
                            math.clamp(ax - 150, 0, contentArea.AbsoluteSize.X - 190),
                            0,
                            ay + 28
                        )
                        panel.Visible = true
                        panel.Size    = UDim2.new(0, 185, 0, 0)
                        Utils.Tween(panel, { Size = UDim2.new(0, 185, 0, 120) }, 0.3, Enum.EasingStyle.Back)
                    else
                        Utils.Tween(panel, { Size = UDim2.new(0, 185, 0, 0) }, 0.22)
                        task.wait(0.25)
                        panel.Visible = false
                    end
                end)

                local obj = {}
                function obj:Set(col)
                    cur               = col
                    swatch.BackgroundColor3 = col
                    hexLabel.Text           = ColorToHex(col)
                    local h, s, v = Color3.toHSV(col)
                    hsv.h, hsv.s, hsv.v = h, s, v
                end
                function obj:Get() return cur end
                return obj
            end

            -- ── LABEL ──
            function Sec:AddLabel(text)
                iOrder = iOrder + 1
                local r = Utils.New("Frame", {
                    BackgroundTransparency = 1,
                    Size                   = UDim2.new(1, 0, 0, 22),
                    LayoutOrder            = iOrder,
                    Parent                 = card,
                })
                Utils.New("TextLabel", {
                    BackgroundTransparency = 1,
                    Position               = UDim2.new(0, 2, 0, 0),
                    Size                   = UDim2.new(1, -4, 1, 0),
                    Text                   = text,
                    TextColor3             = T.TxtSec,
                    Font                   = T.FntBody,
                    TextSize               = 9,
                    TextXAlignment         = Enum.TextXAlignment.Left,
                    TextWrapped            = true,
                    Parent                 = r,
                })
            end

            -- ── SEPARATOR ──
            function Sec:AddSeparator(label)
                iOrder = iOrder + 1
                local r = Utils.New("Frame", {
                    BackgroundTransparency = 1,
                    Size                   = UDim2.new(1, 0, 0, 20),
                    LayoutOrder            = iOrder,
                    Parent                 = card,
                })
                Utils.New("Frame", {
                    BackgroundColor3      = T.Border,
                    BackgroundTransparency = 0.4,
                    AnchorPoint          = Vector2.new(0, 0.5),
                    Position             = UDim2.new(0, 0, 0.5, 0),
                    Size                 = UDim2.new(1, 0, 0, 1),
                    Parent               = r,
                })
                if label then
                    local lbg = Utils.New("Frame", {
                        BackgroundColor3 = T.BG3,
                        AnchorPoint      = Vector2.new(0, 0.5),
                        Position         = UDim2.new(0, 8, 0.5, 0),
                        Size             = UDim2.new(0, 0, 0, 14),
                        AutomaticSize    = Enum.AutomaticSize.X,
                        Parent           = r,
                    })
                    Utils.Pad(lbg, 0, 5, 0, 5)
                    Utils.New("TextLabel", {
                        BackgroundTransparency = 1,
                        Size                   = UDim2.new(0, 0, 1, 0),
                        AutomaticSize          = Enum.AutomaticSize.X,
                        Text                   = label,
                        TextColor3             = T.PinkMute,
                        Font                   = T.FntBold,
                        TextSize               = 8,
                        Parent                 = lbg,
                    })
                end
            end

            return Sec
        end -- AddSection

        return Tab
    end -- AddTab

    -- ── Animação de entrada ──
    win.Size                = UDim2.new(0, winWidth, 0, 0)
    win.BackgroundTransparency = 1
    task.wait(0.05)
    Utils.Tween(win, { Size = UDim2.new(0, winWidth, 0, winHeight), BackgroundTransparency = 0 }, 0.45, Enum.EasingStyle.Back)
    TwBlur(8, 0.45)

    table.insert(BarbiUI._windows, Win)
    return Win
end

-- ══════════════════════════════════════════════════════════════════
return BarbiUI
