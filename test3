            -- Desativar todos
            for _, item in ipairs(Win._btns) do
                Utils.Tween(item.btn, { BackgroundTransparency = 1 }, 0.2)
                Utils.Tween(item.lbl, { TextColor3 = T.TxtSec }, 0.2)
                if item.bar then Utils.Tween(item.bar, { BackgroundTransparency = 0.6 }, 0.2) end
            end
            for _, pg in ipairs(Win._tabs) do pg.Visible = false end

            -- Ativar este
            Utils.Tween(btn, { BackgroundTransparency = 0.75, BackgroundColor3 = T.BG3 }, 0.2)
            Utils.Tween(nameLbl, { TextColor3 = T.Pink }, 0.2)
            Utils.Tween(accentBar, { BackgroundTransparency = 0 }, 0.2)

            local yp = btn.AbsolutePosition.Y - sidebar.AbsolutePosition.Y + btn.AbsoluteSize.Y / 2
            if instant then
                indicator.Position = UDim2.new(1, 0, 0, yp - 14)
            else
                Utils.Tween(indicator, { Position = UDim2.new(1, 0, 0, yp - 14) }, 0.3, Enum.EasingStyle.Quart)
            end

            page.Visible   = true
            Win._active    = page
        end

        table.insert(Win._tabs, page)
        table.insert(Win._btns, { btn = btn, lbl = nameLbl, bar = accentBar })

        btn.MouseEnter:Connect(function()
