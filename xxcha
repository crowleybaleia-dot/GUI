function Library.SaveManager:BuildConfigSection(tabOrGroupbox)
	-- if you pass a groupbox, add save/load controls
	local gb = tabOrGroupbox
	gb:AddLabel("Config")
	gb:AddDivider()
	gb:AddInput("ProfileName", {Text="Profile", Default="default"})
	gb:AddButton("SaveProfile", {Text="Save"}, function()
		local name = Library.Options.ProfileName and Library.Options.ProfileName.Value or "default"
		local ok, err = self:Save(name)
		if ok then Library:Notify("Saved: "..name, 2, "good") else Library:Notify("Save fail: "..tostring(err), 3, "bad") end
	end)
	gb:AddButton("LoadProfile", {Text="Load"}, function()
		local name = Library.Options.ProfileName and Library.Options.ProfileName.Value or "default"
		local ok, err = self:Load(name)
		if ok then Library:Notify("Loaded: "..name, 2, "good") else Library:Notify("Load fail: "..tostring(err), 3, "bad") end
	end)
end

function Library.SaveManager:Save(profileName)
	if not CanFS() then return false, "filesystem not available" end
	local data = {Toggles={}, Options={}}
	for id,t in pairs(Library.Toggles) do data.Toggles[id] = t.Value end
	for id,o in pairs(Library.Options) do
		if id ~= "ProfileName" then data.Options[id] = o.Value end
	end
	writefile(string.format("%s/%s.json", Library.ProfilesFolder, profileName), JSONEncode(data))
	return true
end

function Library.SaveManager:Load(profileName)
	if not CanFS() then return false, "filesystem not available" end
	local path = string.format("%s/%s.json", Library.ProfilesFolder, profileName)
	if not isfile(path) then return false, "profile not found" end
	local ok, decoded = pcall(function() return JSONDecode(readfile(path)) end)
	if not ok then return false, "bad json" end
	for id,v in pairs(decoded.Toggles or {}) do
		if Library.Toggles[id] then Library.Toggles[id]:SetValue(v) end
	end
	for id,v in pairs(decoded.Options or {}) do
		if Library.Options[id] then Library.Options[id]:SetValue(v) end
	end
	return true
end

