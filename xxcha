local Theme = {
	Colors = {
		Sage = Color3.fromRGB(135,168,120),
		Ink = Color3.fromRGB(10,10,10),
		Ink2 = Color3.fromRGB(14,14,14),
		Glass = Color3.fromRGB(16,16,16),
		Text = Color3.fromRGB(232,232,232),
		Sub = Color3.fromRGB(180,180,180),
		Muted = Color3.fromRGB(120,120,120),
		Warn = Color3.fromRGB(255,180,80),
		Bad  = Color3.fromRGB(255,95,95),
		Good = Color3.fromRGB(120,255,160),
	},
	Radius = 12,
	StrokeTransparency = 0.72,
	GlassTransparency = 0.18,
	Anim = 0.15,
	TextSize = 13,
	MonoTextSize = 12,
}

local function Corner(parent, r)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, r or Theme.Radius)
	c.Parent = parent
	return c
end

local function Stroke(parent, color, tr, th)
	local s = Instance.new("UIStroke")
	s.Color = color or Theme.Colors.Sage
	s.Transparency = tr ~= nil and tr or Theme.StrokeTransparency
	s.Thickness = th or 1
	s.Parent = parent
	return s
end

local function Padding(parent, l,t,r,b)
	local p = Instance.new("UIPadding")
	p.PaddingLeft = UDim.new(0, l or 0)
	p.PaddingTop = UDim.new(0, t or 0)
	p.PaddingRight = UDim.new(0, r or 0)
	p.PaddingBottom = UDim.new(0, b or 0)
	p.Parent = parent
	return p
end

local function ListLayout(parent, fill, paddingPx)
	local ll = Instance.new("UIListLayout")
	ll.FillDirection = fill or Enum.FillDirection.Vertical
	ll.SortOrder = Enum.SortOrder.LayoutOrder
	ll.Padding = UDim.new(0, paddingPx or 8)
	ll.Parent = parent
	return ll
end

local function MakeLabel(parent, text, size, color, mono)
	local t = Instance.new("TextLabel")
	t.BackgroundTransparency = 1
	t.Text = text or ""
	t.TextXAlignment = Enum.TextXAlignment.Left
	t.TextYAlignment = Enum.TextYAlignment.Center
	t.TextSize = size or Theme.TextSize
	t.TextColor3 = color or Theme.Colors.Text
	t.Font = mono and Enum.Font.Code or Enum.Font.Gotham
	t.Parent = parent
	return t
end

local function MakeButtonBase(parent)
	local b = Instance.new("TextButton")
	b.AutoButtonColor = false
	b.Text = ""
	b.BackgroundColor3 = Theme.Colors.Glass
	b.BackgroundTransparency = Theme.GlassTransparency
	b.Parent = parent
	Corner(b)
	local st = Stroke(b, Theme.Colors.Sage, Theme.StrokeTransparency)
	return b, st
end

local function MakePanel(parent)
	local f = Instance.new("Frame")
	f.BackgroundColor3 = Theme.Colors.Glass
	f.BackgroundTransparency = Theme.GlassTransparency
	f.Parent = parent
	Corner(f)
	Stroke(f, Theme.Colors.Sage, Theme.StrokeTransparency)
	return f
end

--========================
-- Option base (Linoria-ish)
--========================
local BaseOption = {}
BaseOption.__index = BaseOption

function BaseOption.new(id, default)
	local self = setmetatable({}, BaseOption)
	self.Id = id
	self.Value = default
	self.Changed = Signal()
	self.Disabled = false
	return self
end

function BaseOption:SetValue(v)
	if self.Disabled then return end
	if self.Value == v then return end
	self.Value = v
	if self._sync then self:_sync(v) end
	self.Changed:Fire(v)
end

function BaseOption:OnChanged(fn)
	return self.Changed:Connect(fn)
end

function BaseOption:SetDisabled(v)
	self.Disabled = v and true or false
	if self._setDisabled then self:_setDisabled(self.Disabled) end
end

