function Window:AddTab(name)
	local tab = {}
	tab.Name = name
	tab.Groups = {}
	tab._visible = false

	-- left tab button
	local btn, st = MakeButtonBase(self.LeftTabs)
	btn.Size = UDim2.new(1,0,0,38)
	btn.BackgroundTransparency = 0.12
	st.Transparency = 0.80

	Padding(btn, 10, 0, 10, 0)
	local t = MakeLabel(btn, name, 13, Theme.Colors.Text, false)
	t.Size = UDim2.new(1,0,1,0)

	-- center page
	local page = Instance.new("Frame")
	page.BackgroundTransparency = 1
	page.Size = UDim2.new(1,0,1,0)
	page.Visible = false
	page.Parent = self.CenterPages

	local leftCol = Instance.new("Frame")
	leftCol.BackgroundTransparency = 1
	leftCol.Size = UDim2.new(0.5, -6, 1, 0)
	leftCol.Parent = page
	ListLayout(leftCol, Enum.FillDirection.Vertical, 10)

	local rightCol = Instance.new("Frame")
	rightCol.BackgroundTransparency = 1
	rightCol.Size = UDim2.new(0.5, -6, 1, 0)
	rightCol.Position = UDim2.new(0.5, 6, 0, 0)
	rightCol.Parent = page
	ListLayout(rightCol, Enum.FillDirection.Vertical, 10)

	function tab:Show()
		for _,tb in ipairs(self._window.Tabs) do
			tb.Page.Visible = false
			tb.ButtonStroke.Transparency = 0.85
		end
		page.Visible = true
		st.Transparency = 0.35
	end

	tab.Button = btn
	tab.ButtonStroke = st
	tab.Page = page
	tab.LeftCol = leftCol
	tab.RightCol = rightCol
	tab._window = self
	table.insert(self.Tabs, tab)

	btn.MouseButton1Click:Connect(function()
		tab:Show()
	end)

	function tab:AddLeftGroupbox(title)
		local box, content = MakeGroupbox(leftCol, title)
		local gb = self._window:_wrapGroupbox(content)
		gb._box = box
		return gb
	end

	function tab:AddRightGroupbox(title)
		local box, content = MakeGroupbox(rightCol, title)
		local gb = self._window:_wrapGroupbox(content)
		gb._box = box
		return gb
	end

	return tab
end

function Window:_wrapGroupbox(container)
	local gb = {}
	gb.Container = container
	gb.Window = self

	-- Common builders:
	function gb:AddLabel(text)
		local l = MakeLabel(container, text or "", 13, Theme.Colors.Sub, false)
		l.Size = UDim2.new(1,0,0,18)
		local o = BaseOption.new("_label_"..tostring(math.random(1,1e9)), text)
		o._sync = function(v) l.Text = tostring(v) end
		return o
	end

	function gb:AddDivider()
		local d = Instance.new("Frame")
		d.BackgroundColor3 = Theme.Colors.Sage
		d.BackgroundTransparency = 0.75
		d.Size = UDim2.new(1,0,0,1)
		d.Parent = container
		return d
	end

	function gb:AddParagraph(title, text)
		local f = Instance.new("Frame")
		f.BackgroundTransparency = 1
		f.Size = UDim2.new(1,0,0,0)
		f.AutomaticSize = Enum.AutomaticSize.Y
		f.Parent = container

		local t1 = MakeLabel(f, title or "Paragraph", 13, Theme.Colors.Text, false)
		t1.Size = UDim2.new(1,0,0,18)

		local t2 = Instance.new("TextLabel")
		t2.BackgroundTransparency = 1
		t2.TextXAlignment = Enum.TextXAlignment.Left
		t2.TextYAlignment = Enum.TextYAlignment.Top
		t2.TextWrapped = true
		t2.AutomaticSize = Enum.AutomaticSize.Y
		t2.Size = UDim2.new(1,0,0,0)
		t2.Position = UDim2.new(0,0,0,20)
		t2.TextSize = 12
		t2.TextColor3 = Theme.Colors.Sub
		t2.Font = Enum.Font.Gotham
		t2.Text = text or ""
		t2.Parent = f

		local o = BaseOption.new("_para_"..tostring(math.random(1,1e9)), {title=title,text=text})
		o._sync = function(v)
			t1.Text = tostring(v.title or "")
			t2.Text = tostring(v.text or "")
		end
		return o
	end

	function gb:AddButton(idOrText, cbOrOpts, cbMaybe)
		local id, opts, cb
		if type(cbOrOpts) == "function" then
			id = tostring(idOrText)
			opts = {Text = id}
			cb = cbOrOpts
		else
			id = tostring(idOrText)
			opts = cbOrOpts or {}
			cb = cbMaybe
		end

		local b, st = MakeButtonBase(container)
		b.Size = UDim2.new(1,0,0,34)
		b.BackgroundTransparency = 0.10
		st.Transparency = 0.65
		Padding(b, 10, 0, 10, 0)
		local txt = MakeLabel(b, opts.Text or id, 13, Theme.Colors.Text, false)
		txt.Size = UDim2.new(1,0,1,0)

		b.MouseEnter:Connect(function()
			Tween(st, TweenInfo.new(Theme.Anim), {Transparency = 0.35})
		end)
		b.MouseLeave:Connect(function()
			Tween(st, TweenInfo.new(Theme.Anim), {Transparency = 0.65})
		end)

		b.MouseButton1Click:Connect(function()
			if cb then task.spawn(cb) end
		end)

		local o = BaseOption.new(id, false)
		-- button não precisa ser Options, mas Linoria às vezes retorna objeto.
		return o
	end

	function gb:AddToggle(id, opts)
		opts = opts or {}
		local o = BaseOption.new(id, opts.Default or false)

		local row = Instance.new("Frame")
		row.BackgroundTransparency = 1
		row.Size = UDim2.new(1,0,0,34)
		row.Parent = container

		local click, st = MakeButtonBase(row)
		click.Size = UDim2.new(1,0,1,0)
		click.BackgroundTransparency = 0.10
		st.Transparency = 0.70

		Padding(click, 10, 0, 10, 0)

		local label = MakeLabel(click, opts.Text or id, 13, Theme.Colors.Text, false)
		label.Size = UDim2.new(1,-54,1,0)

		local pill = Instance.new("Frame")
		pill.Size = UDim2.new(0,42,0,20)
		pill.Position = UDim2.new(1,-42,0.5,-10)
		pill.BackgroundColor3 = Theme.Colors.Ink2
		pill.BackgroundTransparency = 0.1
		pill.Parent = click
		Corner(pill, 999)
		Stroke(pill, Theme.Colors.Sage, 0.7)

		local knob = Instance.new("Frame")
		knob.Size = UDim2.new(0,16,0,16)
		knob.Position = UDim2.new(0,2,0.5,-8)
		knob.BackgroundColor3 = Theme.Colors.Muted
		knob.BackgroundTransparency = 0.0
		knob.Parent = pill
		Corner(knob, 999)

		local function render(v)
			if v then
				Tween(knob, TweenInfo.new(Theme.Anim), {Position = UDim2.new(1,-18,0.5,-8), BackgroundColor3 = Theme.Colors.Sage})
			else
				Tween(knob, TweenInfo.new(Theme.Anim), {Position = UDim2.new(0,2,0.5,-8), BackgroundColor3 = Theme.Colors.Muted})
			end
		end

		o._sync = render
		o:_sync(o.Value)

		click.MouseButton1Click:Connect(function()
			o:SetValue(not o.Value)
		end)

		Library.Toggles[id] = o
		return o
	end

	function gb:AddSlider(id, opts)
		opts = opts or {}
		local min = opts.Min or 0
		local max = opts.Max or 100
		local round = opts.Rounding or 0
		local default = opts.Default or min

		local o = BaseOption.new(id, default)

		local wrap = Instance.new("Frame")
		wrap.BackgroundTransparency = 1
		wrap.Size = UDim2.new(1,0,0,52)
		wrap.Parent = container

		local top = Instance.new("Frame")
		top.BackgroundTransparency = 1
		top.Size = UDim2.new(1,0,0,18)
		top.Parent = wrap

		local label = MakeLabel(top, opts.Text or id, 13, Theme.Colors.Text, false)
		label.Size = UDim2.new(1,-70,1,0)

		local val = MakeLabel(top, tostring(default), 12, Theme.Colors.Sub, true)
		val.Size = UDim2.new(0,70,1,0)
		val.TextXAlignment = Enum.TextXAlignment.Right
		val.Position = UDim2.new(1,-70,0,0)

		local bar, st = MakeButtonBase(wrap)
		bar.Position = UDim2.new(0,0,0,24)
		bar.Size = UDim2.new(1,0,0,24)
		bar.BackgroundTransparency = 0.12
		st.Transparency = 0.75

		local fill = Instance.new("Frame")
		fill.BackgroundColor3 = Theme.Colors.Sage
		fill.BackgroundTransparency = 0.35
		fill.Size = UDim2.new(0,0,1,0)
		fill.Parent = bar
		Corner(fill, Theme.Radius)

		local dragging = false
		local function setFromX(x)
			local rel = Clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
			local raw = min + (max - min) * rel
			if round and round > 0 then raw = Round(raw, 10^(-round)) end
			if opts.Rounding == 0 then raw = math.floor(raw + 0.5) end
			o:SetValue(raw)
		end

		bar.InputBegan:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = true
				setFromX(inp.Position.X)
			end
		end)
		bar.InputEnded:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
		end)
		UserInputService.InputChanged:Connect(function(inp)
			if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
				setFromX(inp.Position.X)
			end
		end)

		o._sync = function(v)
			local rel = (v - min) / (max - min)
			rel = Clamp(rel, 0, 1)
			fill.Size = UDim2.new(rel, 0, 1, 0)
			val.Text = tostring(v)
		end
		o:_sync(o.Value)

		Library.Options[id] = o
		return o
	end

	function gb:AddInput(id, opts)
		opts = opts or {}
		local o = BaseOption.new(id, opts.Default or "")

		local row = Instance.new("Frame")
		row.BackgroundTransparency = 1
		row.Size = UDim2.new(1,0,0,52)
		row.Parent = container

		local label = MakeLabel(row, opts.Text or id, 13, Theme.Colors.Text, false)
		label.Size = UDim2.new(1,0,0,18)

		local box, st = MakeButtonBase(row)
		box.Size = UDim2.new(1,0,0,28)
		box.Position = UDim2.new(0,0,0,22)
		box.BackgroundTransparency = 0.12
		st.Transparency = 0.75

		local tb = Instance.new("TextBox")
		tb.BackgroundTransparency = 1
		tb.Text = tostring(o.Value)
		tb.PlaceholderText = opts.Placeholder or ""
		tb.TextXAlignment = Enum.TextXAlignment.Left
		tb.TextSize = 13
		tb.TextColor3 = Theme.Colors.Text
		tb.PlaceholderColor3 = Theme.Colors.Muted
		tb.Font = Enum.Font.Gotham
		tb.ClearTextOnFocus = opts.ClearOnFocus or false
		tb.Size = UDim2.new(1,-16,1,0)
		tb.Position = UDim2.new(0,8,0,0)
		tb.Parent = box

		tb.FocusLost:Connect(function()
			o:SetValue(tb.Text)
		end)

		o._sync = function(v) tb.Text = tostring(v) end

		Library.Options[id] = o
		return o
	end

	-- Dropdown (single/multi) com modal simples
	function gb:AddDropdown(id, opts)
		opts = opts or {}
		local values = opts.Values or {}
		local multi = opts.Multi or false
		local default = opts.Default
		if multi then
			default = default or {}
		else
			if type(default) ~= "number" then default = 1 end
			default = values[default] or values[1]
		end
		local o = BaseOption.new(id, default)

		local row = Instance.new("Frame")
		row.BackgroundTransparency = 1
		row.Size = UDim2.new(1,0,0,52)
		row.Parent = container

		local label = MakeLabel(row, opts.Text or id, 13, Theme.Colors.Text, false)
		label.Size = UDim2.new(1,0,0,18)

		local btn, st = MakeButtonBase(row)
		btn.Size = UDim2.new(1,0,0,28)
		btn.Position = UDim2.new(0,0,0,22)
		btn.BackgroundTransparency = 0.12
		st.Transparency = 0.75
		Padding(btn, 10, 0, 10, 0)

		local valueLbl = MakeLabel(btn, "", 12, Theme.Colors.Sub, false)
		valueLbl.Size = UDim2.new(1,0,1,0)

		local function render(v)
			if multi then
				local picked = {}
				for k,val in pairs(v) do
					if val then table.insert(picked, k) end
				end
				table.sort(picked)
				valueLbl.Text = (#picked>0) and table.concat(picked, ", ") or "(none)"
			else
				valueLbl.Text = tostring(v or "")
			end
		end

		o._sync = render
		o:_sync(o.Value)

		btn.MouseButton1Click:Connect(function()
			-- open modal list
			local modal = self.Modal
			modal.Overlay.Visible = true
			modal.BoxTitle.Text = (opts.Text or id) .. (multi and " (multi)" or "")

			-- clear list
			for _,c in ipairs(modal.List:GetChildren()) do
				if c:IsA("TextButton") then c:Destroy() end
			end

			for _,v in ipairs(values) do
				local item, ist = MakeButtonBase(modal.List)
				item.Size = UDim2.new(1,0,0,32)
				item.BackgroundTransparency = 0.10
				ist.Transparency = 0.80
				Padding(item, 10, 0, 10, 0)

				local t = MakeLabel(item, tostring(v), 13, Theme.Colors.Text, false)
				t.Size = UDim2.new(1,0,1,0)

				local function setSel(sel)
					if sel then
						ist.Transparency = 0.35
					else
						ist.Transparency = 0.80
					end
				end

				if multi then
					setSel(o.Value[tostring(v)] == true)
				else
					setSel(o.Value == v)
				end

				item.MouseButton1Click:Connect(function()
					if multi then
						local nv = {}
						for k,val in pairs(o.Value) do nv[k]=val end
						nv[tostring(v)] = not nv[tostring(v)]
						o:SetValue(nv)
						setSel(nv[tostring(v)] == true)
					else
						o:SetValue(v)
						modal.Overlay.Visible = false
					end
				end)
			end
		end)

		Library.Options[id] = o
		return o
	end

	-- KeyPicker (Toggle/Hold/Always)
	function gb:AddKeyPicker(id, opts)
		opts = opts or {}
		local mode = opts.Mode or "Toggle" -- Toggle / Hold / Always
		local default = opts.Default or "F"
		local key = Enum.KeyCode[default] or Enum.KeyCode.F

		local o = BaseOption.new(id, {Key = key, Mode = mode, Active = false})

		local row = Instance.new("Frame")
		row.BackgroundTransparency = 1
		row.Size = UDim2.new(1,0,0,52)
		row.Parent = container

		local label = MakeLabel(row, opts.Text or id, 13, Theme.Colors.Text, false)
		label.Size = UDim2.new(1,0,0,18)

		local btn, st = MakeButtonBase(row)
		btn.Size = UDim2.new(1,0,0,28)
		btn.Position = UDim2.new(0,0,0,22)
		btn.BackgroundTransparency = 0.12
		st.Transparency = 0.75
		Padding(btn, 10, 0, 10, 0)

		local valueLbl = MakeLabel(btn, "", 12, Theme.Colors.Sub, true)
		valueLbl.Size = UDim2.new(1,0,1,0)

		local waiting = false
		local function render(v)
			valueLbl.Text = string.format("%s  |  %s  |  %s",
				(v.Key and v.Key.Name or "?"),
				v.Mode,
				v.Active and "ON" or "OFF")
		end
		o._sync = render
		o:_sync(o.Value)

		btn.MouseButton1Click:Connect(function()
			if waiting then return end
			waiting = true
			valueLbl.Text = "Press a key..."
			local conn
			conn = UserInputService.InputBegan:Connect(function(inp, gp)
				if gp then return end
				if inp.KeyCode ~= Enum.KeyCode.Unknown then
					local v = o.Value
					v.Key = inp.KeyCode
					o:SetValue(v)
					waiting = false
					conn:Disconnect()
				end
			end)
		end)

		-- activation loop:
		UserInputService.InputBegan:Connect(function(inp, gp)
			if gp then return end
			local v = o.Value
			if inp.KeyCode == v.Key then
				if v.Mode == "Toggle" then
					v.Active = not v.Active
					o:SetValue(v)
				elseif v.Mode == "Hold" then
					v.Active = true
					o:SetValue(v)
				end
			end
		end)
		UserInputService.InputEnded:Connect(function(inp, gp)
			if gp then return end
			local v = o.Value
			if inp.KeyCode == v.Key and v.Mode == "Hold" then
				v.Active = false
				o:SetValue(v)
			end
		end)

		Library.Options[id] = o
		return o
	end

	-- ColorPicker simples (modal com presets + RGB sliders)
	function gb:AddColorPicker(id, opts)
		opts = opts or {}
