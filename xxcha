-- Utils
--========================
local function CanFS()
	return type(writefile)=="function" and type(readfile)=="function" and type(isfile)=="function" and type(isfolder)=="function"
end

local function EnsureFolder(path)
	if not CanFS() then return false end
	if not isfolder(path) then makefolder(path) end
	return true
end

local function JSONEncode(t) return HttpService:JSONEncode(t) end
local function JSONDecode(s) return HttpService:JSONDecode(s) end

local function Signal()
	local be = Instance.new("BindableEvent")
	local s = {}
	function s:Connect(fn) return be.Event:Connect(fn) end
	function s:Fire(...) be:Fire(...) end
	function s:Destroy() be:Destroy() end
	return s
end

local function Tween(obj, ti, props)
	local t = TweenService:Create(obj, ti, props)
	t:Play()
	return t
end

local function Round(n, r)
	r = r or 1
	return math.floor(n / r + 0.5) * r
end

local function Clamp(n, a, b)
	if n < a then return a end
	if n > b then return b end
	return n
end

local function UDim2Offset(x,y) return UDim2.new(0,x,0,y) end

