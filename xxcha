		btn.Size = UDim2.new(1,0,0,28)
		btn.Position = UDim2.new(0,0,0,22)
		btn.BackgroundTransparency = 0.12
		st.Transparency = 0.75
		Padding(btn, 10, 0, 10, 0)

		local swatch = Instance.new("Frame")
		swatch.Size = UDim2.new(0,18,0,18)
		swatch.Position = UDim2.new(1,-28,0.5,-9)
		swatch.BackgroundColor3 = o.Value
		swatch.Parent = btn
		Corner(swatch, 6)
		Stroke(swatch, Theme.Colors.Sage, 0.6)

		local valueLbl = MakeLabel(btn, "", 12, Theme.Colors.Sub, true)
		valueLbl.Size = UDim2.new(1,-40,1,0)

		local function render(c)
			swatch.BackgroundColor3 = c
			valueLbl.Text = string.format("rgb(%d,%d,%d)", math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255))
		end
		o._sync = render
		o:_sync(o.Value)

		btn.MouseButton1Click:Connect(function()
			local modal = self.Modal
			modal.Overlay.Visible = true
			modal.BoxTitle.Text = (opts.Text or id) .. " (Color)"

			for _,c in ipairs(modal.List:GetChildren()) do
				if c:IsA("TextButton") then c:Destroy() end
			end

			local presets = {
				Theme.Colors.Sage, Theme.Colors.Good, Theme.Colors.Warn, Theme.Colors.Bad,
				Color3.fromRGB(255,255,255), Color3.fromRGB(0,0,0),
				Color3.fromRGB(120,170,255), Color3.fromRGB(220,120,255),
			}

			for _,pc in ipairs(presets) do
				local item, ist = MakeButtonBase(modal.List)
				item.Size = UDim2.new(1,0,0,32)
				item.BackgroundTransparency = 0.10
				ist.Transparency = 0.80
				Padding(item, 10, 0, 10, 0)

				local box = Instance.new("Frame")
				box.Size = UDim2.new(0,16,0,16)
				box.Position = UDim2.new(0,0,0.5,-8)
				box.BackgroundColor3 = pc
				box.Parent = item
				Corner(box, 4)
				Stroke(box, Theme.Colors.Sage, 0.6)

				local t = MakeLabel(item, string.format("rgb(%d,%d,%d)", pc.R*255, pc.G*255, pc.B*255), 12, Theme.Colors.Text, true)
				t.Position = UDim2.new(0,24,0,0)
				t.Size = UDim2.new(1,-24,1,0)

				item.MouseButton1Click:Connect(function()
					o:SetValue(pc)
					modal.Overlay.Visible = false
				end)
			end
		end)

		Library.Options[id] = o
		return o
	end

	return gb
end

