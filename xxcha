	status.Size = UDim2.new(1,0,1,0)

	-- columns
	local body = Instance.new("Frame")
	body.BackgroundTransparency = 1
	body.Position = UDim2.new(0,0,0,48)
	body.Size = UDim2.new(1,0,1,-48-40)
	body.Parent = root

	-- left tabs panel
	local left = MakePanel(body)
	left.Size = UDim2.new(0, 220, 1, 0)
	left.BackgroundTransparency = 0.10
	Padding(left, 10, 10, 10, 10)

	local leftTitle = MakeLabel(left, "Navigation", 12, Theme.Colors.Sub, false)
	leftTitle.Size = UDim2.new(1,0,0,18)

	local tabsList = Instance.new("Frame")
	tabsList.BackgroundTransparency = 1
	tabsList.Size = UDim2.new(1,0,1,-18)
	tabsList.Position = UDim2.new(0,0,0,22)
	tabsList.Parent = left
	ListLayout(tabsList, Enum.FillDirection.Vertical, 8)

	-- right console panel
	local right = MakePanel(body)
	right.Size = UDim2.new(0, 240, 1, 0)
	right.Position = UDim2.new(1,-240,0,0)
	right.BackgroundTransparency = 0.10
	Padding(right, 10, 10, 10, 10)

	-- center content
	local center = Instance.new("Frame")
	center.BackgroundTransparency = 1
	center.Position = UDim2.new(0, 220+12, 0, 0)
	center.Size = UDim2.new(1, -(220+12) - (240+12), 1, 0)
	center.Parent = body

	local pages = Instance.new("Frame")
	pages.BackgroundTransparency = 1
	pages.Size = UDim2.new(1,0,1,0)
	pages.Parent = center

	-- scanline (visualzinho)
	local scan = Instance.new("Frame")
	scan.BackgroundColor3 = Theme.Colors.Sage
	scan.BackgroundTransparency = 0.92
	scan.Size = UDim2.new(1,0,0,2)
	scan.Position = UDim2.new(0,0,0,0)
	scan.Parent = root
	task.spawn(function()
		while scan.Parent do
			scan.Position = UDim2.new(0,0,0,48)
			Tween(scan, TweenInfo.new(2.8, Enum.EasingStyle.Linear), {Position = UDim2.new(0,0,1,-40)})
			task.wait(2.8)
		end
	end)

	-- modal + notify + console
	local modal = CreateModal(root)
	local notify = CreateNotifySystem(root)
	local log = CreateConsole(right)

	-- key toggle
	UserInputService.InputBegan:Connect(function(inp, gp)
		if gp then return end
		if inp.KeyCode == Library.Bind then
			gui.Enabled = not gui.Enabled
			Library.Open = gui.Enabled
		end
	end)

	-- build window
	local selfWin = setmetatable({
		Gui = gui,
		Root = root,
		Tabs = {},
		LeftTabs = tabsList,
		CenterPages = pages,
		Modal = modal,
		StatusLabel = status,
		NotifyFn = notify,
		LogFn = log,
	}, Window)

	-- wire library methods to UI
	function Library:Notify(text, dur, kind)
		selfWin.NotifyFn(text, dur, kind)
	end
	function Library:Log(text, kind)
		selfWin.LogFn(text, kind)
	end
	function Library:SetWatermark(text)
		self.WatermarkText = text
		title.Text = text
		watermark.Text = (Library.Bind.Name).." | "..text
	end
	function Library:SetStatus(text)
		status.Text = tostring(text)
	end

	-- default tab
	selfWin:AddTab("Main"):Show()

	return selfWin
end

