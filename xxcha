local function Timestamp()
	local t = os.date("*t")
	return string.format("%02d:%02d:%02d", t.hour, t.min, t.sec)
end

local function CreateNotifySystem(root)
	local holder = Instance.new("Frame")
	holder.BackgroundTransparency = 1
	holder.Size = UDim2.new(0, 320, 1, 0)
	holder.Position = UDim2.new(1, -330, 0, 10)
	holder.Parent = root
	ListLayout(holder, Enum.FillDirection.Vertical, 8)

	local function Notify(text, dur, kind)
		dur = dur or 3
		local item = MakePanel(holder)
		item.Size = UDim2.new(1, 0, 0, 52)
		item.BackgroundTransparency = 0.12

		local accent = Theme.Colors.Sage
		if kind == "warn" then accent = Theme.Colors.Warn end
		if kind == "bad" then accent = Theme.Colors.Bad end
		if kind == "good" then accent = Theme.Colors.Good end

		for _,c in ipairs(item:GetChildren()) do
			if c:IsA("UIStroke") then c.Color = accent; c.Transparency = 0.45 end
		end

		Padding(item, 12, 10, 12, 10)
		local txt = MakeLabel(item, tostring(text), 13, Theme.Colors.Text, false)
		txt.Size = UDim2.new(1, 0, 1, 0)

		item.BackgroundTransparency = 1
		for _,c in ipairs(item:GetChildren()) do
			if c:IsA("UIStroke") then c.Transparency = 1 end
		end
		Tween(item, TweenInfo.new(Theme.Anim), {BackgroundTransparency = 0.12})
		for _,c in ipairs(item:GetChildren()) do
			if c:IsA("UIStroke") then Tween(c, TweenInfo.new(Theme.Anim), {Transparency = 0.45}) end
		end

		task.delay(dur, function()
			if not item.Parent then return end
			Tween(item, TweenInfo.new(Theme.Anim), {BackgroundTransparency = 1})
			for _,c in ipairs(item:GetChildren()) do
				if c:IsA("UIStroke") then Tween(c, TweenInfo.new(Theme.Anim), {Transparency = 1}) end
			end
			task.wait(Theme.Anim + 0.05)
			if item then item:Destroy() end
		end)
	end

	return Notify
end

local function CreateConsole(panel)
	local header = Instance.new("Frame")
	header.BackgroundTransparency = 1
	header.Size = UDim2.new(1,0,0,28)
	header.Parent = panel

	local title = MakeLabel(header, "Console", 14, Theme.Colors.Text, false)
	title.Size = UDim2.new(1,0,1,0)

	local list = Instance.new("ScrollingFrame")
	list.BackgroundTransparency = 1
	list.BorderSizePixel = 0
	list.Size = UDim2.new(1,0,1,-28-36)
	list.Position = UDim2.new(0,0,0,28)
	list.ScrollBarThickness = 3
	list.Parent = panel
	Padding(list, 0, 0, 6, 0)
	local ll = ListLayout(list, Enum.FillDirection.Vertical, 6)

	local inputHolder = Instance.new("Frame")
	inputHolder.BackgroundTransparency = 1
	inputHolder.Size = UDim2.new(1,0,0,36)
	inputHolder.Position = UDim2.new(0,0,1,-36)
	inputHolder.Parent = panel

	local box, st = MakeButtonBase(inputHolder)
	box.Size = UDim2.new(1,0,1,0)
	box.BackgroundTransparency = 0.10
	st.Transparency = 0.65

	local tb = Instance.new("TextBox")
	tb.BackgroundTransparency = 1
	tb.Text = ""
	tb.PlaceholderText = "command..."
	tb.TextXAlignment = Enum.TextXAlignment.Left
	tb.TextSize = Theme.MonoTextSize
	tb.TextColor3 = Theme.Colors.Text
	tb.PlaceholderColor3 = Theme.Colors.Muted
	tb.Font = Enum.Font.Code
	tb.ClearTextOnFocus = false
	tb.Size = UDim2.new(1,-16,1,0)
	tb.Position = UDim2.new(0,8,0,0)
	tb.Parent = box

	local function pushLine(msg, kind)
		local line = Instance.new("TextLabel")
		line.BackgroundTransparency = 1
		line.TextXAlignment = Enum.TextXAlignment.Left
		line.TextYAlignment = Enum.TextYAlignment.Top
		line.RichText = true
		line.TextWrapped = true
		line.AutomaticSize = Enum.AutomaticSize.Y
		line.Size = UDim2.new(1, -8, 0, 0)
		line.Font = Enum.Font.Code
		line.TextSize = Theme.MonoTextSize
		line.TextColor3 = Theme.Colors.Sub

		local tag = "INFO"
		local col = Theme.Colors.Sage
		if kind == "warn" then tag="WARN"; col=Theme.Colors.Warn end
		if kind == "bad" then tag="ERR"; col=Theme.Colors.Bad end
		if kind == "good" then tag="OK"; col=Theme.Colors.Good end

		local rgb = string.format("rgb(%d,%d,%d)", math.floor(col.R*255), math.floor(col.G*255), math.floor(col.B*255))
		line.Text = string.format('<font color="rgb(160,160,160)">[%s]</font> <font color="%s">[%s]</font> %s',
			Timestamp(), rgb, tag, tostring(msg))

		line.Parent = list
		task.defer(function()
			list.CanvasSize = UDim2.new(0,0,0,ll.AbsoluteContentSize.Y+8)
			list.CanvasPosition = Vector2.new(0, math.max(0, ll.AbsoluteContentSize.Y))
		end)
	end

	tb.FocusLost:Connect(function(enter)
		if not enter then return end
		local cmd = tb.Text
		if cmd == "" then return end
		tb.Text = ""
		pushLine("> "..cmd, "info")
		-- você pode plugar parser aqui se quiser
	end)

	return pushLine
end

