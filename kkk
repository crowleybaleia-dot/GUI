        VerticalAlignment    = Enum.VerticalAlignment.Bottom,
        HorizontalAlignment  = Enum.HorizontalAlignment.Right,
        Padding              = UDim.new(0, 8),
        SortOrder            = Enum.SortOrder.LayoutOrder,
    }, NotifyContainer)
end

--[[
    Exibe uma notificação flutuante.

    @param opts {
        Title    : string       -- Título da notificação
        Message  : string       -- Corpo da mensagem
        Duration : number|nil   -- Duração em segundos (padrão: 4)
        Type     : string|nil   -- "success"|"warning"|"error"|"info"
    }
--]]
local function Notify(opts)
    if not NotifyContainer or not NotifyContainer.Parent then return end
    opts = opts or {}

    local typeColor = {
        success = Theme.Success,
        warning = Theme.Warning,
        error   = Theme.Error,
        info    = Theme.Sage,
    }
    local accent = typeColor[(opts.Type or "info"):lower()] or Theme.Sage
    local dur    = opts.Duration or 4

    -- Card
    local card = Util.New("Frame", {
        Name             = "Notif_" .. tostring(tick()),
        Size             = UDim2.new(1, 0, 0, 76),
        BackgroundColor3 = Theme.Surface2,
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        LayoutOrder      = -math.floor(tick()),
        ZIndex           = 201,
    }, NotifyContainer)
    Util.Corner(card, 8)
    Util.Stroke(card, Theme.Border, 1)

    -- Barra lateral de acento
    local bar = Util.New("Frame", {
        Size             = UDim2.new(0, 3, 1, 0),
        Position         = UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = accent,
        ZIndex           = 202,
    }, card)
    Util.Corner(bar, 3)

    -- Título
    Util.New("TextLabel", {
        Text             = opts.Title or "Aviso",
        Font             = Enum.Font.GothamBold,
        TextSize         = 13,
        TextColor3       = Theme.TextPrimary,
        BackgroundTransparency = 1,
        Position         = UDim2.new(0, 16, 0, 10),
        Size             = UDim2.new(1, -20, 0, 18),
        TextXAlignment   = Enum.TextXAlignment.Left,
        ZIndex           = 202,
    }, card)

    -- Mensagem
    Util.New("TextLabel", {
        Text             = opts.Message or "",
        Font             = Enum.Font.Gotham,
        TextSize         = 11,
        TextColor3       = Theme.TextSecondary,
        BackgroundTransparency = 1,
        Position         = UDim2.new(0, 16, 0, 30),
        Size             = UDim2.new(1, -20, 0, 30),
        TextXAlignment   = Enum.TextXAlignment.Left,
        TextWrapped      = true,
        ZIndex           = 202,
    }, card)

    -- Barra de progresso de tempo
    local pgBg = Util.New("Frame", {
        Position         = UDim2.new(0, 0, 1, -3),
        Size             = UDim2.new(1, 0, 0, 3),
        BackgroundColor3 = Theme.Surface3,
        ZIndex           = 202,
    }, card)
    local pg = Util.New("Frame", {
        Size             = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = accent,
        ZIndex           = 203,
    }, pgBg)
    Util.Corner(pgBg, 2)
    Util.Corner(pg, 2)

    -- Entrada suave
    Util.Tween(card, { BackgroundTransparency = 0 }, 0.3)
    -- Progresso drena
    Util.Tween(pg, { Size = UDim2.new(0, 0, 1, 0) }, dur,
        Enum.EasingStyle.Linear, Enum.EasingDirection.In)

    task.delay(dur, function()
        Util.Tween(card, { BackgroundTransparency = 1 }, 0.35)
        task.wait(0.4)
        card:Destroy()
    end)
end

