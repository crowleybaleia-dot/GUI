local Util = {}

-- Cria tween e reproduz
function Util.Tween(obj, props, t, style, dir)
    local info = TweenInfo.new(
        t     or 0.20,
        style or Enum.EasingStyle.Quint,
        dir   or Enum.EasingDirection.Out
    )
    local tw = TweenService:Create(obj, info, props)
    tw:Play()
    return tw
end

-- Cria instância com propriedades em batch
function Util.New(class, props, parent)
    local obj = Instance.new(class)
    for k, v in pairs(props) do
        obj[k] = v
    end
    if parent then obj.Parent = parent end
    return obj
end

-- Adiciona UICorner
function Util.Corner(parent, px)
    return Util.New("UICorner", { CornerRadius = UDim.new(0, px or 6) }, parent)
end

-- Adiciona UIStroke
function Util.Stroke(parent, color, thickness, transp)
    return Util.New("UIStroke", {
        Color        = color     or Theme.Border,
        Thickness    = thickness or 1,
        Transparency = transp    or 0,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    }, parent)
end

-- Adiciona UIGradient horizontal
function Util.Gradient(parent, c0, c1, rot)
    return Util.New("UIGradient", {
        Color    = ColorSequence.new(c0, c1),
        Rotation = rot or 90,
    }, parent)
end

-- Padding simétrico ou individual
function Util.Padding(parent, top, bot, left, right)
    return Util.New("UIPadding", {
        PaddingTop    = UDim.new(0, top   or 0),
        PaddingBottom = UDim.new(0, bot   or top or 0),
        PaddingLeft   = UDim.new(0, left  or top or 0),
        PaddingRight  = UDim.new(0, right or top or 0),
    }, parent)
end

-- Lista vertical
function Util.VList(parent, spacing)
    return Util.New("UIListLayout", {
        FillDirection  = Enum.FillDirection.Vertical,
        Padding        = UDim.new(0, spacing or 6),
        SortOrder      = Enum.SortOrder.LayoutOrder,
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
    }, parent)
end

-- Lista horizontal
function Util.HList(parent, spacing)
    return Util.New("UIListLayout", {
        FillDirection = Enum.FillDirection.Horizontal,
        Padding       = UDim.new(0, spacing or 6),
        SortOrder     = Enum.SortOrder.LayoutOrder,
        VerticalAlignment = Enum.VerticalAlignment.Center,
    }, parent)
end

-- Hover simples com tween de cor de fundo
function Util.Hover(btn, normalColor, hoverColor, duration)
    btn.MouseEnter:Connect(function()
        Util.Tween(btn, { BackgroundColor3 = hoverColor }, duration or 0.15)
    end)
    btn.MouseLeave:Connect(function()
        Util.Tween(btn, { BackgroundColor3 = normalColor }, duration or 0.15)
    end)
end

-- Torna um frame arrastável por um handle
function Util.Draggable(handle, frame)
    local dragging, start, origin = false, nil, nil

    handle.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            start    = inp.Position
            origin   = frame.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local d = inp.Position - start
            local vp = workspace.CurrentCamera.ViewportSize
            local nx = math.clamp(origin.X.Offset + d.X, 0, vp.X - frame.AbsoluteSize.X)
            local ny = math.clamp(origin.Y.Offset + d.Y, 0, vp.Y - frame.AbsoluteSize.Y)
            frame.Position = UDim2.new(0, nx, 0, ny)
        end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

-- PCAll seguro com log de erro
function Util.Safe(fn, ...)
    local ok, err = pcall(fn, ...)
    if not ok then
        warn("[SageHub] Erro no callback: " .. tostring(err))
    end
end

