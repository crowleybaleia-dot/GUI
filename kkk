        Name             = "Pages",
        Position         = UDim2.new(0, sidebarW, 0, 0),
        Size             = UDim2.new(1, -sidebarW, 1, 0),
        BackgroundColor3 = Theme.Background,
        ClipsDescendants = true,
        ZIndex           = 10,
    }, content)

    -- ── Estado da janela ────────────────────────────────────────
    local Window      = {}
    local tabEntries  = {}
    local activeTab   = nil
    local minimized   = false
    local fullH       = H

    -- ── Minimizar ───────────────────────────────────────────────
    local function SetMinimized(val)
        minimized = val
        if minimized then
            Util.Tween(main, { Size = UDim2.new(0, W, 0, 44) }, 0.3)
        else
            Util.Tween(main, { Size = UDim2.new(0, W, 0, fullH) }, 0.3)
        end
    end

    minBtn.MouseButton1Click:Connect(function()
        SetMinimized(not minimized)
    end)

    -- Tecla de minimizar (RightControl por padrão)
    local minKey = opts.MinimizeKey or Enum.KeyCode.RightControl
    UserInputService.InputBegan:Connect(function(inp, gpe)
        if not gpe and inp.KeyCode == minKey then
            SetMinimized(not minimized)
        end
    end)

    -- Fechar
    closeBtn.MouseButton1Click:Connect(function()
        Util.Tween(main, { BackgroundTransparency = 1 }, 0.3)
        Util.Tween(topBar, { BackgroundTransparency = 1 }, 0.3)
        task.wait(0.35)
        sg:Destroy()
    end)

    -- ── Selecionar aba ──────────────────────────────────────────
    local function SelectTab(name)
        for _, te in ipairs(tabEntries) do
            local isActive = (te.Name == name)
            -- Botão da aba
            Util.Tween(te.Btn, {
                BackgroundColor3     = isActive and Theme.Surface3 or Color3.fromRGB(0,0,0),
                BackgroundTransparency = isActive and 0 or 1,
            }, 0.15)
            Util.Tween(te.BtnText, {
                TextColor3 = isActive and Theme.TextPrimary or Theme.TextMuted,
            }, 0.15)
            Util.Tween(te.BtnIcon, {
                TextColor3 = isActive and Theme.Sage or Theme.TextMuted,
            }, 0.15)
            -- Indicador lateral
            Util.Tween(te.Indicator, {
                BackgroundTransparency = isActive and 0 or 1,
            }, 0.15)
            -- Página
            te.Page.Visible = isActive
        end
        activeTab = name
    end

    -- ══════════════════════════════════════════════════════════
    --  MÉTODO: AddTab
    -- ══════════════════════════════════════════════════════════
    --[[
        Cria uma nova aba.
        @param opts {
            Name : string      -- Nome da aba
            Icon : string|nil  -- Kanji/emoji (ex: "花")
        }
        @return Tab
    --]]
    function Window:AddTab(tabOpts)
        tabOpts = tabOpts or {}
