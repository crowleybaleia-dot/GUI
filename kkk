    NotifyContainer = Util.New("Frame", {
        Name             = "SageHub_Notifications",
        AnchorPoint      = Vector2.new(1, 1),
        Position         = UDim2.new(1, -16, 1, -16),
        Size             = UDim2.new(0, 310, 1, -32),
        BackgroundTransparency = 1,
        ZIndex           = 200,
    }, screenGui)
    Util.New("UIListLayout", {
