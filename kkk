        Size      : UDim2|nil    -- Tamanho (padrão: 560×420)
        Position  : UDim2|nil    -- Posição inicial (padrão: centro)
        MinimizeKey : Enum.KeyCode|nil  -- Tecla para minimizar (padrão: RightControl)
    }
    @return Window
--]]
function SageHub:CreateWindow(opts)
    opts = opts or {}

    -- ── ScreenGui ───────────────────────────────────────────────
    local sg = Util.New("ScreenGui", {
        Name              = "SageHub_" .. (opts.Title or "Window"),
        ResetOnSpawn      = false,
        ZIndexBehavior    = Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset    = true,
    })

    -- Tenta usar CoreGui (executors) ou PlayerGui como fallback
    local ok = pcall(function() sg.Parent = CoreGui end)
    if not ok then
        sg.Parent = LP:WaitForChild("PlayerGui")
    end

    EnsureNotifyContainer(sg)

    -- ── Tamanho e posição ───────────────────────────────────────
    local W = opts.Size and opts.Size.X.Offset or 560
    local H = opts.Size and opts.Size.Y.Offset or 440

    local vp = workspace.CurrentCamera.ViewportSize
