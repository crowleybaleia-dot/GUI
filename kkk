            selBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    dropList.Visible = true
                    dropList.Size    = UDim2.new(1, 0, 0, 0)
                    Util.Tween(dropList, { Size = UDim2.new(1, 0, 0, totalH) }, 0.20)
