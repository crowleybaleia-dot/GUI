        -- ─────────────────────────────────────────────────────────
        --  Toggle
        -- ─────────────────────────────────────────────────────────
        --[[
            @param opts {
                Name        : string
                Default     : boolean|nil
                Description : string|nil
                Callback    : function(bool)|nil
            }
            @return { SetValue, GetValue, Toggle }
        --]]
        function Tab:AddToggle(tOpts)
            tOpts = tOpts or {}
            local state = (tOpts.Default == true)
            local card  = MakeCard(40)

            Util.New("TextLabel", {
                Text           = tOpts.Name or "Toggle",
                Font           = Enum.Font.Gotham,
                TextSize       = 12,
                TextColor3     = Theme.TextPrimary,
                BackgroundTransparency = 1,
                Position       = UDim2.new(0, 12, 0, 0),
                Size           = UDim2.new(1, -70, 1, 0),
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex         = 16,
            }, card)

            -- Track
            local track = Util.New("Frame", {
                AnchorPoint      = Vector2.new(1, 0.5),
                Position         = UDim2.new(1, -12, 0.5, 0),
                Size             = UDim2.new(0, 42, 0, 22),
                BackgroundColor3 = state and Theme.Sage or Theme.Surface4,
                ZIndex           = 16,
            }, card)
            Util.Corner(track, 11)
            Util.Stroke(track, Theme.Border, 1)

            -- Knob
            local knob = Util.New("Frame", {
                AnchorPoint      = Vector2.new(0, 0.5),
                Position         = UDim2.new(0, state and 22 or 2, 0.5, 0),
                Size             = UDim2.new(0, 18, 0, 18),
                BackgroundColor3 = state and Color3.new(1,1,1) or Theme.TextMuted,
                ZIndex           = 17,
            }, track)
            Util.Corner(knob, 9)

            local function SetState(val)
                state = val
                Util.Tween(track, { BackgroundColor3 = val and Theme.Sage or Theme.Surface4 }, 0.22)
                Util.Tween(knob, {
                    Position         = UDim2.new(0, val and 22 or 2, 0.5, 0),
                    BackgroundColor3 = val and Color3.new(1,1,1) or Theme.TextMuted,
                }, 0.22)
                if tOpts.Callback then Util.Safe(tOpts.Callback, val) end
            end

            -- Clicar em qualquer parte do card ou do track alterna
            local function Toggle() SetState(not state) end
            card.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then Toggle() end
            end)

            return {
                SetValue = SetState,
                GetValue = function() return state end,
                Toggle   = Toggle,
            }
        end

        -- ─────────────────────────────────────────────────────────
        --  Slider
        -- ─────────────────────────────────────────────────────────
        --[[
            @param opts {
                Name     : string
                Min      : number
                Max      : number
                Default  : number|nil
                Decimals : number|nil  -- casas decimais (padrão 0)
                Suffix   : string|nil  -- ex: " km/h"
                Callback : function(number)|nil
            }
            @return { SetValue, GetValue }
        --]]
        function Tab:AddSlider(sOpts)
            sOpts = sOpts or {}
            local mn   = sOpts.Min      or 0
            local mx   = sOpts.Max      or 100
            local decs = sOpts.Decimals or 0
            local suf  = sOpts.Suffix   or ""
            local cur  = math.clamp(sOpts.Default or mn, mn, mx)

            local card = MakeCard(56)
            card.Size  = UDim2.new(1, 0, 0, 56)

            -- Nome
            Util.New("TextLabel", {
                Text           = sOpts.Name or "Slider",
                Font           = Enum.Font.Gotham,
                TextSize       = 12,
                TextColor3     = Theme.TextPrimary,
                BackgroundTransparency = 1,
                Position       = UDim2.new(0, 12, 0, 7),
                Size           = UDim2.new(1, -80, 0, 16),
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex         = 16,
            }, card)

            -- Valor atual
            local valLbl = Util.New("TextLabel", {
                Text           = tostring(cur) .. suf,
                Font           = Enum.Font.GothamBold,
                TextSize       = 12,
                TextColor3     = Theme.Sage,
                BackgroundTransparency = 1,
                AnchorPoint    = Vector2.new(1, 0),
                Position       = UDim2.new(1, -12, 0, 7),
                Size           = UDim2.new(0, 60, 0, 16),
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex         = 16,
            }, card)

            -- Track de fundo
            local track = Util.New("Frame", {
                Position         = UDim2.new(0, 12, 0, 36),
                Size             = UDim2.new(1, -24, 0, 6),
                BackgroundColor3 = Theme.Surface4,
                ZIndex           = 16,
            }, card)
            Util.Corner(track, 3)

            -- Preenchimento
            local fill = Util.New("Frame", {
                Size             = UDim2.new((cur - mn) / (mx - mn), 0, 1, 0),
                BackgroundColor3 = Theme.Sage,
                ZIndex           = 17,
            }, track)
            Util.Corner(fill, 3)

            -- Thumb
            local thumb = Util.New("Frame", {
                AnchorPoint      = Vector2.new(0.5, 0.5),
                Position         = UDim2.new((cur - mn) / (mx - mn), 0, 0.5, 0),
                Size             = UDim2.new(0, 14, 0, 14),
                BackgroundColor3 = Theme.SageBright,
                ZIndex           = 18,
            }, track)
            Util.Corner(thumb, 7)
            Util.Stroke(thumb, Theme.Background, 2)

            local function SetValue(v)
                v = math.clamp(v, mn, mx)
                if decs > 0 then
                    v = math.floor(v * 10^decs + 0.5) / 10^decs
                else
                    v = math.floor(v + 0.5)
                end
                cur = v
                local pct = (cur - mn) / (mx - mn)
                Util.Tween(fill,  { Size     = UDim2.new(pct, 0, 1, 0) }, 0.06)
                Util.Tween(thumb, { Position = UDim2.new(pct, 0, 0.5, 0) }, 0.06)
                valLbl.Text = tostring(cur) .. suf
                if sOpts.Callback then Util.Safe(sOpts.Callback, cur) end
            end

            -- Interação de arrastar
            local sliding = false
            track.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    sliding = true
                    local rel = (Mouse.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
                    SetValue(mn + math.clamp(rel, 0, 1) * (mx - mn))
                end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    sliding = false
                end
            end)
            RunService.Heartbeat:Connect(function()
                if sliding then
                    local rel = (Mouse.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
                    SetValue(mn + math.clamp(rel, 0, 1) * (mx - mn))
                end
            end)

            return {
                SetValue = SetValue,
                GetValue = function() return cur end,
            }
        end

