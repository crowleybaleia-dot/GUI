        -- ─────────────────────────────────────────────────────────
        --  Keybind
        -- ─────────────────────────────────────────────────────────
        --[[
            @param opts {
                Name     : string
                Default  : Enum.KeyCode|nil
                Callback : function()|nil   -- chamado quando tecla pressionada
                OnChange : function(key)|nil -- chamado quando tecla muda
            }
            @return { GetKey, SetKey }
        --]]
        function Tab:AddKeybind(kOpts)
            kOpts    = kOpts or {}
            local key    = kOpts.Default or Enum.KeyCode.Unknown
            local binding = false

            local card = MakeCard(40)

            Util.New("TextLabel", {
                Text           = kOpts.Name or "Keybind",
                Font           = Enum.Font.Gotham,
                TextSize       = 12,
                TextColor3     = Theme.TextPrimary,
                BackgroundTransparency = 1,
                Position       = UDim2.new(0, 12, 0, 0),
                Size           = UDim2.new(0.55, 0, 1, 0),
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex         = 16,
            }, card)

            local keyBtn = Util.New("TextButton", {
                Text             = key == Enum.KeyCode.Unknown and "Nenhum" or key.Name,
                Font             = Enum.Font.GothamBold,
                TextSize         = 10,
                TextColor3       = Theme.Sage,
                BackgroundColor3 = Theme.Surface3,
                AutoButtonColor  = false,
                AnchorPoint      = Vector2.new(1, 0.5),
                Position         = UDim2.new(1, -10, 0.5, 0),
                Size             = UDim2.new(0, 78, 0, 26),
                ZIndex           = 16,
            }, card)
            Util.Corner(keyBtn, 5)
            Util.Stroke(keyBtn, Theme.BorderSage, 1)

            -- Clique: entra em modo de escuta
            keyBtn.MouseButton1Click:Connect(function()
                binding         = true
                keyBtn.Text     = "..."
                keyBtn.TextColor3 = Theme.Warning
            end)

            -- Escuta global de teclas
            UserInputService.InputBegan:Connect(function(inp, gpe)
                if binding then
                    if inp.UserInputType == Enum.UserInputType.Keyboard then
                        binding          = false
                        key              = inp.KeyCode
                        keyBtn.Text      = key.Name
                        keyBtn.TextColor3 = Theme.Sage
                        if kOpts.OnChange then Util.Safe(kOpts.OnChange, key) end
                    end
                else
                    -- Executa callback quando a tecla registrada for pressionada
                    if not gpe and inp.KeyCode == key and kOpts.Callback then
                        Util.Safe(kOpts.Callback)
                    end
                end
            end)

            return {
                GetKey = function() return key end,
                SetKey = function(k)
                    key         = k
                    keyBtn.Text = k.Name
                end,
            }
        end

        -- ─────────────────────────────────────────────────────────
        --  ColorPicker  (paleta sage pré-definida)
        -- ─────────────────────────────────────────────────────────
        --[[
            @param opts {
                Name     : string
                Default  : Color3|nil
                Callback : function(Color3)|nil
            }
            @return { GetValue, SetValue }
        --]]
        function Tab:AddColorPicker(cpOpts)
            cpOpts = cpOpts or {}
            local color = cpOpts.Default or Theme.Sage

            local presets = {
                Color3.fromRGB(135,168,120),  -- sage
                Color3.fromRGB(160,195,145),  -- sage claro
                Color3.fromRGB( 92,122, 80),  -- sage escuro
                Color3.fromRGB(210, 80, 80),  -- vermelho
                Color3.fromRGB( 80,150,210),  -- azul
                Color3.fromRGB(220,180, 60),  -- dourado
                Color3.fromRGB(180,100,220),  -- roxo
                Color3.fromRGB(232,232,232),  -- branco
                Color3.fromRGB( 50, 50, 50),  -- cinza
                Color3.fromRGB(100,200,120),  -- verde claro
                Color3.fromRGB(220,130, 80),  -- laranja
                Color3.fromRGB( 80,200,200),  -- ciano
            }

            local card = MakeCard(40)
            local isOpen = false

            Util.New("TextLabel", {
                Text           = cpOpts.Name or "Color",
                Font           = Enum.Font.Gotham,
                TextSize       = 12,
                TextColor3     = Theme.TextPrimary,
                BackgroundTransparency = 1,
                Position       = UDim2.new(0, 12, 0, 0),
                Size           = UDim2.new(0.55, 0, 1, 0),
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex         = 16,
            }, card)

            -- Preview de cor
            local preview = Util.New("TextButton", {
                Text             = "",
                AnchorPoint      = Vector2.new(1, 0.5),
                Position         = UDim2.new(1, -12, 0.5, 0),
                Size             = UDim2.new(0, 30, 0, 26),
                BackgroundColor3 = color,
                AutoButtonColor  = false,
                ZIndex           = 16,
            }, card)
            Util.Corner(preview, 6)
            Util.Stroke(preview, Theme.BorderSage, 1)

            -- Paleta popup
            local dotW  = 20
            local cols  = 6
            local rows  = math.ceil(#presets / cols)
            local palH  = rows * (dotW + 4) + 8

            local palette = Util.New("Frame", {
                Position         = UDim2.new(0, 0, 1, 4),
                Size             = UDim2.new(1, 0, 0, 0),
                BackgroundColor3 = Theme.Surface2,
                ClipsDescendants = true,
                Visible          = false,
                ZIndex           = 50,
            }, card)
            Util.Corner(palette, 6)
            Util.Stroke(palette, Theme.BorderSage, 1)

            local grid = Util.New("UIGridLayout", {
                CellSize    = UDim2.new(0, dotW, 0, dotW),
                CellPadding = UDim2.new(0, 4, 0, 4),
                SortOrder   = Enum.SortOrder.LayoutOrder,
            }, palette)
            Util.Padding(palette, 4)

            for i, pc in ipairs(presets) do
                local dot = Util.New("TextButton", {
                    Text             = "",
                    BackgroundColor3 = pc,
                    AutoButtonColor  = false,
                    LayoutOrder      = i,
                    ZIndex           = 51,
                }, palette)
                Util.Corner(dot, 5)
                dot.MouseButton1Click:Connect(function()
                    color           = pc
                    preview.BackgroundColor3 = pc
                    isOpen          = false
                    Util.Tween(palette, { Size = UDim2.new(1, 0, 0, 0) }, 0.18)
                    task.delay(0.2, function() palette.Visible = false end)
                    if cpOpts.Callback then Util.Safe(cpOpts.Callback, pc) end
                end)
            end

            preview.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    palette.Visible = true
                    palette.Size    = UDim2.new(1, 0, 0, 0)
                    Util.Tween(palette, { Size = UDim2.new(1, 0, 0, palH) }, 0.20)
                else
                    Util.Tween(palette, { Size = UDim2.new(1, 0, 0, 0) }, 0.18)
                    task.delay(0.2, function() palette.Visible = false end)
                end
            end)

            return {
                GetValue = function() return color end,
                SetValue = function(c)
                    color                    = c
                    preview.BackgroundColor3 = c
                end,
            }
        end

        -- ─────────────────────────────────────────────────────────
        --  Paragraph (bloco de texto longo)
        -- ─────────────────────────────────────────────────────────
        --[[
            @param opts {
                Title : string
                Body  : string
            }
        --]]
        function Tab:AddParagraph(pOpts)
            pOpts = pOpts or {}

            local textLines = math.max(1, math.ceil(#(pOpts.Body or "") / 48))
            local h = 24 + textLines * 14 + 16
            local card = MakeCard(h)

            if pOpts.Title and pOpts.Title ~= "" then
                Util.New("TextLabel", {
                    Text           = pOpts.Title,
                    Font           = Enum.Font.GothamBold,
                    TextSize       = 11,
                    TextColor3     = Theme.Sage,
                    BackgroundTransparency = 1,
                    Position       = UDim2.new(0, 12, 0, 6),
                    Size           = UDim2.new(1, -20, 0, 16),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex         = 16,
                }, card)
            end

            Util.New("TextLabel", {
                Text           = pOpts.Body or "",
                Font           = Enum.Font.Gotham,
                TextSize       = 10,
                TextColor3     = Theme.TextSecondary,
                BackgroundTransparency = 1,
                Position       = UDim2.new(0, 12, 0, 24),
                Size           = UDim2.new(1, -20, 1, -28),
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped    = true,
                ZIndex         = 16,
            }, card)
        end

        -- ─────────────────────────────────────────────────────────
        --  Retorno da aba
        -- ─────────────────────────────────────────────────────────
        return Tab
    end -- AddTab

    -- ── Expõe Notify pela janela também ─────────────────────────
    function Window:Notify(nOpts)
        Notify(nOpts)
    end

    return Window
end -- CreateWindow

-- ═══════════════════════════════════════════════════════════════
--  RETORNO FINAL DA BIBLIOTECA
-- ═══════════════════════════════════════════════════════════════
