-- ═══════════════════════════════════════════════════
-- HELPERS
-- ═══════════════════════════════════════════════════
local function tw(o, p, t, s, d)
    TweenS:Create(o, TweenInfo.new(t or .18, s or Enum.EasingStyle.Quart, d or Enum.EasingDirection.Out), p):Play()
end

local function N(cls, props, kids)
    local o = Instance.new(cls)
    for k,v in pairs(props or {}) do o[k]=v end
    for _,c in ipairs(kids  or {}) do c.Parent=o end
    return o
end

local function Rnd(r)  return N("UICorner",  {CornerRadius = UDim.new(0, r or 8)}) end
local function Bdr(c,t,tr) return N("UIStroke",{Color=c or C.BORD_CARD, Thickness=t or 1, Transparency=tr or 0}) end
local function Pad(t,b,l,r) return N("UIPadding",{PaddingTop=UDim.new(0,t or 0),PaddingBottom=UDim.new(0,b or 0),PaddingLeft=UDim.new(0,l or 0),PaddingRight=UDim.new(0,r or 0)}) end
local function VList(gap) return N("UIListLayout",{FillDirection=Enum.FillDirection.Vertical,Padding=UDim.new(0,gap or 4),SortOrder=Enum.SortOrder.LayoutOrder,HorizontalAlignment=Enum.HorizontalAlignment.Left,VerticalAlignment=Enum.VerticalAlignment.Top}) end
local function HList(gap) return N("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,Padding=UDim.new(0,gap or 4),SortOrder=Enum.SortOrder.LayoutOrder,HorizontalAlignment=Enum.HorizontalAlignment.Left,VerticalAlignment=Enum.VerticalAlignment.Center}) end

-- Neon glow image
local function NGlow(parent, col, sz)
    return N("ImageLabel",{
        Size=UDim2.new(1,sz or 40,1,sz or 40),
        Position=UDim2.fromOffset(-(sz or 40)/2,-(sz or 40)/2),
        BackgroundTransparency=1,
        Image="rbxassetid://6014261993",
        ImageColor3=col or C.PINK_HOT,
        ImageTransparency=0.65,
        ScaleType=Enum.ScaleType.Slice,
        SliceCenter=Rect.new(49,49,450,450),
        ZIndex=(parent.ZIndex or 1)-1,
        Parent=parent,
    })
end

-- Horizontal gradient line
local function GLine(parent, col1, col2, h, yPos)
    local f=N("Frame",{
        Size=UDim2.new(1,0,0,h or 1),
        Position=yPos or UDim2.new(0,0,1,-1),
        BackgroundColor3=col1 or C.PINK_HOT,
        BackgroundTransparency=0,
        ZIndex=(parent.ZIndex or 1)+1,
        Parent=parent,
    })
    N("UIGradient",{
        Color=ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.new(0,0,0)),
            ColorSequenceKeypoint.new(0.2, col1 or C.PINK_HOT),
            ColorSequenceKeypoint.new(0.8, col2 or C.PURP_LITE),
            ColorSequenceKeypoint.new(1, Color3.new(0,0,0)),
        }),
        Parent=f,
    })
    return f
end

-- Drag
local function Drag(frame, handle)
    handle = handle or frame
    local d,di,sm,sp
    handle.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            d=true di=nil sm=i.Position sp=frame.Position
            i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then d=false end end)
        end
    end)
    handle.InputChanged:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseMovement then di=i end end)
    InputS.InputChanged:Connect(function(i)
        if i==di and d then
            local delta=i.Position-sm
            frame.Position=UDim2.new(sp.X.Scale,sp.X.Offset+delta.X,sp.Y.Scale,sp.Y.Offset+delta.Y)
        end
    end)
end

