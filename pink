        -- Activate logic
        local function Activate()
            for _,t in pairs(WinObj._tabs) do
                t.page.Visible=false
                tw(t.lbl,{TextColor3=C.TxtMuted},0.15)
                tw(t.btn,{BackgroundTransparency=1},0.15)
                tw(t.pill,{BackgroundTransparency=1},0.15)
                tw(t.dot,{BackgroundTransparency=1},0.15)
            end
            page.Visible=true
            tw(lbl,{TextColor3=C.TxtMain},0.15)
            tw(btn,{BackgroundColor3=C.Sakura1,BackgroundTransparency=0.35},0.18)
            tw(pill,{BackgroundTransparency=0},0.18)
            tw(dot,{BackgroundTransparency=0},0.18)
            WinObj._active=name
        end

        btn.MouseButton1Click:Connect(function()
            for i=1,4 do task.delay(i*0.06,function() SpawnPetal(btn,math.random(8,SW-8),17) end) end
            Activate()
        end)
        btn.MouseEnter:Connect(function()
            if WinObj._active~=name then
                tw(btn,{BackgroundColor3=C.Glass3,BackgroundTransparency=0.5},0.12)
                tw(lbl,{TextColor3=C.TxtSub},0.12)
            end
        end)
        btn.MouseLeave:Connect(function()
            if WinObj._active~=name then
                tw(btn,{BackgroundTransparency=1},0.12)
                tw(lbl,{TextColor3=C.TxtMuted},0.12)
            end
        end)

        table.insert(WinObj._tabs,{btn=btn,lbl=lbl,page=page,pill=pill,dot=dot,name=name})
        if #WinObj._tabs==1 then Activate() end

        -- ═══════════════════════════════════════════════════
        --  TAB OBJECT  (element builders)
