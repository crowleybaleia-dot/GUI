    MakeCtrlBtn("—", Theme.BG_PANEL, function()
        isVisible = false
        Util.Tween(Window, { Position = UDim2.new(0.5, -Sizes.WINDOW_W/2, 1, 20) }, 0.3, Enum.EasingStyle.Back)
        Util.Tween(blur, { Size = 0 }, 0.3)
