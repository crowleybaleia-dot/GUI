        -- ────────────────────────────────────────────────
        -- AddBind (key bind)
        -- ────────────────────────────────────────────────
        function TabObj:AddBind(opts)
            opts = opts or {}
            local name    = opts.Name or "Keybind"
            local default = opts.Default or Enum.KeyCode.Unknown
            local cb      = opts.Callback or function() end
            local flag    = opts.Flag

            local current = default
            local listening = false

            local row = MakeRow()

            Util.Create("TextLabel", {
                Size = UDim2.new(0.55, 0, 1, 0),
                Position = UDim2.fromOffset(12, 0),
                BackgroundTransparency = 1,
                Text = name,
                TextColor3 = Theme.TEXT_SECONDARY,
                Font = Font.SEMI,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = row,
            })

            local bindBtn = Util.Create("TextButton", {
                Size = UDim2.fromOffset(68, 20),
                Position = UDim2.new(1, -80, 0.5, -10),
                BackgroundColor3 = Theme.BIND_BG,
                AutoButtonColor = false,
                Font = Font.SEMI,
                TextSize = 11,
                TextColor3 = Theme.BIND_TEXT,
                Parent = row,
            })
            Util.MakeCorner(3).Parent = bindBtn
            local bindStroke = Util.MakeStroke(Theme.BIND_BORDER, 1)
            bindStroke.Parent = bindBtn

            local function FormatKey(k)
                if k == Enum.KeyCode.Unknown then return "No Bind" end
                return tostring(k):match("Enum%.KeyCode%.(.+)") or tostring(k)
            end
            bindBtn.Text = FormatKey(current)

            bindBtn.MouseButton1Click:Connect(function()
                listening = true
                bindBtn.Text = "..."
                Util.Tween(bindStroke, { Color = Theme.PINK_500 }, 0.12)
            end)

            UserInputService.InputBegan:Connect(function(input, gpe)
                if not listening then return end
                if input.UserInputType == Enum.UserInputType.Keyboard then
                    listening = false
                    current = input.KeyCode
                    bindBtn.Text = FormatKey(current)
                    Util.Tween(bindStroke, { Color = Theme.BIND_BORDER }, 0.12)
                    if flag then PinkUI.Flags[flag] = current end
                    cb(current)
                end
            end)

            return {
                Get = function() return current end,
                Set = function(_, k) current = k bindBtn.Text = FormatKey(k) end,
            }
        end

