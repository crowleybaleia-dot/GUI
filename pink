            TextSize = 11,
            AutoButtonColor = false,
            Parent = CtrlFrame,
        })
        Util.MakeCorner(999).Parent = btn
        btn.MouseButton1Click:Connect(onClick or function() end)
        btn.MouseEnter:Connect(function() Util.Tween(btn, { BackgroundColor3 = Theme.BG_HOVER }, 0.12) end)
        btn.MouseLeave:Connect(function() Util.Tween(btn, { BackgroundColor3 = color or Theme.BG_PANEL }, 0.12) end)
        return btn
    end

