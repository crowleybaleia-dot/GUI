        -- ────────────────────────────────────────────────
        --  Bind
        -- ────────────────────────────────────────────────
        function TabObj:Bind(o)
            o=o or {}
            local cur=o.Default or Enum.KeyCode.Unknown
            local cb=o.Callback or function()end
            local listening=false

            local r=Row(36)
            New("TextLabel",{
                Size=UDim2.new(0.55,0,1,0),Position=UDim2.fromOffset(12,0),
                BackgroundTransparency=1,Text=o.Name or "Bind",
                TextColor3=C.TxtSub,Font=Enum.Font.GothamSemibold,TextSize=13,
                TextXAlignment=Enum.TextXAlignment.Left,ZIndex=6,Parent=r,
            })

            local chip=New("TextButton",{
                Size=UDim2.fromOffset(70,20),Position=UDim2.new(1,-82,0.5,-10),
                BackgroundColor3=C.Glass3,BackgroundTransparency=0.2,
                Font=Enum.Font.GothamSemibold,TextSize=11,TextColor3=C.TxtSub,
                AutoButtonColor=false,ZIndex=6,Parent=r,
            })
            Corner(R.Small).Parent=chip
            local chipStroke=Stroke(C.Gold3,1,0.5); chipStroke.Parent=chip

            local function KeyName(k)
                if k==Enum.KeyCode.Unknown then return "No Bind" end
                return tostring(k):match("Enum%.KeyCode%.(.+)") or "?"
            end
            chip.Text=KeyName(cur)

            chip.MouseButton1Click:Connect(function()
                listening=true chip.Text="..."
                tw(chipStroke,{Color=C.Sakura3,Transparency=0.1},0.12)
                tw(chip,{BackgroundColor3=C.Sakura1},0.12)
            end)
            Input.InputBegan:Connect(function(i,gpe)
                if not listening or gpe then return end
                if i.UserInputType==Enum.UserInputType.Keyboard then
                    listening=false cur=i.KeyCode chip.Text=KeyName(cur)
                    tw(chipStroke,{Color=C.Gold3,Transparency=0.5},0.12)
                    tw(chip,{BackgroundColor3=C.Glass3},0.12)
                    if o.Flag then SakuraUI.Flags[o.Flag]=cur end
                    cb(cur)
                end
            end)
            r.MouseEnter:Connect(function() tw(r,{BackgroundColor3=C.Sakura1,BackgroundTransparency=0.55},0.12) end)
            r.MouseLeave:Connect(function() tw(r,{BackgroundColor3=C.Glass2,BackgroundTransparency=T.GlassDeep},0.12) end)
            return {Get=function()return cur end,Set=function(_,k)cur=k chip.Text=KeyName(k) end}
        end

