        local col=({ok=C.CON_OK, sys=C.CON_SYS, err=C.CON_ERR})[logType] or C.CON_TXT
        local prefix=({ok="[OK]",sys="[SYS]",err="[ERR]"})[logType] or "   "

        local line=N("TextLabel",{
            Size=UDim2.new(1,0,0,14),
            BackgroundTransparency=1,
            RichText=true,
            Text=string.format('<font color="#%s">%s</font> <font color="#%s">%s</font>',
                ("%02X%02X%02X"):format(col.R*255,col.G*255,col.B*255), prefix,
                ("%02X%02X%02X"):format(C.CON_TXT.R*255,C.CON_TXT.G*255,C.CON_TXT.B*255), msg),
            Font=Enum.Font.Code, TextSize=10,
            TextXAlignment=Enum.TextXAlignment.Left,
            TextTruncate=Enum.TextTruncate.AtEnd,
            ZIndex=7,Parent=conScroll,
        })
        -- auto-scroll
        task.delay(0.05,function()
            if conScroll.CanvasSize.Y.Offset > conScroll.AbsoluteSize.Y then
                conScroll.CanvasPosition=Vector2.new(0,conScroll.AbsoluteCanvasSize.Y)
            end
        end)
        return line
    end

    -- Default logs
    WObj:Log("Memory patched 🔥")
    WObj:Log("ESP module ready ✦")
    WObj:Log("Waiting for server sync..","sys")
    task.delay(1.2,function() WObj:Log("Synced! Ready to slay 🩷") end)

