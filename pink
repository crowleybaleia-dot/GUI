        -- ────────────────────────────────────────────────
        --  Toggle
        -- ────────────────────────────────────────────────
        function TabObj:Toggle(o)
            o=o or {}
            local state=o.Default or false
            local cb=o.Callback or function()end
            local TW,TH2=36,20

            local r=Row(40)

            -- Name label
            New("TextLabel",{
                Size=UDim2.new(1,-(TW+20+60),1,0),Position=UDim2.fromOffset(12,0),
                BackgroundTransparency=1,Text=o.Name or "Toggle",
                TextColor3=C.TxtSub,Font=Enum.Font.GothamSemibold,TextSize=13,
                TextXAlignment=Enum.TextXAlignment.Left,ZIndex=6,Parent=r,
            })

            -- Bind chip (glass style)
            local bindChip=New("TextButton",{
                Size=UDim2.fromOffset(54,18),
                Position=UDim2.new(1,-(TW+14+54+6),0.5,-9),
                BackgroundColor3=C.Glass3,BackgroundTransparency=0.3,
                Text="No Bind",TextColor3=C.TxtMuted,Font=Enum.Font.Gotham,TextSize=10,
                AutoButtonColor=false,ZIndex=6,Parent=r,
            })
            Corner(R.Small).Parent=bindChip
            Stroke(C.Gold3,1,0.6).Parent=bindChip

            -- Toggle track
            local track=New("Frame",{
                Size=UDim2.fromOffset(TW,TH2),
                Position=UDim2.new(1,-(TW+10),0.5,-TH2/2),
                BackgroundColor3=state and C.TglOn or C.TglOff,
                BackgroundTransparency=0.15,
                ZIndex=6,Parent=r,
            })
            Corner(R.Pill).Parent=track
            local trkStroke=Stroke(state and C.Sakura4 or C.Glass4,1,state and 0.2 or 0.5)
            trkStroke.Parent=track
            Glow(track,C.Sakura3,16)

            -- Thumb
            local thumb=New("Frame",{
                Size=UDim2.fromOffset(TH2-6,TH2-6),
                Position=state and UDim2.fromOffset(TW-TH2+3,3) or UDim2.fromOffset(3,3),
                BackgroundColor3=state and C.Gold2 or C.Glass0,
                ZIndex=7,Parent=track,
            })
            Corner(R.Pill).Parent=thumb
            -- Thumb inner dot
            New("Frame",{
                Size=UDim2.fromOffset(4,4),AnchorPoint=Vector2.new(0.5,0.5),
                Position=UDim2.new(0.5,0,0.5,0),
                BackgroundColor3=state and C.Gold4 or C.Sakura3,
                BackgroundTransparency=state and 0 or 0.5,
                ZIndex=8,Parent=thumb,
            })

            local function Set(v,anim)
                state=v
                local onOff=state
                if anim then
                    tw(track,{BackgroundColor3=onOff and C.TglOn or C.TglOff,BackgroundTransparency=0.1},0.2)
                    tw(trkStroke,{Color=onOff and C.Sakura4 or C.Glass4,Transparency=onOff and 0.2 or 0.5},0.2)
                    tw(thumb,{Position=onOff and UDim2.fromOffset(TW-TH2+3,3) or UDim2.fromOffset(3,3),BackgroundColor3=onOff and C.Gold2 or C.Glass0},0.2,Enum.EasingStyle.Back)
                    if onOff then for i=1,5 do task.delay(i*0.05,function() SpawnPetal(r,math.random(TW+10,TW+30)+r.AbsoluteSize.X-TW-30,18) end) end end
                else
                    track.BackgroundColor3=onOff and C.TglOn or C.TglOff
                    thumb.Position=onOff and UDim2.fromOffset(TW-TH2+3,3) or UDim2.fromOffset(3,3)
                end
                if o.Flag then SakuraUI.Flags[o.Flag]=state end
                cb(state)
            end

            local hb=New("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=8,Parent=r})
            hb.MouseButton1Click:Connect(function() Set(not state,true) end)
            r.MouseEnter:Connect(function() tw(r,{BackgroundColor3=C.Sakura1,BackgroundTransparency=0.55},0.12) end)
            r.MouseLeave:Connect(function() tw(r,{BackgroundColor3=C.Glass2,BackgroundTransparency=T.GlassDeep},0.12) end)

            if state then Set(true,false) end
            return {Set=function(_,v)Set(v,true)end,Get=function()return state end}
        end

        -- ────────────────────────────────────────────────
        --  Slider
        -- ────────────────────────────────────────────────
        function TabObj:Slider(o)
            o=o or {}
            local min,max,dp2 = o.Min or 0, o.Max or 100, o.DecimalPlaces or 0
            local val = math.clamp(o.Default or (min+max)/2, min, max)
            local cb  = o.Callback or function()end
            local suffix = o.Suffix or ""
            local dragging = false

            local r=Row(50)

            -- Top row
            local topF=New("Frame",{Size=UDim2.new(1,-20,0,20),Position=UDim2.fromOffset(10,7),BackgroundTransparency=1,ZIndex=6,Parent=r})
            -- Icon + Name
            New("TextLabel",{Size=UDim2.new(0.65,0,1,0),BackgroundTransparency=1,
                Text="✦  "..(o.Name or "Slider"),TextColor3=C.TxtSub,Font=Enum.Font.GothamSemibold,TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Left,ZIndex=7,Parent=topF})
            local valLbl=New("TextLabel",{Size=UDim2.new(0.35,0,1,0),Position=UDim2.new(0.65,0,0,0),
                BackgroundTransparency=1,RichText=true,
                Font=Enum.Font.GothamBold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=7,Parent=topF})

            local function Fmt(v)
                local s=string.format("%."..dp2.."f",v)
                valLbl.Text=string.format('<font color="#F5C842">%s</font><font color="#B89AAE">/%s%s</font>',s,max,suffix)
            end Fmt(val)

            -- Track bg
            local trkBg=New("Frame",{
                Size=UDim2.new(1,-20,0,5),Position=UDim2.new(0,10,0,34),
                BackgroundColor3=C.Glass3,BackgroundTransparency=0.2,
                ZIndex=6,Parent=r,
            })
            Corner(R.Pill).Parent=trkBg

            -- Fill (gradient gold→sakura)
            local fill=New("Frame",{
                Size=UDim2.new((val-min)/(max-min),0,1,0),
                BackgroundColor3=C.Sakura3,ZIndex=7,Parent=trkBg,
            })
            Corner(R.Pill).Parent=fill
            New("UIGradient",{Color=ColorSequence.new({ColorSequenceKeypoint.new(0,C.Gold3),ColorSequenceKeypoint.new(1,C.Sakura3)}),Parent=fill})

            -- Thumb (diamond shape via rotation)
            local thumb=New("Frame",{
                Size=UDim2.fromOffset(13,13),AnchorPoint=Vector2.new(0.5,0.5),
                Position=UDim2.new((val-min)/(max-min),0,0.5,0),
                BackgroundColor3=C.Glass0,Rotation=45,ZIndex=8,Parent=trkBg,
            })
            Corner(2).Parent=thumb
            Glow(thumb,C.Gold3,14)

            -- Gold inner dot on thumb
            New("Frame",{Size=UDim2.fromOffset(5,5),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),BackgroundColor3=C.Gold3,Rotation=-45,ZIndex=9,Parent=thumb})

            local function Update(v)
                v=math.clamp(v,min,max)
                local mult=10^dp2; v=math.floor(v*mult+0.5)/mult
                val=v
                local p=(v-min)/(max-min)
                tw(fill,{Size=UDim2.new(p,0,1,0)},0.05)
                tw(thumb,{Position=UDim2.new(p,0,0.5,0)},0.05)
                Fmt(v)
                if o.Flag then SakuraUI.Flags[o.Flag]=v end
                cb(v)
            end

            local hit=New("TextButton",{Size=UDim2.new(1,0,0,22),Position=UDim2.new(0,0,0,26),BackgroundTransparency=1,Text="",ZIndex=9,Parent=r})
            hit.MouseButton1Down:Connect(function()
                dragging=true
                tw(thumb,{Size=UDim2.fromOffset(15,15)},0.1)
            end)
            Input.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then
                    dragging=false
                    tw(thumb,{Size=UDim2.fromOffset(13,13)},0.1)
                end
            end)
            Run.Heartbeat:Connect(function()
                if dragging then
                    local mx=Input:GetMouseLocation().X
                    local p=math.clamp((mx-trkBg.AbsolutePosition.X)/trkBg.AbsoluteSize.X,0,1)
                    Update(min+p*(max-min))
                end
            end)
            r.MouseEnter:Connect(function() tw(r,{BackgroundColor3=C.Sakura1,BackgroundTransparency=0.55},0.12) end)
            r.MouseLeave:Connect(function() tw(r,{BackgroundColor3=C.Glass2,BackgroundTransparency=T.GlassDeep},0.12) end)

            return {Set=function(_,v)Update(v)end,Get=function()return val end}
        end

