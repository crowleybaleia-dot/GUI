            })
            Corner(R.Elem).Parent=ddPanel Stroke(C.Sakura3,1,0.35).Parent=ddPanel
            Sheen(ddPanel,12) Pad(4,4,4,4).Parent=ddPanel
            List(Enum.FillDirection.Vertical,2).Parent=ddPanel

            for _,opt in ipairs(opts) do
                local ob=New("TextButton",{
                    Size=UDim2.new(1,0,0,26),
                    BackgroundColor3=opt==sel and C.Sakura1 or C.Glass2,
                    BackgroundTransparency=opt==sel and 0.3 or 0.5,
                    Text=opt,TextColor3=opt==sel and C.Sakura4 or C.TxtSub,
                    Font=Enum.Font.GothamSemibold,TextSize=12,
                    AutoButtonColor=false,ZIndex=21,Parent=ddPanel,
                })
                Corner(R.Small).Parent=ob
                ob.MouseButton1Click:Connect(function()
                    sel=opt selLbl.Text=opt open=false
                    tw(arrow,{Rotation=0},0.15) ddPanel.Visible=false
                    SpawnPetal(r,math.random(20,r.AbsoluteSize.X-20),18)
                    if o.Flag then SakuraUI.Flags[o.Flag]=opt end cb(opt)
                end)
                ob.MouseEnter:Connect(function() tw(ob,{BackgroundColor3=C.Sakura1,BackgroundTransparency=0.3,TextColor3=C.Sakura4},0.1) end)
                ob.MouseLeave:Connect(function() tw(ob,{BackgroundColor3=opt==sel and C.Sakura1 or C.Glass2,BackgroundTransparency=opt==sel and 0.3 or 0.5,TextColor3=opt==sel and C.Sakura4 or C.TxtSub},0.1) end)
            end

            local hb=New("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=12,Parent=r})
            hb.MouseButton1Click:Connect(function()
                open=not open ddPanel.Visible=open
                tw(arrow,{Rotation=open and 180 or 0},0.18)
            end)
            r.MouseEnter:Connect(function() tw(r,{BackgroundColor3=C.Sakura1,BackgroundTransparency=0.55},0.12) end)
            r.MouseLeave:Connect(function() tw(r,{BackgroundColor3=C.Glass2,BackgroundTransparency=T.GlassDeep},0.12) end)
            return {Get=function()return sel end,Set=function(_,v)sel=v selLbl.Text=v if o.Flag then SakuraUI.Flags[o.Flag]=v end cb(v) end}
        end

        -- ────────────────────────────────────────────────
        --  Color Picker
        -- ────────────────────────────────────────────────
        function TabObj:Color(o)
            o=o or {}
            local cur=o.Default or C.Sakura3
            local cb=o.Callback or function()end
            local open=false

            local wrap=New("Frame",{Size=UDim2.new(1,0,0,36),BackgroundTransparency=1,ClipsDescendants=false,ZIndex=8,Parent=page})
            local r=New("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=C.Glass2,BackgroundTransparency=T.GlassDeep,ZIndex=8,Parent=wrap})
            Corner(R.Elem).Parent=r Stroke(C.Glass4,1,T.GlassBdr).Parent=r Sheen(r,12)

            New("TextLabel",{
                Size=UDim2.new(0.65,0,1,0),Position=UDim2.fromOffset(12,0),
                BackgroundTransparency=1,Text=o.Name or "Color",
                TextColor3=C.TxtSub,Font=Enum.Font.GothamSemibold,TextSize=13,
                TextXAlignment=Enum.TextXAlignment.Left,ZIndex=9,Parent=r,
            })

            -- Swatch
            local swatch=New("Frame",{
                Size=UDim2.fromOffset(26,20),Position=UDim2.new(1,-38,0.5,-10),
                BackgroundColor3=cur,ZIndex=9,Parent=r,
            })
            Corner(R.Small).Parent=swatch
            Stroke(C.Glass4,1,0.3).Parent=swatch
            Glow(swatch,cur,12)

            -- Picker panel
            local pp=New("Frame",{
                Size=UDim2.new(1,0,0,96),Position=UDim2.new(0,0,1,3),
                BackgroundColor3=C.Glass1,BackgroundTransparency=0.1,
                ZIndex=16,Visible=false,Parent=wrap,
            })
            Corner(R.Elem).Parent=pp Stroke(C.Sakura3,1,0.4).Parent=pp Sheen(pp,14)
            Pad(8,8,10,10).Parent=pp List(Enum.FillDirection.Vertical,6).Parent=pp

            local h2,s2,v2=Color3.toHSV(cur)
            local function Rebuild()
                cur=Color3.fromHSV(h2,s2,v2) swatch.BackgroundColor3=cur
                if o.Flag then SakuraUI.Flags[o.Flag]=cur end cb(cur)
            end

            local function MiniSlide(lbl3,init,colA,colB,onChange)
                local f=New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,Parent=pp})
                New("TextLabel",{Size=UDim2.fromOffset(10,18),BackgroundTransparency=1,Text=lbl3,TextColor3=C.Gold4,Font=Enum.Font.GothamBold,TextSize=9,ZIndex=17,Parent=f})
                local tr=New("Frame",{Size=UDim2.new(1,-16,0,4),Position=UDim2.fromOffset(14,7),BackgroundColor3=C.Glass3,ZIndex=16,Parent=f})
                Corner(R.Pill).Parent=tr
                New("UIGradient",{Color=ColorSequence.new({ColorSequenceKeypoint.new(0,colA),ColorSequenceKeypoint.new(1,colB)}),Parent=tr})
                local fi=New("Frame",{Size=UDim2.new(init,0,1,0),BackgroundColor3=colB,ZIndex=17,Parent=tr})
                Corner(R.Pill).Parent=fi
                local tm=New("TextButton",{Size=UDim2.fromOffset(11,11),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(init,0,0.5,0),BackgroundColor3=C.Glass0,Text="",ZIndex=18,Parent=tr})
                Corner(R.Pill).Parent=tm
                local d=false
                tm.MouseButton1Down:Connect(function()d=true end)
                Input.InputEnded:Connect(function(i)if i.UserInputType==Enum.UserInputType.MouseButton1 then d=false end end)
                Run.Heartbeat:Connect(function()
                    if d then
                        local p=math.clamp((Input:GetMouseLocation().X-tr.AbsolutePosition.X)/tr.AbsoluteSize.X,0,1)
                        fi.Size=UDim2.new(p,0,1,0) tm.Position=UDim2.new(p,0,0.5,0)
                        onChange(p) Rebuild()
                    end
                end)
            end
            MiniSlide("H",h2,Color3.fromHex("#FF0000"),Color3.fromHex("#FF00FF"),function(p)h2=p end)
            MiniSlide("S",s2,Color3.new(1,1,1),C.Sakura3,function(p)s2=p end)
            MiniSlide("V",v2,Color3.new(0,0,0),C.Gold2,function(p)v2=p end)

            local hb=New("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=10,Parent=r})
            hb.MouseButton1Click:Connect(function() open=not open pp.Visible=open end)
            r.MouseEnter:Connect(function() tw(r,{BackgroundColor3=C.Sakura1,BackgroundTransparency=0.55},0.12) end)
            r.MouseLeave:Connect(function() tw(r,{BackgroundColor3=C.Glass2,BackgroundTransparency=T.GlassDeep},0.12) end)
            return {Get=function()return cur end,Set=function(_,c)cur=c swatch.BackgroundColor3=c h2,s2,v2=Color3.toHSV(c) end}
        end

        -- ────────────────────────────────────────────────
        --  Notify shortcut
        -- ────────────────────────────────────────────────
        function TabObj:Notify(o) Notify(o) end

        return TabObj
    end -- :Tab

    function WinObj:Notify(o) Notify(o) end
    function WinObj:Destroy() blur:Destroy() sg:Destroy() end

    return WinObj
end -- :Window

return SakuraUI
