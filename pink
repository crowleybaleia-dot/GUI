    function WObj:Tab(cfg2)
        cfg2=cfg2 or {}
        local tname=cfg2.Name or "TAB"
        local ticon=cfg2.Icon or ""
        local badge=cfg2.Badge  -- number or nil

        -- Sidebar nav button
        local navBtn=N("TextButton",{
            Size=UDim2.new(1,0,0,36),
            BackgroundColor3=C.BG_SIDEBAR,
            BackgroundTransparency=1,
            Text="",AutoButtonColor=false,
            ZIndex=6,Parent=navScroll,
        })
        Rnd(8).Parent=navBtn

        -- Active indicator bar (left)
        local indicator=N("Frame",{
            Size=UDim2.new(0,3,0.6,0),
            Position=UDim2.new(0,0,0.2,0),
            BackgroundColor3=C.PINK_HOT,
            BackgroundTransparency=1,
            ZIndex=7,Parent=navBtn,
        })
        Rnd(99).Parent=indicator
        NGlow(indicator,C.PINK_HOT,10)

        -- Icon
        if ticon~="" then
            N("TextLabel",{
                Size=UDim2.fromOffset(20,36),Position=UDim2.fromOffset(14,0),
                BackgroundTransparency=1,Text=ticon,TextSize=14,
                Font=Enum.Font.GothamBold,ZIndex=7,Parent=navBtn,
            })
        end

        local lbl=N("TextLabel",{
            Size=UDim2.new(1,-(badge and 50 or 30),1,0),
            Position=UDim2.fromOffset(ticon~="" and 36 or 14,0),
            BackgroundTransparency=1,Text=tname,
            TextColor3=C.TXT_MUTED,Font=Enum.Font.GothamBold,TextSize=12,
            TextXAlignment=Enum.TextXAlignment.Left,
            ZIndex=7,Parent=navBtn,
        })

        -- Badge (number pill)
        if badge then
            local bd=N("Frame",{
                Size=UDim2.fromOffset(28,18),
                Position=UDim2.new(1,-36,0.5,-9),
                BackgroundColor3=C.PINK_DIM,
                ZIndex=7,Parent=navBtn,
            })
            Rnd(99).Parent=bd
            N("TextLabel",{
                Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                Text=tostring(badge),TextColor3=C.PINK_HOT,
                Font=Enum.Font.GothamBold,TextSize=10,
                ZIndex=8,Parent=bd,
            })
        end

        -- Page (2-col grid)
        local page=N("Frame",{
            Name="Page_"..tname,
            Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1,
            ClipsDescendants=false,
            Visible=false,
            ZIndex=3,Parent=pageHolder,
        })

        -- Page header
        local pageHead=N("Frame",{
            Size=UDim2.new(1,0,0,44),
            BackgroundTransparency=1,
            ZIndex=4,Parent=page,
        })
        N("TextLabel",{
            Size=UDim2.new(0.6,0,1,0),Position=UDim2.fromOffset(20,0),
            BackgroundTransparency=1,
            Text=(ticon~="" and ticon.."  " or "")..tname,
            TextColor3=C.TXT_TITLE,Font=Enum.Font.GothamBold,TextSize=18,
            TextXAlignment=Enum.TextXAlignment.Left,
            ZIndex=5,Parent=pageHead,
        })
        GLine(pageHead,C.PINK_HOT,C.PURP_LITE,1,UDim2.new(0,20,1,-1))

        -- Two-column grid
        local grid=N("Frame",{
            Size=UDim2.new(1,-24,1,-52),
            Position=UDim2.fromOffset(12,48),
            BackgroundTransparency=1,
            ZIndex=3,Parent=page,
        })
        N("UIGridLayout",{
            CellSize=UDim2.new(0.5,-6,0,1),
            CellPaddingSize=UDim2.fromOffset(12,12),
            FillDirection=Enum.FillDirection.Horizontal,
            SortOrder=Enum.SortOrder.LayoutOrder,
            Parent=grid,
        })

        -- Activate tab
        local function Activate()
            for _,t in pairs(WObj._tabs) do
                t.page.Visible=false
                tw(t.lbl,{TextColor3=C.TXT_MUTED},0.14)
                tw(t.btn,{BackgroundTransparency=1},0.14)
                tw(t.ind,{BackgroundTransparency=1},0.14)
            end
            page.Visible=true
            tw(lbl,{TextColor3=C.PINK_HOT},0.14)
            tw(navBtn,{BackgroundColor3=C.PURP_DARK,BackgroundTransparency=0},0.16)
            tw(indicator,{BackgroundTransparency=0},0.16)
            WObj._active=tname
        end

        navBtn.MouseButton1Click:Connect(Activate)
        navBtn.MouseEnter:Connect(function()
            if WObj._active~=tname then
                tw(navBtn,{BackgroundColor3=C.BG_ELEM,BackgroundTransparency=0},0.12)
                tw(lbl,{TextColor3=C.TXT_MAIN},0.12)
            end
        end)
        navBtn.MouseLeave:Connect(function()
            if WObj._active~=tname then
                tw(navBtn,{BackgroundTransparency=1},0.12)
                tw(lbl,{TextColor3=C.TXT_MUTED},0.12)
            end
        end)

        table.insert(WObj._tabs,{btn=navBtn,lbl=lbl,page=page,ind=indicator,name=tname})
        if #WObj._tabs==1 then Activate() end

        -- ═══════════════════════════════════════════
        -- TAB OBJECT
        -- ═══════════════════════════════════════════
        local TObj={}

        -- Card builder
        function TObj:Card(ccfg)
            ccfg=ccfg or {}
            local ctitle=ccfg.Title or ""
            local cicon=ccfg.Icon or "🩷"

            -- Auto-size card
            local card=N("Frame",{
                BackgroundColor3=C.BG_CARD,
                AutomaticSize=Enum.AutomaticSize.Y,
                ZIndex=5,Parent=grid,
            })
            Rnd(10).Parent=card
            Bdr(C.BORD_CARD,1,0).Parent=card

            -- Card header
            local cheader=N("Frame",{
                Size=UDim2.new(1,0,0,34),
                BackgroundColor3=C.BG_ELEM,
                ZIndex=6,Parent=card,
            })
            Rnd(10).Parent=cheader
            -- bottom-round override (only round top)
            N("Frame",{Size=UDim2.new(1,0,0.5,0),Position=UDim2.new(0,0,0.5,0),BackgroundColor3=C.BG_ELEM,ZIndex=5,Parent=cheader})
            GLine(cheader,C.PINK_HOT,C.PURP_LITE,1,UDim2.new(0,0,1,-1))

            -- Header icon dot (colored)
            N("Frame",{
                Size=UDim2.fromOffset(8,8),Position=UDim2.fromOffset(14,13),
                BackgroundColor3=C.PINK_HOT,ZIndex=7,Parent=cheader,
            }); local hDot=cheader:FindFirstChildOfClass("Frame")
            if hDot then Rnd(99).Parent=hDot NGlow(hDot,C.PINK_HOT,8) end

            N("TextLabel",{
                Size=UDim2.new(1,-32,1,0),Position=UDim2.fromOffset(28,0),
                BackgroundTransparency=1,
                Text=cicon.."  "..ctitle:upper(),
                TextColor3=C.TXT_MUTED,Font=Enum.Font.GothamBold,TextSize=10,
                TextXAlignment=Enum.TextXAlignment.Left,
                ZIndex=7,Parent=cheader,
            })

            -- Card body (element list)
            local body=N("Frame",{
                Size=UDim2.new(1,0,0,0),
                Position=UDim2.fromOffset(0,34),
                BackgroundTransparency=1,
                AutomaticSize=Enum.AutomaticSize.Y,
                ZIndex=5,Parent=card,
            })
            VList(0).Parent=body
            Pad(6,10,12,12).Parent=body

            -- ── CARD OBJECT (elements) ──
            local CObj={}

            -- element row helper
            local function Row(h)
                local r=N("Frame",{
                    Size=UDim2.new(1,0,0,h or 34),
                    BackgroundColor3=C.BG_CARD,
                    BackgroundTransparency=1,
                    ZIndex=6,Parent=body,
                })
                return r
            end

            -- Separator line inside card
            function CObj:Sep(o)
                o=o or {}
                local f=Row(20)
                if o.Text then
                    N("TextLabel",{
                        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                        Text=o.Text:upper(),TextColor3=C.TXT_MUTED,
                        Font=Enum.Font.GothamBold,TextSize=8,
                        TextXAlignment=Enum.TextXAlignment.Left,
                        ZIndex=7,Parent=f,
                    })
                end
            end

            -- ── TOGGLE ──
            function CObj:Toggle(o)
                o=o or {}
                local state=o.Default or false
                local cb=o.Callback or function()end
                local TW,TH2=42,22

                local r=Row(34)

                N("TextLabel",{
                    Size=UDim2.new(1,-(TW+16),1,0),Position=UDim2.fromOffset(0,0),
                    BackgroundTransparency=1,Text=o.Name or "Toggle",
                    TextColor3=C.TXT_MAIN,Font=Enum.Font.Gotham,TextSize=13,
                    TextXAlignment=Enum.TextXAlignment.Left,
                    ZIndex=7,Parent=r,
                })

                -- Track (pill shape)
                local track=N("Frame",{
                    Size=UDim2.fromOffset(TW,TH2),
                    Position=UDim2.new(1,-(TW),0.5,-TH2/2),
                    BackgroundColor3=state and C.TGL_ON or C.TGL_OFF,
                    ZIndex=7,Parent=r,
                })
                Rnd(99).Parent=track
                local tSt=Bdr(state and C.PINK_HOT or C.BORD_ELEM,1,state and 0.3 or 0); tSt.Parent=track
                if state then NGlow(track,C.PINK_HOT,12) end

                local glowImg
                if state then glowImg=NGlow(track,C.PINK_HOT,12) end

                -- Thumb (circle)
                local thumb=N("Frame",{
                    Size=UDim2.fromOffset(TH2-6,TH2-6),
                    Position=state and UDim2.fromOffset(TW-TH2+3,3) or UDim2.fromOffset(3,3),
                    BackgroundColor3=C.TGL_THUMB,
                    ZIndex=8,Parent=track,
                })
                Rnd(99).Parent=thumb

                local function SetState(v,anim)
                    state=v
                    local tgtBG=v and C.TGL_ON or C.TGL_OFF
                    local tgtPos=v and UDim2.fromOffset(TW-TH2+3,3) or UDim2.fromOffset(3,3)
                    if anim then
                        tw(track,{BackgroundColor3=tgtBG},0.18)
                        tw(tSt,{Color=v and C.PINK_HOT or C.BORD_ELEM,Transparency=v and 0.3 or 0},0.18)
                        tw(thumb,{Position=tgtPos},0.2,Enum.EasingStyle.Back)
                    else
                        track.BackgroundColor3=tgtBG
                        thumb.Position=tgtPos
                    end
                    if o.Flag then BarbieHub.Flags[o.Flag]=v end
                    cb(v)
                end

                local hb=N("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=9,Parent=r})
                hb.MouseButton1Click:Connect(function() SetState(not state,true) end)
                r.MouseEnter:Connect(function() tw(r,{BackgroundColor3=C.BG_CARD2,BackgroundTransparency=0},0.1) end)
                r.MouseLeave:Connect(function() tw(r,{BackgroundTransparency=1},0.1) end)

                return {Set=function(_,v)SetState(v,true)end,Get=function()return state end}
            end

            -- ── SLIDER ──
            function CObj:Slider(o)
                o=o or {}
                local mn,mx,dp3=o.Min or 0,o.Max or 100,o.DecimalPlaces or 0
                local val=math.clamp(o.Default or (mn+mx)/2,mn,mx)
                local cb=o.Callback or function()end
                local sfx=o.Suffix or ""
                local dragging=false

                local r=Row(44)

                -- Label + value header
                local hf=N("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,ZIndex=7,Parent=r})
                N("TextLabel",{Size=UDim2.new(0.6,0,1,0),BackgroundTransparency=1,
                    Text=(o.Name or "Slider"):upper(),TextColor3=C.TXT_MUTED,
                    Font=Enum.Font.GothamBold,TextSize=9,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=8,Parent=hf})
                local vLbl=N("TextLabel",{Size=UDim2.new(0.4,0,1,0),Position=UDim2.new(0.6,0,0,0),
                    BackgroundTransparency=1,Font=Enum.Font.GothamBold,TextSize=11,
                    TextColor3=C.TXT_VAL,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=8,Parent=hf})

                local function Fmt(v)
                    vLbl.Text=string.format("%."..dp3.."f",v)..sfx
                end Fmt(val)

                -- Track
                local tBg=N("Frame",{
                    Size=UDim2.new(1,0,0,4),Position=UDim2.fromOffset(0,26),
                    BackgroundColor3=C.SLD_TRACK,ZIndex=7,Parent=r,
                })
                Rnd(99).Parent=tBg

                local fill=N("Frame",{
                    Size=UDim2.new((val-mn)/(mx-mn),0,1,0),
                    BackgroundColor3=C.SLD_FILL,ZIndex=8,Parent=tBg,
                })
                Rnd(99).Parent=fill
                N("UIGradient",{Color=ColorSequence.new({ColorSequenceKeypoint.new(0,C.PURP_LITE),ColorSequenceKeypoint.new(1,C.PINK_HOT)}),Parent=fill})

                -- Thumb (pill/circle)
                local thumb=N("Frame",{
                    Size=UDim2.fromOffset(14,14),AnchorPoint=Vector2.new(0.5,0.5),
                    Position=UDim2.new((val-mn)/(mx-mn),0,0.5,0),
                    BackgroundColor3=C.SLD_THUMB,ZIndex=9,Parent=tBg,
                })
                Rnd(99).Parent=thumb
                NGlow(thumb,C.PINK_HOT,14)

                local function Upd(v)
                    v=math.clamp(v,mn,mx)
                    local m=10^dp3; v=math.floor(v*m+.5)/m; val=v
                    local p=(v-mn)/(mx-mn)
                    tw(fill,{Size=UDim2.new(p,0,1,0)},0.05)
                    tw(thumb,{Position=UDim2.new(p,0,0.5,0)},0.05)
                    Fmt(v)
                    if o.Flag then BarbieHub.Flags[o.Flag]=v end; cb(v)
                end

                local hit=N("TextButton",{Size=UDim2.new(1,0,0,22),Position=UDim2.fromOffset(0,20),BackgroundTransparency=1,Text="",ZIndex=10,Parent=r})
                hit.MouseButton1Down:Connect(function()
                    dragging=true tw(thumb,{Size=UDim2.fromOffset(16,16)},0.1)
                end)
                InputS.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then
                        dragging=false tw(thumb,{Size=UDim2.fromOffset(14,14)},0.1)
                    end
                end)
                RunS.Heartbeat:Connect(function()
                    if dragging then
                        local p=math.clamp((InputS:GetMouseLocation().X-tBg.AbsolutePosition.X)/tBg.AbsoluteSize.X,0,1)
                        Upd(mn+p*(mx-mn))
                    end
                end)
                r.MouseEnter:Connect(function() tw(r,{BackgroundColor3=C.BG_CARD2,BackgroundTransparency=0},0.1) end)
                r.MouseLeave:Connect(function() tw(r,{BackgroundTransparency=1},0.1) end)

                return {Set=function(_,v)Upd(v)end,Get=function()return val end}
            end

            -- ── BUTTON (styled like APPLY / RESET) ──
            function CObj:Button(o)
                o=o or {}
                local cb=o.Callback or function()end
                local style=o.Style or "primary"  -- "primary" | "outline"

                local btnFrm=N("Frame",{
                    Size=UDim2.new(1,0,0,32),
                    BackgroundTransparency=1,ZIndex=6,Parent=body,
                })

                local btn=N("TextButton",{
                    Size=UDim2.new(1,0,1,0),
                    BackgroundColor3=style=="outline" and Color3.new(0,0,0) or C.PURP_DARK,
                    BackgroundTransparency=style=="outline" and 1 or 0,
                    Text=(o.Name or "BUTTON"):upper()..(o.Emoji and "  "..o.Emoji or ""),
                    TextColor3=style=="outline" and C.PINK_HOT or C.TXT_MAIN,
                    Font=Enum.Font.GothamBold,TextSize=11,
                    AutoButtonColor=false,ZIndex=7,Parent=btnFrm,
                })
                Rnd(8).Parent=btn
                Bdr(C.PINK_HOT,1,style=="outline" and 0.3 or 0.5).Parent=btn
                NGlow(btn,C.PINK_HOT,8)

                btn.MouseEnter:Connect(function()
                    tw(btn,{BackgroundColor3=C.PINK_DIM,BackgroundTransparency=0,TextColor3=C.WHITE},0.14)
                end)
                btn.MouseLeave:Connect(function()
                    tw(btn,{BackgroundColor3=style=="outline" and Color3.new(0,0,0) or C.PURP_DARK,BackgroundTransparency=style=="outline" and 1 or 0,TextColor3=style=="outline" and C.PINK_HOT or C.TXT_MAIN},0.14)
                end)
                btn.MouseButton1Click:Connect(function()
                    tw(btn,{BackgroundColor3=C.PINK_HOT,TextColor3=C.WHITE},0.08)
                    task.delay(0.2,function() tw(btn,{BackgroundColor3=style=="outline" and Color3.new(0,0,0) or C.PURP_DARK,TextColor3=style=="outline" and C.PINK_HOT or C.TXT_MAIN},0.18) end)
                    cb()
                end)

                return {Fire=function()cb()end}
            end

            -- ── DROPDOWN ──
            function CObj:Select(o)
                o=o or {}
                local opts2=o.Options or {}
                local sel=o.Default or opts2[1] or ""
                local cb=o.Callback or function()end
                local open=false

                local wrap=N("Frame",{Size=UDim2.new(1,0,0,34),BackgroundTransparency=1,ZIndex=8,Parent=body})
                N("TextLabel",{
                    Size=UDim2.new(1,0,0,14),BackgroundTransparency=1,
                    Text=(o.Name or ""):upper(),TextColor3=C.TXT_MUTED,
                    Font=Enum.Font.GothamBold,TextSize=8,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=9,Parent=wrap,
                })

                local selFrm=N("Frame",{
                    Size=UDim2.new(1,0,0,22),Position=UDim2.fromOffset(0,14),
                    BackgroundColor3=C.BG_ELEM,ZIndex=9,Parent=wrap,
                })
                Rnd(6).Parent=selFrm Bdr(C.BORD_ELEM,1).Parent=selFrm

                local selLbl=N("TextLabel",{
                    Size=UDim2.new(1,-26,1,0),Position=UDim2.fromOffset(8,0),
                    BackgroundTransparency=1,Text=sel,
                    TextColor3=C.PINK_HOT,Font=Enum.Font.GothamSemibold,TextSize=11,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=10,Parent=selFrm,
                })
                local arrow=N("TextLabel",{
                    Size=UDim2.fromOffset(20,22),Position=UDim2.new(1,-22,0,0),
                    BackgroundTransparency=1,Text="▾",TextColor3=C.PINK_HOT,
                    Font=Enum.Font.GothamBold,TextSize=13,ZIndex=10,Parent=selFrm,
                })

                local ddList=N("Frame",{
                    Size=UDim2.new(1,0,0,math.min(#opts2,5)*22+6),
                    Position=UDim2.fromOffset(0,36),
                    BackgroundColor3=C.BG_ELEM,ZIndex=18,Visible=false,Parent=wrap,
                })
                Rnd(6).Parent=ddList Bdr(C.BORD_PINK,1,0.4).Parent=ddList
                Pad(3,3,4,4).Parent=ddList VList(2).Parent=ddList

                for _,opt in ipairs(opts2) do
                    local ob=N("TextButton",{
                        Size=UDim2.new(1,0,0,20),
                        BackgroundColor3=opt==sel and C.PURP_DARK or Color3.new(0,0,0),
                        BackgroundTransparency=opt==sel and 0 or 1,
                        Text=opt,TextColor3=opt==sel and C.PINK_HOT or C.TXT_SUB,
                        Font=Enum.Font.GothamSemibold,TextSize=11,
                        AutoButtonColor=false,ZIndex=19,Parent=ddList,
                    })
                    Rnd(4).Parent=ob
                    ob.MouseButton1Click:Connect(function()
                        sel=opt selLbl.Text=opt open=false ddList.Visible=false
                        tw(arrow,{Rotation=0},0.15)
                        if o.Flag then BarbieHub.Flags[o.Flag]=opt end cb(opt)
                    end)
                    ob.MouseEnter:Connect(function() tw(ob,{BackgroundColor3=C.PURP_DARK,BackgroundTransparency=0,TextColor3=C.PINK_HOT},0.1) end)
                    ob.MouseLeave:Connect(function() tw(ob,{BackgroundColor3=opt==sel and C.PURP_DARK or Color3.new(0,0,0),BackgroundTransparency=opt==sel and 0 or 1,TextColor3=opt==sel and C.PINK_HOT or C.TXT_SUB},0.1) end)
                end

                local hb=N("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=11,Parent=selFrm})
                hb.MouseButton1Click:Connect(function()
                    open=not open ddList.Visible=open tw(arrow,{Rotation=open and 180 or 0},0.18)
                end)
                return {Get=function()return sel end,Set=function(_,v)sel=v selLbl.Text=v cb(v) end}
            end

            -- ── INPUT ──
            function CObj:Input(o)
                o=o or {}
                local cb=o.Callback or function()end
                local wrap=N("Frame",{Size=UDim2.new(1,0,0,44),BackgroundTransparency=1,ZIndex=7,Parent=body})
                N("TextLabel",{
                    Size=UDim2.new(1,0,0,14),BackgroundTransparency=1,
                    Text=(o.Name or ""):upper(),TextColor3=C.TXT_MUTED,
                    Font=Enum.Font.GothamBold,TextSize=8,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=8,Parent=wrap,
                })
                local ibg=N("Frame",{
                    Size=UDim2.new(1,0,0,24),Position=UDim2.fromOffset(0,16),
                    BackgroundColor3=C.BG_ELEM,ZIndex=8,Parent=wrap,
                })
                Rnd(6).Parent=ibg
                local iSt=Bdr(C.BORD_ELEM,1); iSt.Parent=ibg

                local tb=N("TextBox",{
                    Size=UDim2.new(1,-16,1,0),Position=UDim2.fromOffset(8,0),
                    BackgroundTransparency=1,
                    PlaceholderText=o.Placeholder or "...",
                    PlaceholderColor3=C.TXT_MUTED,
                    Text=o.Default or "",
                    TextColor3=C.TXT_MAIN,Font=Enum.Font.Gotham,TextSize=12,
                    TextXAlignment=Enum.TextXAlignment.Left,
                    ClearTextOnFocus=false,ZIndex=9,Parent=ibg,
                })
                tb.Focused:Connect(function() tw(iSt,{Color=C.PINK_HOT,Transparency=0.2},0.15) end)
                tb.FocusLost:Connect(function(e)
                    tw(iSt,{Color=C.BORD_ELEM,Transparency=0},0.15)
                    if o.Flag then BarbieHub.Flags[o.Flag]=tb.Text end
                    if e then cb(tb.Text) end
                end)
                return {Get=function()return tb.Text end,Set=function(_,v)tb.Text=tostring(v)end}
            end

            -- ── BIND ──
            function CObj:Bind(o)
                o=o or {}
                local cur=o.Default or Enum.KeyCode.Unknown
                local cb=o.Callback or function()end
                local listening=false

                local r=Row(34)
                N("TextLabel",{
                    Size=UDim2.new(0.55,0,1,0),BackgroundTransparency=1,
                    Text=o.Name or "Keybind",TextColor3=C.TXT_MAIN,
                    Font=Enum.Font.Gotham,TextSize=13,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=7,Parent=r,
                })
                local chip=N("TextButton",{
                    Size=UDim2.fromOffset(68,22),Position=UDim2.new(1,-70,0.5,-11),
                    BackgroundColor3=C.BG_ELEM,
                    Font=Enum.Font.GothamSemibold,TextSize=10,TextColor3=C.TXT_SUB,
                    AutoButtonColor=false,ZIndex=7,Parent=r,
                })
                Rnd(6).Parent=chip
                local cSt=Bdr(C.BORD_ELEM,1); cSt.Parent=chip

                local function KN(k) if k==Enum.KeyCode.Unknown then return "No Bind" end return tostring(k):match("Enum%.KeyCode%.(.+)") or "?" end
                chip.Text=KN(cur)

                chip.MouseButton1Click:Connect(function()
                    listening=true chip.Text="[...]"
                    tw(cSt,{Color=C.PINK_HOT},0.12) tw(chip,{BackgroundColor3=C.PURP_DARK},0.12)
                end)
                InputS.InputBegan:Connect(function(i,gpe)
                    if not listening or gpe then return end
                    if i.UserInputType==Enum.UserInputType.Keyboard then
                        listening=false cur=i.KeyCode chip.Text=KN(cur)
                        tw(cSt,{Color=C.BORD_ELEM},0.12) tw(chip,{BackgroundColor3=C.BG_ELEM},0.12)
                        if o.Flag then BarbieHub.Flags[o.Flag]=cur end cb(cur)
                    end
                end)
                r.MouseEnter:Connect(function() tw(r,{BackgroundColor3=C.BG_CARD2,BackgroundTransparency=0},0.1) end)
                r.MouseLeave:Connect(function() tw(r,{BackgroundTransparency=1},0.1) end)
                return {Get=function()return cur end,Set=function(_,k)cur=k chip.Text=KN(k)end}
            end

            function CObj:Notify(o) BarbieNotify(o) end

            return CObj
        end -- :Card

        function TObj:Notify(o) BarbieNotify(o) end
        return TObj
    end -- :Tab

    function WObj:Notify(o) BarbieNotify(o) end
    function WObj:Destroy() blur:Destroy() sg:Destroy() end

    return WObj
end -- :Window

return BarbieHub
