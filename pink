    tw(p,{Position=UDim2.fromOffset(destX,destY),BackgroundTransparency=1,Size=UDim2.fromOffset(2,2)},0.6,Enum.EasingStyle.Quad)
    Debris:AddItem(p,0.65)
end

-- Drag helper
local function Draggable(frame, handle)
    handle = handle or frame
    local drag,dragInput,startMouse,startPos = false
    handle.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            drag=true dragInput=nil startMouse=i.Position startPos=frame.Position
            i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then drag=false end end)
        end
    end)
    handle.InputChanged:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseMovement then dragInput=i end end)
    Input.InputChanged:Connect(function(i)
        if i==dragInput and drag then
            local d=i.Position-startMouse
            frame.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
        end
    end)
end

