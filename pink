            })

            tb.Focused:Connect(function()
                Util.Tween(inputStroke, { Color = Theme.PINK_500 }, 0.15)
                Util.Tween(inputBg, { BackgroundColor3 = Theme.BG_HOVER }, 0.15)
            end)
            tb.FocusLost:Connect(function(enter)
                Util.Tween(inputStroke, { Color = Theme.BORDER }, 0.15)
                Util.Tween(inputBg, { BackgroundColor3 = Theme.BG_ELEMENT }, 0.15)
                if nums then tb.Text = tostring(tonumber(tb.Text) or "") end
                if flag then PinkUI.Flags[flag] = tb.Text end
                if enter then cb(tb.Text) end
            end)

            return {
                Get = function(_) return tb.Text end,
                Set = function(_, v) tb.Text = tostring(v) end,
            }
        end

        -- ────────────────────────────────────────────────
        -- AddColorPicker
        -- ────────────────────────────────────────────────
        function TabObj:AddColorPicker(opts)
            opts = opts or {}
            local name    = opts.Name or "Color"
            local default = opts.Default or Theme.PINK_500
            local cb      = opts.Callback or function() end
            local flag    = opts.Flag

            local current = default
            local open = false

            local wrapper = Util.Create("Frame", {
                Size = UDim2.new(1, 0, 0, Sizes.ELEMENT_H),
                BackgroundTransparency = 1,
                ClipsDescendants = false,
                ZIndex = 8,
                Parent = Page,
            })

            local row = Util.Create("Frame", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundColor3 = Theme.BG_PANEL,
                ZIndex = 8,
                Parent = wrapper,
            })
            Util.MakeCorner(Sizes.CORNER_SMALL).Parent = row
            Util.MakeStroke(Theme.BORDER, 1).Parent = row

            Util.Create("TextLabel", {
                Size = UDim2.new(0.6, 0, 1, 0),
                Position = UDim2.fromOffset(12, 0),
                BackgroundTransparency = 1,
                Text = name,
                TextColor3 = Theme.TEXT_SECONDARY,
                Font = Font.SEMI,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 9,
                Parent = row,
            })

            -- Color preview swatch
            local swatch = Util.Create("Frame", {
                Size = UDim2.fromOffset(22, 22),
                Position = UDim2.new(1, -36, 0.5, -11),
                BackgroundColor3 = current,
                ZIndex = 9,
                Parent = row,
            })
            Util.MakeCorner(4).Parent = swatch
            Util.MakeStroke(Theme.BORDER, 1).Parent = swatch

            -- Simple HSV picker (compact 3-slider version)
            local pickerFrame = Util.Create("Frame", {
                Size = UDim2.new(1, 0, 0, 90),
                Position = UDim2.new(0, 0, 1, 2),
                BackgroundColor3 = Theme.BG_PANEL,
                ClipsDescendants = false,
                ZIndex = 18,
                Visible = false,
                Parent = wrapper,
            })
            Util.MakeCorner(Sizes.CORNER_SMALL).Parent = pickerFrame
            Util.MakeStroke(Theme.PINK_800, 1).Parent = pickerFrame
            Util.MakePadding(8, 8, 10, 10).Parent = pickerFrame
            local pickerLayout = Util.MakeListLayout(Enum.FillDirection.Vertical, 6)
            pickerLayout.Parent = pickerFrame

            local h, s, v = Color3.toHSV(current)

            local function Rebuild()
                current = Color3.fromHSV(h, s, v)
                swatch.BackgroundColor3 = current
                if flag then PinkUI.Flags[flag] = current end
                cb(current)
            end

            local function MiniSlider(label, initial, onChg)
                local f = Util.Create("Frame", { Size = UDim2.new(1, 0, 0, 18), BackgroundTransparency = 1, Parent = pickerFrame })
                Util.Create("TextLabel", { Size = UDim2.new(0, 12, 1, 0), BackgroundTransparency = 1, Text = label, TextColor3 = Theme.TEXT_MUTED, Font = Font.BOLD, TextSize = 9, Parent = f })
                local track = Util.Create("Frame", { Size = UDim2.new(1, -18, 0, 3), Position = UDim2.fromOffset(16, 7), BackgroundColor3 = Theme.SLIDER_TRACK, Parent = f })
                Util.MakeCorner(999).Parent = track
                local fill = Util.Create("Frame", { Size = UDim2.new(initial, 0, 1, 0), BackgroundColor3 = Theme.PINK_400, Parent = track })
                Util.MakeCorner(999).Parent = fill
                local thumb = Util.Create("TextButton", { Size = UDim2.fromOffset(10, 10), AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(initial, 0, 0.5, 0), BackgroundColor3 = Color3.new(1,1,1), Text = "", ZIndex = 19, Parent = track })
                Util.MakeCorner(999).Parent = thumb
                local drag = false
                thumb.MouseButton1Down:Connect(function() drag = true end)
                UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
                RunService.Heartbeat:Connect(function()
                    if drag then
                        local mx = UserInputService:GetMouseLocation().X
                        local p = math.clamp((mx - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                        fill.Size = UDim2.new(p, 0, 1, 0)
                        thumb.Position = UDim2.new(p, 0, 0.5, 0)
                        onChg(p)
                        Rebuild()
                    end
                end)
            end

            MiniSlider("H", h, function(p) h = p end)
            MiniSlider("S", s, function(p) s = p end)
            MiniSlider("V", v, function(p) v = p end)

            local toggleBtn = Util.Create("TextButton", { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 10, Parent = row })
            toggleBtn.MouseButton1Click:Connect(function()
                open = not open
                pickerFrame.Visible = open
            end)

            return {
                Get = function(_) return current end,
                Set = function(_, c) current = c swatch.BackgroundColor3 = c h, s, v = Color3.toHSV(c) end,
            }
        end

        -- ────────────────────────────────────────────────
        -- AddNotify (shortcut for notification)
        -- ────────────────────────────────────────────────
        function TabObj:AddNotify(opts)
            ShowNotification(opts)
        end

        return TabObj
    end

    -- ─────────────────────────────────────────────────────
    -- Window-level Notify
    -- ─────────────────────────────────────────────────────
    function WindowObj:Notify(opts)
        ShowNotification(opts)
    end

    function WindowObj:Destroy()
        blur:Destroy()
        ScreenGui:Destroy()
    end

    return WindowObj
end

-- ═══════════════════════════════════════════════════════════
-- GLOBAL FLAGS
-- ═══════════════════════════════════════════════════════════
PinkUI.Flags = {}

-- ═══════════════════════════════════════════════════════════
-- GLOBAL NOTIFY (static)
-- ═══════════════════════════════════════════════════════════
function PinkUI:Notify(opts)
    ShowNotification(opts)
end

-- ═══════════════════════════════════════════════════════════
-- DESTROY ALL
-- ═══════════════════════════════════════════════════════════
function PinkUI:DestroyAll()
    for _, v in pairs(CoreGui:GetChildren()) do
        if v.Name:match("^PinkUI_") then v:Destroy() end
    end
    for _, v in pairs(game.Lighting:GetChildren()) do
        if v:IsA("BlurEffect") then v:Destroy() end
    end
end

return PinkUI
