local NS, NH
local function EnsureNotif()
    if NS and NS.Parent then return end
    NS=N("ScreenGui",{Name="BarbieHub_Notifs",ResetOnSpawn=false,ZIndexBehavior=Enum.ZIndexBehavior.Sibling,Parent=CoreGui})
    NH=N("Frame",{Size=UDim2.new(0,300,1,0),Position=UDim2.new(1,-312,0,0),BackgroundTransparency=1,Parent=NS})
    local l=VList(8); l.VerticalAlignment=Enum.VerticalAlignment.Bottom; l.Parent=NH
    Pad(0,14,0,0).Parent=NH
end

local function BarbieNotify(opts)
    opts=opts or {} EnsureNotif()
    local title=opts.Title or "BarbieHub"
    local text=opts.Text or ""
    local dur=opts.Duration or 4
    local accent=({info=C.PINK_HOT,success=C.STS_GREEN,warning=C.STS_YELLOW,error=C.STS_RED})[opts.Type or "info"] or C.PINK_HOT

    local card=N("Frame",{
        Size=UDim2.new(1,0,0,72),
        BackgroundColor3=C.BG_CARD,
        BackgroundTransparency=0,
        ClipsDescendants=true,
        Parent=NH,
    })
    Rnd(10).Parent=card
    Bdr(accent,1,0.2).Parent=card
    NGlow(card,accent,18)

    N("Frame",{Size=UDim2.new(0,3,0.7,0),Position=UDim2.new(0,0,0.15,0),BackgroundColor3=accent,Parent=card})

    N("TextLabel",{Size=UDim2.new(1,-44,0,20),Position=UDim2.fromOffset(14,10),BackgroundTransparency=1,
        Text="🩷 "..title,TextColor3=C.TXT_TITLE,Font=Enum.Font.GothamBold,TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Left,Parent=card})
    N("TextLabel",{Size=UDim2.new(1,-44,0,26),Position=UDim2.fromOffset(14,28),BackgroundTransparency=1,
        Text=text,TextColor3=C.TXT_SUB,Font=Enum.Font.Gotham,TextSize=11,
        TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=card})

    local pb=N("Frame",{Size=UDim2.new(1,0,0,2),Position=UDim2.new(0,0,1,-2),BackgroundColor3=C.BG_ELEM,Parent=card})
    local pf=N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=accent,Parent=pb})

    card.Position=UDim2.new(1,20,0,0)
    tw(card,{Position=UDim2.new(0,0,0,0)},0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
    TweenS:Create(pf,TweenInfo.new(dur,Enum.EasingStyle.Linear),{Size=UDim2.new(0,0,1,0)}):Play()

    task.delay(dur,function()
        tw(card,{Position=UDim2.new(1,20,0,0)},0.22)
        task.wait(0.25) card:Destroy()
    end)
end

