                Util.Tween(tabLabel, { TextColor3 = Theme.TEXT_SECONDARY }, 0.12)
            end
        end)
        TabBtn.MouseLeave:Connect(function()
            if WindowObj._ActiveTab ~= tabName then
                Util.Tween(TabBtn, { BackgroundTransparency = 1 }, 0.12)
                Util.Tween(tabLabel, { TextColor3 = Theme.TEXT_MUTED }, 0.12)
            end
        end)

        local tabData = { Btn = TabBtn, Label = tabLabel, Page = Page, Indicator = indicator, Name = tabName }
        table.insert(WindowObj._Tabs, tabData)

        -- Auto-activate first tab
        if #WindowObj._Tabs == 1 then Activate() end

