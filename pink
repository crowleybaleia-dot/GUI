    l.VerticalAlignment=Enum.VerticalAlignment.Bottom
    l.Parent=NotifHolder
    Pad(0,16,0,0).Parent=NotifHolder
end

local function Notify(opts)
    opts=opts or {}
    EnsureNotifs()
    local title    = opts.Title    or "SakuraUI"
    local text     = opts.Text     or ""
    local duration = opts.Duration or 4
    local ntype    = opts.Type     or "info"

    local accent = ({info=C.Sakura3,success=C.OK,warning=C.Warn,error=C.Err})[ntype] or C.Sakura3

    -- Card
    local card = New("Frame",{
        Size=UDim2.new(1,0,0,76),
        BackgroundColor3=C.Glass1,
        BackgroundTransparency=T.Glass,
        ClipsDescendants=true,
        Parent=NotifHolder,
    })
    Corner(R.Panel).Parent=card
    Stroke(accent,1,0.3).Parent=card
    Sheen(card,14)
    Glow(card,accent,20)

    -- Left accent stripe
    local stripe=New("Frame",{Size=UDim2.new(0,3,0.7,0),Position=UDim2.new(0,0,0.15,0),BackgroundColor3=accent,Parent=card})
    Corner(R.Pill).Parent=stripe

    -- Petal icon
    New("TextLabel",{
        Size=UDim2.fromOffset(28,28),Position=UDim2.fromOffset(14,10),
        BackgroundTransparency=1,Text="🌸",TextSize=18,Font=Enum.Font.GothamBold,Parent=card,
    })

    -- Title
    New("TextLabel",{
        Size=UDim2.new(1,-52,0,20),Position=UDim2.fromOffset(46,10),
        BackgroundTransparency=1,Text=title,
        TextColor3=C.TxtMain,Font=Enum.Font.GothamBold,TextSize=13,
        TextXAlignment=Enum.TextXAlignment.Left,Parent=card,
    })
    -- Body
    New("TextLabel",{
        Size=UDim2.new(1,-52,0,28),Position=UDim2.fromOffset(46,28),
        BackgroundTransparency=1,Text=text,
        TextColor3=C.TxtSub,Font=Enum.Font.Gotham,TextSize=11,
        TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=card,
    })
    -- Progress bar bg
    local pbg=New("Frame",{Size=UDim2.new(1,0,0,2),Position=UDim2.new(0,0,1,-2),BackgroundColor3=C.Glass3,Parent=card})
    local pb =New("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=accent,Parent=pbg})
    New("UIGradient",{Color=ColorSequence.new({ColorSequenceKeypoint.new(0,C.Gold2),ColorSequenceKeypoint.new(1,accent)}),Parent=pb})

    -- Animate in
    card.Position=UDim2.new(1,20,0,0)
    tw(card,{Position=UDim2.new(0,0,0,0)},0.35,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
    Tween:Create(pb,TweenInfo.new(duration,Enum.EasingStyle.Linear),{Size=UDim2.new(0,0,1,0)}):Play()

    task.delay(duration,function()
        tw(card,{Position=UDim2.new(1,20,0,0),BackgroundTransparency=1},0.25)
        task.wait(0.3) card:Destroy()
    end)
end

