        -- ────────────────────────────────────────────────
        -- AddToggle
        -- ────────────────────────────────────────────────
        function TabObj:AddToggle(opts)
            opts = opts or {}
            local name     = opts.Name or "Toggle"
            local default  = opts.Default or false
            local cb       = opts.Callback or function() end
            local flag     = opts.Flag

            local state = default
            local row = MakeRow()

            -- Label
            Util.Create("TextLabel", {
                Size = UDim2.new(1, -(Sizes.TOGGLE_W + 32), 1, 0),
                Position = UDim2.fromOffset(12, 0),
                BackgroundTransparency = 1,
                Text = name,
                TextColor3 = Theme.TEXT_SECONDARY,
                Font = Font.SEMI,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = row,
            })

            -- Bind-style button (No Bind style) left side
            local bindChip = Util.Create("TextButton", {
                Size = UDim2.fromOffset(52, 18),
                Position = UDim2.new(1, -(Sizes.TOGGLE_W + 20 + 52 + 8), 0.5, -9),
                BackgroundColor3 = Theme.BIND_BG,
                Text = "No Bind",
                TextColor3 = Theme.TEXT_MUTED,
                Font = Font.REGULAR,
                TextSize = 10,
                AutoButtonColor = false,
                Parent = row,
            })
            Util.MakeCorner(3).Parent = bindChip
            Util.MakeStroke(Theme.BIND_BORDER, 1).Parent = bindChip

            -- Toggle track
            local track = Util.Create("Frame", {
                Size = UDim2.fromOffset(Sizes.TOGGLE_W, Sizes.TOGGLE_H),
                Position = UDim2.new(1, -(Sizes.TOGGLE_W + 10), 0.5, -Sizes.TOGGLE_H/2),
                BackgroundColor3 = state and Theme.TOGGLE_ON or Theme.TOGGLE_OFF,
                Parent = row,
            })
            Util.MakeCorner(999).Parent = track
            Util.MakeStroke(state and Theme.PINK_600 or Theme.BORDER, 1).Parent = track

            -- Thumb
            local thumb = Util.Create("Frame", {
                Size = UDim2.fromOffset(Sizes.TOGGLE_H - 6, Sizes.TOGGLE_H - 6),
                Position = state and UDim2.fromOffset(Sizes.TOGGLE_W - Sizes.TOGGLE_H + 3, 3)
                                  or UDim2.fromOffset(3, 3),
                BackgroundColor3 = Color3.new(1,1,1),
                ZIndex = 2,
                Parent = track,
            })
            Util.MakeCorner(999).Parent = thumb
            Util.Create("UIDropShadowEffect", {Enabled = false}).Parent = thumb

            -- Glow
            local glow = Util.Create("ImageLabel", {
                Size = UDim2.new(1, 14, 1, 14),
                Position = UDim2.fromOffset(-7, -7),
                BackgroundTransparency = 1,
                Image = "rbxassetid://6014261993",
                ImageColor3 = Theme.PINK_500,
                ImageTransparency = state and 0.5 or 1,
                ScaleType = Enum.ScaleType.Slice,
                SliceCenter = Rect.new(49,49,450,450),
                ZIndex = -1,
                Parent = track,
            })

            local function SetState(val, animate)
                state = val
                local targetBG    = val and Theme.TOGGLE_ON or Theme.TOGGLE_OFF
                local targetPos   = val and UDim2.fromOffset(Sizes.TOGGLE_W - Sizes.TOGGLE_H + 3, 3)
                                         or UDim2.fromOffset(3, 3)
                local strokeColor = val and Theme.PINK_600 or Theme.BORDER
                if animate then
                    Util.Tween(track, { BackgroundColor3 = targetBG }, 0.18)
                    Util.Tween(thumb, { Position = targetPos }, 0.18, Enum.EasingStyle.Back)
                    Util.Tween(glow, { ImageTransparency = val and 0.5 or 1 }, 0.18)
                    for _, s in ipairs(track:GetChildren()) do
                        if s:IsA("UIStroke") then Util.Tween(s, { Color = strokeColor }, 0.18) end
                    end
                else
                    track.BackgroundColor3 = targetBG
                    thumb.Position = targetPos
                    glow.ImageTransparency = val and 0.5 or 1
                end
                if flag then PinkUI.Flags[flag] = val end
                cb(val)
            end

            local togBtn = Util.Create("TextButton", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = 5,
                Parent = row,
            })
            togBtn.MouseButton1Click:Connect(function()
                Util.Ripple(row, Mouse.X - row.AbsolutePosition.X, Mouse.Y - row.AbsolutePosition.Y)
                SetState(not state, true)
            end)
            row.MouseEnter:Connect(function() Util.Tween(row, { BackgroundColor3 = Theme.BG_HOVER }, 0.12) end)
            row.MouseLeave:Connect(function() Util.Tween(row, { BackgroundColor3 = Theme.BG_PANEL }, 0.12) end)

            return {
                Set = function(_, v) SetState(v, true) end,
                Get = function(_) return state end,
            }
        end

        -- ────────────────────────────────────────────────
        -- AddSlider
        -- ────────────────────────────────────────────────
        function TabObj:AddSlider(opts)
            opts = opts or {}
            local name    = opts.Name or "Slider"
            local min     = opts.Min or 0
            local max     = opts.Max or 100
            local default = math.clamp(opts.Default or 50, min, max)
            local dp      = opts.DecimalPlaces or 0
            local suffix  = opts.Suffix or ""
            local cb      = opts.Callback or function() end
            local flag    = opts.Flag

            local value = default
            local dragging = false

            local row = MakeRow(48)

            -- Top row: label + value display
            local lblRow = Util.Create("Frame", {
                Size = UDim2.new(1, -20, 0, 20),
                Position = UDim2.fromOffset(10, 6),
                BackgroundTransparency = 1,
                Parent = row,
            })

            -- Icon + Name
            Util.Create("TextLabel", {
                Size = UDim2.new(0.7, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "▶◼  " .. name,
                TextColor3 = Theme.TEXT_SECONDARY,
                Font = Font.SEMI,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = lblRow,
            })

            -- Value label (right-aligned, bold pink)
            local valueLabel = Util.Create("TextLabel", {
                Size = UDim2.new(0.3, 0, 1, 0),
                Position = UDim2.new(0.7, 0, 0, 0),
                BackgroundTransparency = 1,
                TextColor3 = Theme.TEXT_PRIMARY,
                Font = Font.BOLD,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Right,
                Parent = lblRow,
            })

            local function FormatVal(v)
                local formatted = string.format("%." .. dp .. "f", v)
                valueLabel.Text = string.format(
                    "<font color='#%s'>%s</font><font color='#%s'>/%s%s</font>",
                    "FF8FB8", formatted,
                    "7A5570", tostring(max), suffix
                )
            end
            valueLabel.RichText = true
            FormatVal(value)

            -- Track bg
            local trackBg = Util.Create("Frame", {
                Size = UDim2.new(1, -20, 0, 4),
                Position = UDim2.new(0, 10, 0, 34),
                BackgroundColor3 = Theme.SLIDER_TRACK,
                Parent = row,
            })
            Util.MakeCorner(999).Parent = trackBg

            -- Fill
            local fill = Util.Create("Frame", {
                Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
                BackgroundColor3 = Theme.SLIDER_FILL,
                ClipsDescendants = false,
                Parent = trackBg,
            })
            Util.MakeCorner(999).Parent = fill
            -- Gradient on fill
            Util.Create("UIGradient", {
                Color = ColorSequence.new({ ColorSequenceKeypoint.new(0, Theme.PINK_700), ColorSequenceKeypoint.new(1, Theme.PINK_300) }),
                Parent = fill,
            })

            -- Thumb
            local thumb = Util.Create("Frame", {
                Size = UDim2.fromOffset(12, 12),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new((default - min) / (max - min), 0, 0.5, 0),
                BackgroundColor3 = Theme.SLIDER_THUMB,
                ZIndex = 3,
                Parent = trackBg,
            })
            Util.MakeCorner(999).Parent = thumb
            Util.Create("ImageLabel", {
                Size = UDim2.new(1, 10, 1, 10),
                Position = UDim2.fromOffset(-5, -5),
                BackgroundTransparency = 1,
                Image = "rbxassetid://6014261993",
                ImageColor3 = Theme.PINK_400,
                ImageTransparency = 0.5,
                ScaleType = Enum.ScaleType.Slice,
                SliceCenter = Rect.new(49,49,450,450),
                ZIndex = 2,
                Parent = thumb,
            })

            local function UpdateSlider(v)
                v = math.clamp(v, min, max)
                local dp_mult = 10 ^ dp
                v = math.floor(v * dp_mult + 0.5) / dp_mult
                value = v
                local pct = (v - min) / (max - min)
                Util.Tween(fill, { Size = UDim2.new(pct, 0, 1, 0) }, 0.05)
                Util.Tween(thumb, { Position = UDim2.new(pct, 0, 0.5, 0) }, 0.05)
                FormatVal(v)
                if flag then PinkUI.Flags[flag] = v end
                cb(v)
            end

            -- Click/drag on track
            local hitbox = Util.Create("TextButton", {
                Size = UDim2.new(1, 0, 0, 20),
                Position = UDim2.new(0, 0, 0, 24),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = 5,
                Parent = row,
            })
            hitbox.MouseButton1Down:Connect(function()
                dragging = true
                Util.Tween(thumb, { Size = UDim2.fromOffset(14, 14) }, 0.1)
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                    Util.Tween(thumb, { Size = UDim2.fromOffset(12, 12) }, 0.1)
                end
            end)
            RunService.Heartbeat:Connect(function()
                if dragging then
                    local mouseX = UserInputService:GetMouseLocation().X
                    local trackX = trackBg.AbsolutePosition.X
                    local trackW = trackBg.AbsoluteSize.X
                    local pct = math.clamp((mouseX - trackX) / trackW, 0, 1)
                    UpdateSlider(min + pct * (max - min))
                end
            end)

            return {
                Set = function(_, v) UpdateSlider(v) end,
                Get = function(_) return value end,
            }
        end

