            r.MouseLeave:Connect(function() tw(r,{BackgroundColor3=C.Glass2,BackgroundTransparency=T.GlassDeep},0.12) end)
            return {Get=function()return tb.Text end,Set=function(_,v)tb.Text=tostring(v)end}
