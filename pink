local NotifContainer
local function EnsureNotifContainer()
    if NotifContainer and NotifContainer.Parent then return end
    local sg = Util.Create("ScreenGui", {
        Name = "PinkUI_Notifs",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        Parent = CoreGui,
    })
    NotifContainer = Util.Create("Frame", {
        Size = UDim2.new(0, Sizes.NOTIF_W, 1, 0),
        Position = UDim2.new(1, -(Sizes.NOTIF_W + 12), 0, 0),
        BackgroundTransparency = 1,
        Parent = sg,
    })
    local layout = Util.MakeListLayout(Enum.FillDirection.Vertical, 8)
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
    layout.Parent = NotifContainer
    Util.MakePadding(0, 14, 0, 0).Parent = NotifContainer
end

local function ShowNotification(opts)
    opts = opts or {}
    EnsureNotifContainer()
    local title    = opts.Title or "PinkUI"
    local text     = opts.Text or ""
    local duration = opts.Duration or 4
    local ntype    = opts.Type or "info"  -- "info","success","warning","error"

    local barColor = ({
        info    = Theme.PINK_500,
        success = Theme.SUCCESS,
        warning = Theme.WARNING,
        error   = Theme.ERROR,
    })[ntype] or Theme.PINK_500

    -- Container
    local notif = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 70),
        BackgroundColor3 = Theme.NOTIF_BG,
        BackgroundTransparency = 0,
        ClipsDescendants = true,
        Parent = NotifContainer,
    })
    Util.MakeCorner(Sizes.CORNER_ELEMENT).Parent = notif
    local stroke = Util.MakeStroke(barColor, 1, 0.5)
    stroke.Parent = notif

    -- Colored left bar
    local bar = Util.Create("Frame", {
        Size = UDim2.new(0, 3, 1, 0),
        Position = UDim2.fromOffset(0, 0),
        BackgroundColor3 = barColor,
        Parent = notif,
    })
    Util.MakeCorner(2).Parent = bar

    -- Title
    Util.Create("TextLabel", {
        Size = UDim2.new(1, -18, 0, 20),
        Position = UDim2.fromOffset(14, 10),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = Theme.TEXT_PRIMARY,
        Font = Font.BOLD,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = notif,
    })
    -- Body
    Util.Create("TextLabel", {
        Size = UDim2.new(1, -18, 0, 32),
        Position = UDim2.fromOffset(14, 30),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Theme.TEXT_SECONDARY,
        Font = Font.REGULAR,
        TextSize = 12,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = notif,
    })
    -- Progress bar
    local progBg = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, -2),
        BackgroundColor3 = Theme.BG_ELEMENT,
        Parent = notif,
    })
    local prog = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = barColor,
        Parent = progBg,
    })

    -- Slide in
    notif.Position = UDim2.new(1, 20, 0, 0)
    Util.Tween(notif, { Position = UDim2.new(0, 0, 0, 0) }, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    -- Progress tween
    TweenService:Create(prog, TweenInfo.new(duration, Enum.EasingStyle.Linear), { Size = UDim2.new(0, 0, 1, 0) }):Play()

    task.delay(duration, function()
        Util.Tween(notif, { Position = UDim2.new(1, 20, 0, 0) }, 0.25)
        task.wait(0.3)
        notif:Destroy()
    end)
end

