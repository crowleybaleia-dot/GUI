            Size = UDim2.new(0, 2, 0.6, 0),
            Position = UDim2.new(0, 0, 0.2, 0),
            BackgroundColor3 = Theme.PINK_500,
            BackgroundTransparency = 1,
            Parent = TabBtn,
        })
        Util.MakeCorner(2).Parent = indicator

        -- Icon + Label
        local tabLabel = Util.Create("TextLabel", {
            Size = UDim2.new(1, -20, 1, 0),
            Position = UDim2.fromOffset(14, 0),
            BackgroundTransparency = 1,
            Text = (tabIcon and (tabIcon .. "  ") or "") .. tabName,
            TextColor3 = Theme.TEXT_MUTED,
            Font = Font.SEMI,
            TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = TabBtn,
        })

        -- Page frame
        local Page = Util.Create("ScrollingFrame", {
            Name = "Page_" .. tabName,
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = Theme.PINK_700,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            Visible = false,
            Parent = TabPages,
        })
        Util.MakePadding(10, 10, 12, 12).Parent = Page
        local pageLayout = Util.MakeListLayout(Enum.FillDirection.Vertical, 4)
        pageLayout.Parent = Page

        -- Activate tab logic
        local function Activate()
            -- Deactivate all
            for _, t in pairs(WindowObj._Tabs) do
                t.Page.Visible = false
                Util.Tween(t.Label, { TextColor3 = Theme.TEXT_MUTED }, 0.15)
                Util.Tween(t.Btn, { BackgroundTransparency = 1 }, 0.15)
                Util.Tween(t.Indicator, { BackgroundTransparency = 1 }, 0.15)
            end
            -- Activate this
            Page.Visible = true
            Util.Tween(tabLabel, { TextColor3 = Theme.TEXT_PRIMARY }, 0.15)
            Util.Tween(TabBtn, { BackgroundColor3 = Theme.BG_HOVER, BackgroundTransparency = 0 }, 0.15)
