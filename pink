-- ═══════════════════════════════════════════════════════════════
--  TWEEN PRESETS
-- ═══════════════════════════════════════════════════════════════
local function tw(obj, props, t, style, dir)
    style = style or Enum.EasingStyle.Quart
    dir   = dir   or Enum.EasingDirection.Out
    Tween:Create(obj, TweenInfo.new(t or 0.18, style, dir), props):Play()
end

-- ═══════════════════════════════════════════════════════════════
--  INSTANCE FACTORY
-- ═══════════════════════════════════════════════════════════════
local function New(cls, props, kids)
    local o = Instance.new(cls)
    for k,v in pairs(props or {}) do o[k]=v end
    for _,k in ipairs(kids  or {}) do k.Parent=o end
    return o
end
local function Corner(r)  return New("UICorner",{CornerRadius=UDim.new(0,r or R.Elem)}) end
local function Stroke(col,th,tr) return New("UIStroke",{Color=col or C.Glass4,Thickness=th or 1,Transparency=tr or T.GlassBdr}) end
local function Pad(t,b,l,r) return New("UIPadding",{PaddingTop=UDim.new(0,t or 0),PaddingBottom=UDim.new(0,b or 0),PaddingLeft=UDim.new(0,l or 0),PaddingRight=UDim.new(0,r or 0)}) end
local function List(dir,gap,ha,va)
    return New("UIListLayout",{
        FillDirection=dir or Enum.FillDirection.Vertical,
        Padding=UDim.new(0,gap or 4),
        HorizontalAlignment=ha or Enum.HorizontalAlignment.Left,
        VerticalAlignment=va or Enum.VerticalAlignment.Top,
        SortOrder=Enum.SortOrder.LayoutOrder,
    })
end

-- Sheen highlight (reflexo de vidro no topo)
local function Sheen(parent, h)
    local f = New("Frame",{
        Size=UDim2.new(1,-4,0,h or 18),
        Position=UDim2.fromOffset(2,2),
        BackgroundColor3=C.Glass0,
        BackgroundTransparency=T.Sheen,
        ZIndex=(parent.ZIndex or 1)+1,
        Parent=parent,
    })
    Corner(R.Panel).Parent=f
    New("UIGradient",{
        Transparency=NumberSequence.new({
            NumberSequenceKeypoint.new(0,0.0),
            NumberSequenceKeypoint.new(0.5,0.6),
            NumberSequenceKeypoint.new(1,1.0),
        }),
        Rotation=0,
        Parent=f,
    })
    return f
end

