local function CreateCard(data, order)
    local isActive = (data.status == "Ativo")
    local isFeatured = data.featured

    local card = New("Frame",{
        BackgroundColor3=isFeatured and C.Surf3 or C.Surf2,
        ZIndex=13, LayoutOrder=order or 99,
    }, GRID)
    Corner(card,8)
    Stroke(card, isFeatured and C.BorderSage or C.Border, 1)

    -- Hover
    card.MouseEnter:Connect(function()
        Tw(card,{BackgroundColor3=C.Surf4},.18)
    end)
    card.MouseLeave:Connect(function()
        Tw(card,{BackgroundColor3=isFeatured and C.Surf3 or C.Surf2},.18)
    end)

    -- Linha topo sage (featured)
    if isFeatured then
        local lt = New("Frame",{
            Size=UDim2.new(1,0,0,2), BackgroundColor3=C.Sage,
            BackgroundTransparency=0.5, ZIndex=14,
        }, card)
        Corner(lt,8)
    end

    -- STATUS DOT + TEXTO
    local sdot = New("Frame",{
        AnchorPoint=Vector2.new(1,0),
        Position=UDim2.new(1,-24,0,12),
        Size=UDim2.new(0,6,0,6),
        BackgroundColor3=isActive and C.Sage or C.TextMuted,
        ZIndex=14,
    }, card)
    Corner(sdot,3)

    Label(card, isActive and "● ATIVO" or "● OFF",
        Enum.Font.GothamBold,8,
        isActive and C.Sage or C.TextMuted,
        UDim2.new(1,-62,0,10), UDim2.new(0,56,0,10),
        Enum.TextXAlignment.Right,false,14)

    -- Estrela featured
    if isFeatured then
        Label(card,"★",Enum.Font.GothamBold,11,C.Gold,
            UDim2.new(1,-16,0,10), UDim2.new(0,12,0,12),
            Enum.TextXAlignment.Right,false,14)
    end

    -- ÍCONE
    local iconBg = New("Frame",{
        Position=UDim2.new(0,10,0,12),
        Size=UDim2.new(0,38,0,38),
        BackgroundColor3=C.Surf4, ZIndex=14,
    }, card)
    Corner(iconBg,8)
    Stroke(iconBg,C.BorderSage,1)
    Label(iconBg,data.icon,Enum.Font.GothamBold,18,C.Sage,
        UDim2.new(0,0,0,0), UDim2.new(1,0,1,0),
        Enum.TextXAlignment.Center,false,15)

    -- NOME
    Label(card,data.name,Enum.Font.GothamBold,13,C.Text,
        UDim2.new(0,10,0,56), UDim2.new(1,-20,0,17),
        Enum.TextXAlignment.Left,false,14)

    -- JOGO
    Label(card,data.game,Enum.Font.Gotham,9,C.TextMuted,
        UDim2.new(0,10,0,73), UDim2.new(1,-20,0,12),
        Enum.TextXAlignment.Left,false,14)

    -- DESC
    Label(card,data.desc,Enum.Font.Gotham,9,C.TextMuted,
        UDim2.new(0,10,0,86), UDim2.new(1,-20,0,24),
        Enum.TextXAlignment.Left,true,14)

    -- Linha separadora
    New("Frame",{
        Position=UDim2.new(0,10,1,-28), Size=UDim2.new(1,-20,0,1),
        BackgroundColor3=C.Border, ZIndex=14,
    }, card)

    -- TAGS
    local tagX = 10
    for _, tag in ipairs(data.tags or {}) do
        local tw2 = #tag * 5 + 10
        local tbg = New("Frame",{
            Position=UDim2.new(0,tagX,1,-22),
            Size=UDim2.new(0,tw2,0,14),
            BackgroundColor3=C.Surf4, ZIndex=14,
        }, card)
        Corner(tbg,3)
        Label(tbg,tag,Enum.Font.GothamBold,7,C.TextDim,
            UDim2.new(0,0,0,0), UDim2.new(1,0,1,0),
            Enum.TextXAlignment.Center,false,15)
        tagX = tagX + tw2 + 4
    end

    -- EXEC BUTTON
    local execB = New("TextButton",{
        Text="EXEC", Font=Enum.Font.GothamBold, TextSize=8,
        TextColor3=C.Sage, BackgroundColor3=C.Surf,
        AutoButtonColor=false,
        AnchorPoint=Vector2.new(1,1),
        Position=UDim2.new(1,-8,1,-6),
        Size=UDim2.new(0,40,0,18), ZIndex=15,
    }, card)
    Corner(execB,4)
    Stroke(execB,C.BorderSage,1)

    execB.MouseEnter:Connect(function()
        Tw(execB,{BackgroundColor3=C.Surf3,TextColor3=C.SageBright},.12)
    end)
    execB.MouseLeave:Connect(function()
        Tw(execB,{BackgroundColor3=C.Surf,TextColor3=C.Sage},.12)
    end)
    execB.MouseButton1Click:Connect(function()
        Tw(execB,{BackgroundColor3=C.SageDark},.06)
        task.delay(.1,function() Tw(execB,{BackgroundColor3=C.Surf},.15) end)
        if data.callback then
            local ok2,err = pcall(data.callback)
            if not ok2 then warn("[SageHub] "..tostring(err)) end
        end
        -- Log no console
        _G.SageHub_Log("OK","→ "..data.name.." injetado")
    end)

    return card
end

