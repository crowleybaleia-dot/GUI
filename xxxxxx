-- ─── UTILS ────────────────────────────────────────────────────
local function Tw(obj, props, t, sty, dir)
    TweenService:Create(obj,
        TweenInfo.new(t or .18, sty or Enum.EasingStyle.Quint,
                      dir or Enum.EasingDirection.Out),
        props):Play()
end

local function New(cls, p, par)
    local o = Instance.new(cls)
    for k,v in pairs(p) do o[k]=v end
    if par then o.Parent = par end
    return o
end

local function Corner(par, r)
    New("UICorner",{CornerRadius=UDim.new(0,r or 6)},par)
end

local function Stroke(par, col, th)
    New("UIStroke",{Color=col or C.Border, Thickness=th or 1,
        ApplyStrokeMode=Enum.ApplyStrokeMode.Border}, par)
end

local function Pad(par, t, b, l, r)
    New("UIPadding",{
        PaddingTop=UDim.new(0,t or 0), PaddingBottom=UDim.new(0,b or t or 0),
        PaddingLeft=UDim.new(0,l or t or 0), PaddingRight=UDim.new(0,r or l or t or 0),
    }, par)
end

local function VList(par, sp)
    New("UIListLayout",{FillDirection=Enum.FillDirection.Vertical,
        Padding=UDim.new(0,sp or 0), SortOrder=Enum.SortOrder.LayoutOrder,
        HorizontalAlignment=Enum.HorizontalAlignment.Center}, par)
end

local function HList(par, sp)
    New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,
        Padding=UDim.new(0,sp or 0), SortOrder=Enum.SortOrder.LayoutOrder,
        VerticalAlignment=Enum.VerticalAlignment.Center}, par)
end

local function Label(par, text, font, size, col, pos, sz, xa, wrap, z)
    return New("TextLabel",{
        Text=text, Font=font or Enum.Font.Gotham,
        TextSize=size or 11, TextColor3=col or C.Text,
        BackgroundTransparency=1,
        Position=pos or UDim2.new(0,0,0,0),
        Size=sz or UDim2.new(1,0,1,0),
        TextXAlignment=xa or Enum.TextXAlignment.Left,
        TextWrapped=wrap or false,
        ZIndex=z or 5,
    }, par)
end

local function Bar(par, w, col, z)
    local f = New("Frame",{
        Size=UDim2.new(w or 0, 0, 1, 0),
        BackgroundColor3=col or C.Sage, ZIndex=z or 5,
    }, par)
    Corner(f, 2)
    return f
end

-- Draggable
local function MakeDrag(handle, frame)
    local drag, st, sp = false, nil, nil
    handle.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            drag=true; st=i.Position; sp=frame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
            local d = i.Position - st
            frame.Position = UDim2.new(sp.X.Scale, sp.X.Offset+d.X,
                                       sp.Y.Scale, sp.Y.Offset+d.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
    end)
end

