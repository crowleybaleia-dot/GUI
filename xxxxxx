    local cpu = math.random(20,55)
    local ram = math.random(50,75)
    cpuVal.Text = tostring(cpu).."%"
    ramVal.Text = tostring(ram).."%"
    Tw(cpuSFill,{Size=UDim2.new(cpu/100,0,1,0)},.5)
    Tw(ramSFill,{Size=UDim2.new(ram/100,0,1,0)},.5)
    Tw(cpuFill, {Size=UDim2.new(cpu/100,0,1,0)},.5)
    Tw(ramFill, {Size=UDim2.new(ram/100,0,1,0)},.5)
    Tw(fpsFill, {Size=UDim2.new(fpsPct,0,1,0)},.5)

    -- Dot pulsante
    Tw(loadDot,{BackgroundTransparency=loadDot.BackgroundTransparency>0 and 0 or 0.5},.4)
end)

