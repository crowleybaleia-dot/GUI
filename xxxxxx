local activeNav = "Scripts"
local allNavBtns = {}

local function CreateNavBtn(item)
    local btn = New("TextButton",{
        Text="", BackgroundColor3=C.Surf3,
        BackgroundTransparency=1,
        AutoButtonColor=false,
        Position=UDim2.new(0,8,0,item.y),
        Size=UDim2.new(1,-16,0,32),
        ZIndex=13,
    }, SIDEBAR)
    Corner(btn,6)

    local ind = New("Frame",{
        Position=UDim2.new(0,0,0.15,0), Size=UDim2.new(0,3,0.70,0),
        BackgroundColor3=C.Sage, BackgroundTransparency=1, ZIndex=14,
    }, btn)
    Corner(ind,2)

    Label(btn,item.icon,Enum.Font.GothamBold,13,C.TextMuted,
        UDim2.new(0,6,0,0), UDim2.new(0,26,1,0),
        Enum.TextXAlignment.Center,false,14)

    local txtLbl = Label(btn,item.name,Enum.Font.Gotham,11,C.TextMuted,
        UDim2.new(0,34,0,0), UDim2.new(1,-50,1,0),
        Enum.TextXAlignment.Left,false,14)

    if item.badge then
        local bg = New("Frame",{
            AnchorPoint=Vector2.new(1,.5),
            Position=UDim2.new(1,-4,.5,0),
            Size=UDim2.new(0,26,0,16),
            BackgroundColor3=C.Sage, ZIndex=14,
        }, btn)
        Corner(bg,8)
        Label(bg,item.badge,Enum.Font.GothamBold,9,C.Bg,
            UDim2.new(0,0,0,0), UDim2.new(1,0,1,0),
            Enum.TextXAlignment.Center,false,15)
    end

    local isActive = (item.name == activeNav)

    local function SetActive(v)
        Tw(btn,{BackgroundColor3=v and C.Surf3 or C.Bg,
                BackgroundTransparency=v and 0 or 1},.15)
        Tw(txtLbl,{TextColor3=v and C.Text or C.TextMuted},.15)
        Tw(ind,{BackgroundTransparency=v and 0 or 1},.15)
    end

    SetActive(isActive)

    btn.MouseEnter:Connect(function()
        if item.name~=activeNav then
            Tw(btn,{BackgroundColor3=C.Surf3,BackgroundTransparency=0.7},.12)
        end
    end)
    btn.MouseLeave:Connect(function()
        if item.name~=activeNav then
            Tw(btn,{BackgroundTransparency=1},.12)
        end
    end)
    btn.MouseButton1Click:Connect(function()
        for _,v in ipairs(allNavBtns) do v.SetActive(false) end
        activeNav = item.name
        SetActive(true)
    end)

    table.insert(allNavBtns,{SetActive=SetActive})
end

