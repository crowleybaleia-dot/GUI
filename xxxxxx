-- Função de log global
local logTypes = {
    OK  = C.Sage,
    ERR = C.Red,
    INF = C.Blue,
    WRN = C.Yellow,
}

local function AddLog(typ, msg)
    local now   = os.date("*t")
    local tstr  = string.format("%02d:%02d:%02d", now.hour, now.min, now.sec)
    local col   = logTypes[typ] or C.TextDim

    local row = New("Frame",{
        Size=UDim2.new(1,0,0,14),
        BackgroundTransparency=1, ZIndex=14,
    }, conBody)
    HList(row,4)

    New("TextLabel",{
        Text=tstr, Font=Enum.Font.Gotham, TextSize=8,
        TextColor3=C.TextMuted, BackgroundTransparency=1,
        Size=UDim2.new(0,48,1,0),
        TextXAlignment=Enum.TextXAlignment.Left, ZIndex=15,
    }, row)
    New("TextLabel",{
        Text="["..typ.."]", Font=Enum.Font.GothamBold, TextSize=8,
        TextColor3=col, BackgroundTransparency=1,
        Size=UDim2.new(0,32,1,0),
        TextXAlignment=Enum.TextXAlignment.Left, ZIndex=15,
    }, row)
    New("TextLabel",{
        Text=msg, Font=Enum.Font.Gotham, TextSize=8,
        TextColor3=C.TextDim, BackgroundTransparency=1,
        Size=UDim2.new(1,-84,1,0),
        TextXAlignment=Enum.TextXAlignment.Left, ZIndex=15,
        TextWrapped=true,
    }, row)

    -- Scroll para baixo
    task.defer(function()
        conBody.CanvasPosition = Vector2.new(0, math.huge)
    end)
end

