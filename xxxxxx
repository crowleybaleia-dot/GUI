local frameCount, lastFPS, lastTime = 0, 60, 0

RunService.RenderStepped:Connect(function(dt)
    frameCount = frameCount + 1
    lastTime   = lastTime + dt
    if lastTime >= 1 then
        lastFPS  = frameCount
        frameCount, lastTime = 0, 0
    end
end)

-- Atualiza stats a cada 2 segundos
local statTimer = 0
RunService.Heartbeat:Connect(function(dt)
    statTimer = statTimer + dt
    if statTimer < 2 then return end
    statTimer = 0

    -- Relógio
    local t = os.date("*t")
    clockLbl.Text = string.format("%02d:%02d:%02d", t.hour, t.min, t.sec)

    -- FPS
    local fps     = math.min(lastFPS, 144)
    local fpsPct  = fps / 144
    local fpsStr  = tostring(fps)
    fpsVal.Text   = fpsStr
    Tw(fpsFill,  {Size=UDim2.new(fpsPct,0,1,0)},.5)
    Tw(fpsSFill, {Size=UDim2.new(fpsPct,0,1,0)},.5)

    -- Ping (simulado, pode substituir por HttpService)
    local ping = math.random(10, 40)
    pingVal.Text = tostring(ping).."ms"
    Tw(pingSFill,{Size=UDim2.new(1-(ping/200),0,1,0)},.5)

