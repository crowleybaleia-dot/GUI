local Hub = {}

--[[
    Adiciona um script ao grid.

    @param data {
        Icon     : string        -- Kanji/emoji do ícone
        Name     : string        -- Nome do script
        Game     : string        -- Jogo alvo
        Desc     : string        -- Descrição curta
        Status   : string        -- "Ativo" ou "OFF"
        Tags     : table         -- {"Farm","OP"} etc.
        Featured : boolean|nil   -- Destaca com borda sage
        Callback : function|nil  -- Executado ao clicar EXEC
    }
--]]
function Hub:AddScript(data)
    data = data or {}
    local entry = {
        icon     = data.Icon     or "•",
        name     = data.Name     or "Script",
        game     = data.Game     or "Universal",
        desc     = data.Desc     or "",
        status   = data.Status   or "OFF",
        tags     = data.Tags     or {},
        featured = data.Featured or false,
        callback = data.Callback,
    }
    table.insert(userScripts, entry)
    CreateCard(entry, 100 + #userScripts)
    AddLog("OK","Script registrado: "..entry.name)
end

--[[
    Exibe notificação flutuante integrada ao Hub.

    @param opts {
        Title   : string
        Message : string
        Type    : "success"|"warning"|"error"|"info"
        Duration: number|nil
    }
--]]
function Hub:Notify(opts)
    opts = opts or {}
    local typeCol = {
        success=C.Sage, warning=C.Yellow, error=C.Red, info=C.Blue,
    }
    local accent = typeCol[(opts.Type or "info"):lower()] or C.Sage
    local dur    = opts.Duration or 4

    local nc = New("Frame",{
        AnchorPoint=Vector2.new(1,1),
        Position=UDim2.new(1,-12,1,-40),
        Size=UDim2.new(0,260,0,64),
        BackgroundColor3=C.Surf2,
        BackgroundTransparency=1,
        ClipsDescendants=true,
        ZIndex=200,
    }, sg)
    Corner(nc,8)
    Stroke(nc,C.Border,1)

    New("Frame",{Size=UDim2.new(0,3,1,0), BackgroundColor3=accent, ZIndex=201}, nc)
    Label(nc,opts.Title or "Aviso",Enum.Font.GothamBold,12,C.Text,
        UDim2.new(0,14,0,8), UDim2.new(1,-18,0,16),
        Enum.TextXAlignment.Left,false,201)
    Label(nc,opts.Message or "",Enum.Font.Gotham,10,C.TextDim,
        UDim2.new(0,14,0,26), UDim2.new(1,-18,0,28),
        Enum.TextXAlignment.Left,true,201)

    local pgB = New("Frame",{
        Position=UDim2.new(0,0,1,-3), Size=UDim2.new(1,0,0,3),
        BackgroundColor3=C.Surf4, ZIndex=201,
    }, nc)
    local pgF = New("Frame",{
        Size=UDim2.new(1,0,1,0), BackgroundColor3=accent, ZIndex=202,
    }, pgB)
    Corner(pgF,2)

    Tw(nc,{BackgroundTransparency=0},.3)
    Tw(pgF,{Size=UDim2.new(0,0,1,0)},dur,Enum.EasingStyle.Linear)

    task.delay(dur,function()
        Tw(nc,{BackgroundTransparency=1},.3)
        task.wait(.35); nc:Destroy()
    end)

    AddLog((opts.Type=="error" and "ERR" or opts.Type=="warning" and "WRN" or "INF"),
        (opts.Title or "Notify")..": "..(opts.Message or ""))
end

--[[
    Limpa todos os scripts do grid (mantém os padrão se keepDefault=true).
--]]
function Hub:ClearScripts(keepDefault)
    if not keepDefault then
        for _, child in ipairs(GRID:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end
    end
    userScripts = {}
end

